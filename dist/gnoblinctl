#!/usr/bin/env bash
# gnoblinctl — Hyprctl-style client for gnoblin-shell's local control socket.
#
#   gnoblinctl dispatch <action> [arg]   e.g.  gnoblinctl dispatch snap left
#   gnoblinctl actions                   list the available actions
#   gnoblinctl inspect [--raw] [OUT]     dump the live scene inspector JSON
set -euo pipefail

usage() {
  echo "usage: gnoblinctl dispatch <action> [arg] | gnoblinctl actions | gnoblinctl inspect [--raw] [OUT]" >&2
}

request() {
  local wire="$1"
  python3 - "$wire" <<'PY'
import glob
import os
import socket
import sys

wire = sys.argv[1]


def clean_display_name(name):
    base = os.path.basename(name)
    return "".join(c if c.isalnum() or c in "._-" else "_" for c in base)


def socket_candidates():
    explicit = os.environ.get("GNOBLIN_CONTROL_SOCKET")
    if explicit:
        yield explicit

    runtime = os.environ.get("XDG_RUNTIME_DIR") or f"/run/user/{os.getuid()}"
    display = os.environ.get("WAYLAND_DISPLAY")
    if display:
        yield os.path.join(runtime, "gnoblin", f"{clean_display_name(display)}.sock")

    sockets = glob.glob(os.path.join(runtime, "gnoblin", "*.sock"))
    if len(sockets) == 1:
        yield sockets[0]


seen = set()
socket_errors = []
for path in socket_candidates():
    if not path or path in seen:
        continue
    seen.add(path)
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
            sock.settimeout(2)
            sock.connect(path)
            sock.sendall(wire.encode("utf-8") + b"\n")
            sock.shutdown(socket.SHUT_WR)
            chunks = []
            while True:
                chunk = sock.recv(65536)
                if not chunk:
                    break
                chunks.append(chunk)
        sys.stdout.write(b"".join(chunks).decode("utf-8", errors="replace"))
        sys.exit(0)
    except OSError as exc:
        socket_errors.append(f"{path}: {exc}")

# Compatibility fallback for old builds that only expose dev.gnoblin.Shell.
try:
    import gi
    gi.require_version("Gio", "2.0")
    from gi.repository import Gio, GLib
except Exception as exc:
    detail = "; ".join(socket_errors) if socket_errors else "no control socket found"
    sys.exit(f"gnoblinctl: {detail}; D-Bus fallback unavailable: {exc}")

try:
    proxy = Gio.DBusProxy.new_for_bus_sync(
        Gio.BusType.SESSION,
        Gio.DBusProxyFlags.NONE,
        None,
        "dev.gnoblin.Shell",
        "/dev/gnoblin/Shell",
        "dev.gnoblin.Shell",
        None,
    )

    if wire == "actions":
        (actions,) = proxy.call_sync("ListActions", None, Gio.DBusCallFlags.NONE, -1, None).unpack()
        print("\n".join(actions))
    elif wire == "inspect":
        (raw,) = proxy.call_sync("InspectScene", None, Gio.DBusCallFlags.NONE, -1, None).unpack()
        print(raw)
    elif wire.startswith("dispatch "):
        parts = wire.split(" ", 2)
        action = parts[1] if len(parts) > 1 else ""
        arg = parts[2] if len(parts) > 2 else ""
        proxy.call_sync("Dispatch", GLib.Variant("(ss)", (action, arg)), Gio.DBusCallFlags.NONE, -1, None)
        print("ok")
    else:
        sys.exit(f"gnoblinctl: unknown request {wire!r}")
except Exception as exc:
    detail = "; ".join(socket_errors) if socket_errors else "no control socket found"
    sys.exit(f"gnoblinctl: no running gnoblin compositor ({detail}; D-Bus fallback failed: {exc})")
PY
}

write_or_print() {
  local text="$1"
  local out="$2"

  if [ -n "$out" ] && [ "$out" != "-" ]; then
    mkdir -p "$(dirname "$out")"
    printf '%s\n' "$text" > "$out"
  else
    printf '%s\n' "$text"
  fi
}

case "${1:-}" in
  dispatch)
    if [ "$#" -lt 2 ]; then
      usage
      exit 2
    fi
    action="$2"
    shift 2
    arg="$*"
    if [ -n "$arg" ]; then
      request "dispatch $action $arg"
    else
      request "dispatch $action"
    fi
    ;;
  actions)
    request "actions"
    ;;
  inspect)
    shift
    pretty=1
    out=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --pretty|-p)
          pretty=1
          ;;
        --raw)
          pretty=0
          ;;
        -o|--output)
          if [ "$#" -lt 2 ]; then
            usage
            exit 2
          fi
          out="$2"
          shift
          ;;
        -*)
          usage
          exit 2
          ;;
        *)
          if [ -n "$out" ]; then
            usage
            exit 2
          fi
          out="$1"
          ;;
      esac
      shift
    done

    raw="$(request "inspect")"
    if [ "$pretty" -eq 1 ]; then
      formatted="$(printf '%s\n' "$raw" | python3 -m json.tool)"
    else
      formatted="$raw"
    fi
    write_or_print "$formatted" "$out"
    ;;
  *)
    usage
    exit 2
    ;;
esac
