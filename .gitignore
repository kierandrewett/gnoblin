# Dev build trees (Meson under build/)
/build/

# Installed prefix (built mutter + gnome-shell + session data) — regenerated by `just dev`
/install/

# Scratch/local packaging output. Nothing in the repo writes here by default.
/dist/

# Local packaging outputs
/packaging/**/*.rpm
/packaging/**/*.deb
/packaging/**/*.pkg.tar.*

# Editor / OS cruft
*.swp
*~
.DS_Store

# Python bytecode cache
__pycache__/
*.pyc
