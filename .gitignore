# Dev build trees (meson + cargo target-dir lives under build/)
/build/
/src/clients/target/

# Installed prefix (built mutter + clients) — regenerated by `just dev`
/install/

# Scratch capture/screenshot output. Keep gnoblinctl tracked: it is the real
# control client installed by scripts/install-userspace.sh.
/dist/*
!/dist/
!/dist/gnoblinctl

# Local packaging outputs
/packaging/**/*.rpm
/packaging/**/*.deb
/packaging/**/*.pkg.tar.*

# Editor / OS cruft
*.swp
*~
.DS_Store

# Python bytecode cache
__pycache__/
*.pyc
