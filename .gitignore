/build/
/src/clients/target/

# Installed prefix (built mutter + clients) — regenerated by `just dev`
/install/

# Scratch capture/screenshot output
/dist/

# Local packaging outputs
/packaging/**/*.rpm
/packaging/**/*.deb
/packaging/**/*.pkg.tar.*

# Editor / OS cruft
*.swp
*~
.DS_Store

# Python bytecode cache
__pycache__/
*.pyc
