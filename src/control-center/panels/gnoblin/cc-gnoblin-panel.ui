<?xml version="1.0" encoding="UTF-8"?>
<!-- gnoblin control-center panel template (plain GtkBuilder XML; no blueprint
     dependency so it builds with the stock g-c-c toolchain). Feature/grant rows
     are added at runtime from org.gnoblin.Shell; this carries only the scaffold. -->
<interface>
  <template class="CcGnoblinPanel" parent="CcPanel">
    <child type="subpage">
      <object class="AdwNavigationPage">
        <property name="title" translatable="yes">gnoblin</property>
        <child>
          <object class="AdwToolbarView">
            <child type="top">
              <object class="AdwHeaderBar"/>
            </child>
            <property name="content">
              <object class="AdwPreferencesPage">
                <child>
                  <object class="AdwBanner" id="unavailable_banner">
                    <property name="title" translatable="yes">The gnoblin shell is not running — controls are unavailable.</property>
                    <property name="revealed">False</property>
                  </object>
                </child>
                <child>
                  <object class="AdwPreferencesGroup" id="features_group">
                    <property name="title" translatable="yes">Shell Features</property>
                    <property name="description" translatable="yes">Turn built-in gnome-shell subsystems on or off so an external client can own them instead. Changes apply live.</property>
                  </object>
                </child>
                <child>
                  <object class="AdwPreferencesGroup" id="screencast_group">
                    <property name="title" translatable="yes">Screen Recording</property>
                    <property name="description" translatable="yes">Apps you have granted persistent screen-capture access. Revoke to require a fresh prompt next time.</property>
                  </object>
                </child>
                <child>
                  <object class="AdwPreferencesGroup">
                    <child>
                      <object class="AdwButtonRow" id="reload_button">
                        <property name="title" translatable="yes">Reload gnoblin</property>
                        <property name="start-icon-name">view-refresh-symbolic</property>
                        <signal name="activated" handler="on_reload_clicked" swapped="no"/>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
