// ContextMenu.slint — generic, reusable popup menu used by the desktop
// right-click handler, app-indicator clicks, and (later) appindicator menu
// items. Visual style mirrors macOS / GNOME context menus: rounded rect,
// thin border, drop-shadow, 8 px container inset, 12 px row padding,
// 34 px comfortable row height, separators are a centred 1 px hairline
// with vertical margin. The menu is positioned by the caller (via
// `x`/`y`); it sizes itself to fit `items`.

import { Tokens, Theme, TokenMode, Spacing, Radius, Motion } from "../Tokens.slint";

export struct MenuItem {
    /// Stable id passed back through `item-clicked` so callers don't have to
    /// match on label text. -1 reserves the value for separators.
    id:          int,
    label:       string,
    /// Optional accelerator hint shown right-aligned (e.g. "⌘C", "Del").
    accelerator: string,
    /// True for non-clickable separator rows.
    separator:   bool,
    /// Row opens a submenu — drawn with a trailing chevron instead of an
    /// accelerator (replaces the old ugly ">" baked into the label).
    submenu:     bool,
    /// Disabled rows render at reduced opacity and don't fire `item-clicked`.
    enabled:     bool,
}

export component ContextMenu {
    in property <[MenuItem]> items;
    /// Whether the menu is open. Caller flips to `false` on item click or
    /// outside-click; the menu fades out via the animate block.
    in property <bool>       open: false;
    /// Keyboard-selected row index. -1 means no selection (cold open).
    /// Driven by Rust on Up/Down arrow input while the menu is open;
    /// rendered as a highlight identical to the hover state. The pointer
    /// hover state still works independently (mouse takes precedence
    /// visually because `has-hover` is checked first).
    in-out property <int>    selected-index: -1;
    /// Transform-origin for the open/close scale, in the menu's own
    /// local coords. Defaults to top-left (cursor anchor for a normal
    /// drop-down menu); callers override (e.g. dock menu flips up,
    /// origin-y becomes `height`).
    in property <length>     origin-x: 0px;
    in property <length>     origin-y: 0px;
    /// Backdrop blur — same scheme as the popouts: a slice of the
    /// full-screen blurred wallpaper, offset so the visible region
    /// behind the rounded chrome matches what's actually on-screen
    /// behind us. Without these, the menu reads as opaque-grey
    /// instead of glass.
    in property <image>      backdrop;
    in property <length>     backdrop-screen-w: 1px;
    in property <length>     backdrop-screen-h: 1px;
    // Screen-y of the host surface's top edge (negative), so the slice samples
    // the correct band of wallpaper even though the menu lives in a surface
    // anchored at the bottom of the screen.
    in property <length>     backdrop-offset-y: 0px;
    in property <length>     menu-x: 0px;
    in property <length>     menu-y: 0px;

    callback item-clicked(int);
    /// Fired when the user clicks outside the menu (caller closes it).
    callback dismiss();

    width: 220px;
    // Comfortable container inset: 6px above the first row and below the last.
    height: items-col.preferred-height + 12px;

    // ── macOS-style click flicker ──────────────────────────────────────
    // When a row is clicked we don't fire `item-clicked` immediately —
    // instead we run a brief off→on blink on that row's highlight, then
    // fire. Reads as a confirmation flash before the menu dismisses,
    // matching the AppKit feel.
    //
    //   step 0: idle
    //   step 1: highlight OFF (60 ms)
    //   step 2: highlight ON  (60 ms)
    //   step 3: fire `item-clicked`, reset
    //
    // `flickering-id` is the menu-item id mid-blink; per-row bg checks
    // (`it.id == flickering-id && step == 1`) so only the clicked row
    // blinks while everything else holds.
    property <int> flicker-step: 0;
    property <int> flickering-id: -1;
    flicker-timer := Timer {
        interval: 60ms;
        running: root.flicker-step > 0 && root.flicker-step < 3;
        triggered => {
            root.flicker-step = root.flicker-step + 1;
            if (root.flicker-step >= 3) {
                root.item-clicked(root.flickering-id);
                root.flickering-id = -1;
                root.flicker-step = 0;
            }
        }
    }

    // Open/close transition. Asymmetric easing — open uses the
    // ease-in-out "in" curve so the ramp is visible; close uses
    // the libadwaita "spring" so dismissal feels snappy. Now that
    // visibility isn't culled (see comment below) the in {} block
    // actually fires; the previous attempt failed because Slint
    // tore down the menu's GPU pipeline between opens, swallowing
    // the open ramp in a first-paint stall.
    property <float> vis: 0.0;
    states [
        is-open when root.open: {
            vis: 1.0;
            in {
                animate vis {
                    duration: Tokens.motion-overlay-open-duration;
                    easing:   Tokens.motion-overlay-curve-in;
                }
            }
            out {
                animate vis {
                    duration: Tokens.motion-overlay-close-duration;
                    easing:   Tokens.motion-overlay-curve-out;
                }
            }
        }
    ]

    // ALWAYS visible (drawn at opacity ~0 when closed). The
    // alternative — culling via `visible: vis > 0.001` — caused the
    // menu's GPU pipeline (drop-shadow blur passes, glyph atlas, the
    // shadow chain) to be torn down + rebuilt on every open. The
    // first paint of the new pipeline stalls for tens of ms, swallowing
    // the open animation entirely (user reported "it's like the whole
    // thing freezes as its opening"). Close didn't stall because the
    // pipeline was already warm. Cost of always rendering: drawing a
    // 220×N rect at near-zero opacity every frame — negligible vs the
    // freeze.
    visible: true;
    opacity: root.vis;
    property <float> scale-t: Tokens.motion-overlay-scale-from
        + (1.0 - Tokens.motion-overlay-scale-from) * root.vis;

    // True transform-scale (slint 1.16+) so the entire menu — bg, rows,
    // separators, accelerator labels — shrinks as one node, like CSS
    // `transform: scale(...)`. Origin defaults to the cursor anchor
    // (top-left for drop-down menus); callers override `origin-x` /
    // `origin-y` for flipped or panel-anchored variants. Width/height
    // of the wrapper match the menu so hit-testing stays in sync with
    // the rendered geometry.
    Rectangle {
        width: parent.width;
        height: parent.height;
        transform-scale-x: root.scale-t;
        transform-scale-y: root.scale-t;
        transform-origin: { x: root.origin-x, y: root.origin-y };

    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: Theme.chrome-shadow-source;
        border-radius: Tokens.menu-corner-radius;
        drop-shadow-blur: Tokens.menu-shadow-blur;
        drop-shadow-offset-y: Tokens.menu-shadow-offset-y;
        drop-shadow-color: Theme.chrome-shadow;
    }

    bg := Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        // Transparent so the backdrop Image below shows through the
        // rounded clip. The theme-tint Rectangle on top supplies the
        // surface colour at translucent alpha — combination reads as
        // "glass over the wallpaper".
        background: transparent;
        border-radius: Tokens.menu-corner-radius;
        clip: true;

        // Backdrop slice — same glass scheme as the popouts. The full-screen
        // pre-blurred wallpaper, offset so the slice landing in the rounded clip
        // is the region actually behind the menu ON SCREEN. The menu lives in the
        // dock's bottom-anchored surface, so we offset by BOTH the surface's
        // screen position (`backdrop-offset-y`) and the menu's position within it
        // — without the surface offset the slice sampled the wrong band of
        // wallpaper, which is why it didn't match the dock/popouts.
        // (The dock pill itself gets real compositor blur because the dock's blur
        // effect covers the pill; the menu sits in the surface headroom that the
        // effect doesn't reach, hence the slice.)
        Image {
            x: -root.menu-x;
            y: root.backdrop-offset-y - root.menu-y;
            width: root.backdrop-screen-w;
            height: root.backdrop-screen-h;
            source: root.backdrop;
            image-fit: fill;
        }
        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.menu-bg;
        }

        Rectangle {
            x: Tokens.menu-corner-radius;
            y: 0px;
            width: parent.width - 2 * Tokens.menu-corner-radius;
            height: Tokens.chrome-highlight-height;
            background: Theme.menu-highlight;
        }

        items-col := VerticalLayout {
            x: 0; y: 6px;
            width: parent.width;
            spacing: 2px;
            padding-left: 7px;
            padding-right: 7px;

            for it[i] in root.items: Rectangle {
                // Comfortable 30px rows with a rounded highlight inset from the
                // menu edge; no per-item separators (grouping is by spacing).
                height: it.separator ? 9px : 30px;
                width: parent.width - 14px;
                // Highlight via either input: pointer hover OR the
                // keyboard's `selected-index`. Tried wiring hover
                // through `selected-index` for unification, but that
                // raced with the keyboard handler — the `changed
                // has-hover` callback would re-fire and stomp the
                // index Rust had just set. Cheaper and more reliable
                // to OR the two and accept that both inputs may
                // highlight different rows for a frame.
                property <bool> active: !it.separator && it.enabled
                                          && (i == root.selected-index
                                              || row-touch.has-hover);
                // Mid-flicker (step 1 = "off"), force this row's bg to
                // transparent regardless of `active` — that's the brief
                // "blink" before the action fires. Step 2 returns the
                // accent. Other rows are unaffected.
                property <bool> blinking-off: it.id == root.flickering-id
                                              && root.flicker-step == 1;
                background: blinking-off
                    ? transparent
                    : (active ? Theme.surface-active-bg : transparent);
                // Hover / keyboard-selected highlight tweens in, so the
                // accent fills under the pointer instead of snapping —
                // 100ms ease-out sits in the 80–150ms hover band. Kept
                // short so the 60ms click-flicker blink still reads as a
                // crisp flash rather than smearing into a slow fade.
                animate background {
                    duration: Motion.fast;
                    easing: Motion.fast-curve;
                }
                border-radius: Radius.sm;

                // Separator hairline — only visible when `it.separator`.
                // Centred vertically in the 11px row so the hairline has
                // ~5px of breathing room above and below instead of
                // sitting flush against the neighbouring rows.
                Rectangle {
                    x: Spacing.xs; y: parent.height / 2 - 0.5px;
                    width: parent.width - 2 * Spacing.xs;
                    height: 1px;
                    background: Theme.mode == TokenMode.Dark
                        ? rgba(255, 255, 255, 0.08)
                        : rgba(0, 0, 0, 0.08);
                    visible: it.separator;
                }

                // TouchArea is always present (id stable) but disabled for
                // separators / disabled rows. Slint doesn't let us access an
                // id declared inside an `if` from sibling expressions, so
                // we keep it unconditional and rely on `enabled`.
                row-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    // The menu stays `visible: true` at opacity 0 to keep
                    // Slint's render pipeline warm between opens. Gate input
                    // separately so invisible menus cannot be clicked.
                    enabled: root.open && !it.separator && it.enabled;
                    // Trigger the flicker; the timer fires
                    // `item-clicked` after blink. Guard against double
                    // clicks while a flicker is already in flight.
                    clicked => {
                        if (root.flicker-step == 0) {
                            root.flickering-id = it.id;
                            root.flicker-step = 1;
                        }
                    }
                }

                // Accelerator label (right-aligned). 0px width when empty so
                // it contributes nothing to layout.
                acc := Text {
                    x: parent.width - self.width - 12px;
                    y: 0;
                    width: it.accelerator == "" ? 0px : self.preferred-width;
                    height: parent.height;
                    text: it.accelerator;
                    // Highlighted row gets white-ish accelerator text;
                    // resting state uses the muted secondary fg.
                    color: parent.active
                        ? rgba(255, 255, 255, 0.85)
                        : (it.enabled ? Theme.text-secondary : rgba(128, 128, 128, 0.38));
                    font-family: Tokens.font-family;
                    font-size: 12px;
                    vertical-alignment: center;
                    visible: !it.separator;
                }

                Text {
                    x: 12px; y: 0;
                    // 12px inset on each side + a 12px gap before the
                    // right-aligned accelerator so the label and shortcut
                    // never crowd each other.
                    width: parent.width - 24px - acc.width
                        - (it.accelerator == "" ? 0px : 12px)
                        - (it.submenu ? 18px : 0px);
                    height: parent.height;
                    text: it.label;
                    color: parent.active
                        ? rgba(255, 255, 255, 0.98)
                        : (it.enabled ? Theme.text-primary : rgba(128, 128, 128, 0.44));
                    font-family: Tokens.font-family;
                    font-size: 13px;
                    vertical-alignment: center;
                    overflow: elide;
                    visible: !it.separator;
                }

                // Submenu chevron — a crisp vector "›", right-aligned, replacing
                // the old ">" character that used to be baked into the label.
                if it.submenu: Path {
                    x: parent.width - 21px;
                    y: parent.height / 2 - 5px;
                    width: 6px;
                    height: 10px;
                    viewbox-width: 6;
                    viewbox-height: 10;
                    stroke: parent.active
                        ? rgba(255, 255, 255, 0.92)
                        : Theme.text-secondary;
                    stroke-width: 1.5px;
                    MoveTo { x: 1.5; y: 1; }
                    LineTo { x: 5; y: 5; }
                    LineTo { x: 1.5; y: 9; }
                }
            }
        }
    }

    Rectangle {
        x: Tokens.chrome-hairline-width;
        y: Tokens.chrome-hairline-width;
        width: parent.width - 2 * Tokens.chrome-hairline-width;
        height: parent.height - 2 * Tokens.chrome-hairline-width;
        background: transparent;
        border-radius: Tokens.menu-corner-radius - Tokens.chrome-hairline-width;
        border-width: Tokens.chrome-hairline-width;
        border-color: Theme.menu-border;
    }
    }
}
