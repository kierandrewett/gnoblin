// WindowChrome.slint — Server-side decoration chrome for a single toplevel window.
// Renders per WINDOW_SPEC, supporting both dark and light mode via the Theme global.
//
//   - configurable border-radius outer (circular arc approximation of squircle SDF)
//   - configurable hairline border — alpha varies by mode × focus state (animated)
//   - 1 px inner highlight gradient — brighter in light mode / active state
//   - Drop shadow: one strong layer (Slint limit); GPU agent adds the other two
//   - Title bar: 33 px, background varies by mode × focus (animated)
//   - Controls: close/min/max right-aligned 21×21px circles with 6px insets
//
// Approximations documented:
//   - border-radius is circular arc not squircle SDF
//   - Only one drop-shadow layer (Slint per-element limit)
//   - subpixel borders depend on the renderer/device scale
//
// Animation strategy:
//   The component holds locally-resolved colour properties whose values change
//   based on Theme.mode and the `focused` in-property.  Slint `animate` blocks
//   on these local properties produce the 200 ms ease-in-out crossfade whenever
//   either the mode or focus state changes.

import { Tokens, Theme, TokenMode } from "./Tokens.slint";
import { IconButton } from "./widgets/IconButton.slint";
import { SurfaceItem } from "./SurfaceItem.slint";

export component WindowChrome {
    // ── Properties ────────────────────────────────────────────────────────────
    in property <string> title: "Window";
    in property <bool>   focused: true;
    // The wayland surface texture — fed by Rust each commit.
    in property <image>  content;
    // Animation values from the Rust spring engine.
    // 1.0 = fully visible / full size; 0.0 = invisible / shrunk.
    in property <float>  anim-opacity: 1.0;
    in property <float>  anim-scale:   1.0;
    // Alt-tab ring selection highlight.
    in property <bool>   alt-tab-selected: false;
    // Source-clip rect on the client surface, in buffer pixel coords.
    // CSD clients render their own shadow/border/corners into the buffer;
    // xdg_surface.set_window_geometry tells us the visible inner rect, and we
    // clip the Image to that so only the bare client content shows. SSD
    // clients pass full buffer dims and the clip is a no-op.
    in property <int>    content-clip-x: 0;
    in property <int>    content-clip-y: 0;
    in property <int>    content-clip-w: 0;
    in property <int>    content-clip-h: 0;
    // Per-surface render-element list (Phase 4 of the architectural
    // rewrite). When non-empty, the content-area below renders a Repeater
    // over these instead of the legacy single `content` Image. Each
    // SurfaceItem positions independently inside the content-area.
    in property <[SurfaceItem]> surfaces: [];
    // ClientSide-decoration mode (Firefox / GTK header-bar apps). When true,
    // the client paints its own titlebar / border / shadow into the buffer,
    // so we hide our SSD titlebar + Slint border + drop-shadow and let the
    // client surface fill the entire window rect.
    in property <bool>   csd: false;
    // Maximized — the window fills the work area. Corner rounding + drop-
    // shadow collapse so the window sits flush against the screen edges.
    in property <bool>   maximized: false;
    // Geometry is animating (maximize / unmaximize) or being drag-resized.
    in property <bool>   resizing: false;
    // Animated outer corner radius in logical px (Rust springs it between
    // the themed radius and 0 across a maximize / unmaximize).
    in property <float>  corner-radius-px: 18;

    // Effective corner radius as a length — squared off (0) when maximized,
    // the themed squircle radius otherwise, smoothly interpolated.
    property <length> corner-radius: root.corner-radius-px * 1px;

    // ── Callbacks ─────────────────────────────────────────────────────────────
    callback close-clicked();
    callback minimize-clicked();
    callback maximize-clicked();
    // Fired when the user clicks the titlebar (to activate/raise this window).
    callback title-clicked();

    // ── Geometry — caller positions this component absolutely ─────────────────
    min-width:  200px;
    min-height: Tokens.titlebar-height + 100px;

    // ── Locally-resolved colour properties (animated) ─────────────────────────
    // Each one computes the "target" colour from the current mode + focus state.
    // Slint sees the value change and drives the animate block.

    property <color> resolved-border: Theme.mode == TokenMode.Dark
        ? (focused ? Tokens.border-dark-active   : Tokens.border-dark-inactive)
        : (focused ? Tokens.border-light-active  : Tokens.border-light-inactive);

    property <color> resolved-titlebar-bg: Theme.mode == TokenMode.Dark
        ? (focused ? Tokens.titlebar-bg-dark-active   : Tokens.titlebar-bg-dark-inactive)
        : (focused ? Tokens.titlebar-bg-light-active  : Tokens.titlebar-bg-light-inactive);

    // Opaque backing colour for the titlebar — the translucent
    // `resolved-titlebar-bg` overlays this so transparency never reveals the
    // wallpaper. Mode-only (no focus dependency) so animations stay stable.
    property <color> resolved-titlebar-solid-bg: Theme.mode == TokenMode.Dark
        ? Tokens.titlebar-bg-dark-active
        : Tokens.titlebar-bg-light-active;

    property <color> resolved-titlebar-fg: Theme.mode == TokenMode.Dark
        ? Tokens.titlebar-fg-dark
        : Tokens.titlebar-fg-light;

    property <color> resolved-titlebar-border: Theme.mode == TokenMode.Dark
        ? Tokens.titlebar-border-dark
        : Tokens.titlebar-border-light;

    // Inner top-edge highlight alpha. Tuned MUCH lower than the original
    // WINDOW_SPEC values — at 0.08/0.50 the highlight strip stamped a
    // bright white band across the top of every window, very obvious on
    // dark content (terminals, code editors). The "highlight" is now a
    // gentle hint of top-down lighting, not a gloss bar.
    property <color> resolved-highlight-top: Theme.mode == TokenMode.Dark
        ? (focused ? rgba(255,255,255,0.04) : rgba(255,255,255,0.02))
        : (focused ? rgba(255,255,255,0.18) : rgba(255,255,255,0.10));

    // Content area background (no focus dependency — mode only).
    property <color> resolved-content-bg: Theme.window-content-bg;

    // Window control tint.
    property <color> resolved-control-bg:         Theme.control-bg;
    property <color> resolved-control-bg-hover:   Theme.control-bg-hover;
    property <color> resolved-control-bg-pressed: Theme.control-bg-pressed;
    property <color> resolved-control-icon-tint:  Theme.control-icon-tint;

    // ── Animation blocks — 200 ms ease-in-out on all colour transitions ───────
    animate resolved-border              { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-titlebar-bg         { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-titlebar-solid-bg   { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-titlebar-fg         { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-titlebar-border     { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-highlight-top       { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-content-bg          { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-control-bg          { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-control-bg-hover    { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-control-bg-pressed  { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }
    animate resolved-control-icon-tint   { duration: Tokens.motion-fade-duration; easing: Tokens.motion-fade-curve; }

    // ── Lifecycle animations ──────────────────────────────────────────────────
    // Opacity fade comes from the spring; scale comes from `anim-scale`
    // applied to outer-frame's width/height with x/y centring offsets so the
    // chrome shrinks/grows around its centre. The drop-shadow stays attached
    // to outer-frame so it scales with the chrome rather than ghosting.
    opacity: root.anim-opacity;

    // ── Outer frame with border and shadow ────────────────────────────────────
    // For CSD clients (Firefox / GTK header-bar apps), the border, drop-
    // shadow, and titlebar collapse out and the client surface paints over
    // the chrome. The chrome STILL has an opaque content bg so transparent
    // pixels in the buffer (and the brief moment before the first commit)
    // never reveal the wallpaper through the window.
    outer-frame := Rectangle {
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        width:  parent.width  * root.anim-scale;
        height: parent.height * root.anim-scale;

        // Squircle radius applies in BOTH SSD and CSD modes — the rounded
        // corners are part of our chrome aesthetic and clip the (cropped)
        // client surface to the squircle on CSD apps too. The 1 px border
        // is SSD-only; CSD apps draw their own internal border (or none).
        //
        // For CSD: bg is TRANSPARENT. The client buffer's anti-aliased
        // rounded corners gradient from opaque (interior content) to
        // alpha=0 (the drop-shadow padding GTK includes around the
        // visible window). If our outer-frame bg is opaque (e.g.
        // `window-content-bg = #1d1d1d`), it bleeds through that
        // gradient and reads as a bright halo at the corners — exactly
        // what the user described as "window background behind on the
        // corners". Transparent here lets the wallpaper / windows
        // beneath show through the same alpha gradient the buffer
        // intends, so the corner blend reads correctly. The clip
        // radius (root.corner-radius, 18 px) rounds at least as much
        // as GTK's own ~15-16 px, so the clip arc sits at or outside
        // the app's corner — never inside it (14 px was the old bug
        // that glowed; see Tokens window-corner-radius-outer).
        border-radius: root.corner-radius;
        border-width:  root.csd ? 0px : Tokens.chrome-hairline-width;
        border-color:  root.resolved-border;
        background:    root.csd ? transparent : root.resolved-content-bg;
        clip:          true;

        // Drop shadow — single Slint layer. Skipped for CSD (client paints
        // its own) and when maximized (window is flush to the screen edges,
        // a shadow would just bleed onto the panel / dock).
        drop-shadow-blur:     (root.csd || root.maximized) ? 0px : Tokens.window-shadow-blur;
        drop-shadow-offset-y: (root.csd || root.maximized) ? 0px : Tokens.window-shadow-offset-y;
        drop-shadow-color:    (root.csd || root.maximized)
            ? rgba(0, 0, 0, 0.0) : Theme.chrome-shadow;

        // ── Solid titlebar backing — SSD only ──────────────────────────
        // For CSD, the client owns its header bar (GTK headerbar, app
        // title, header buttons). Our backing here used to render at
        // light-mode `titlebar-bg-light-active` (#ffffff) regardless,
        // which leaked through as a white strip across the top of
        // every CSD app whose buffer didn't quite cover the very top
        // pixel row (rounded corners, sub-pixel positioning, etc.).
        // Hiding it for CSD lets the client's own buffer be the only
        // thing painted at the titlebar region.
        titlebar-backing := Rectangle {
            x: 0; y: 0;
            width: parent.width;
            height: Tokens.titlebar-height;
            background: root.resolved-titlebar-solid-bg;
            border-top-left-radius: root.corner-radius;
            border-top-right-radius: root.corner-radius;
            border-bottom-left-radius: 0px;
            border-bottom-right-radius: 0px;
            visible: !root.csd;
        }

        // ── Title bar (SSD only — for CSD the client paints its own
        // header bar into the buffer, so collapsing this whole subtree
        // removes the slint TouchAreas that would otherwise eat clicks
        // intended for the client's window controls.)
        titlebar := Rectangle {
            x: 0; y: 0;
            width: parent.width;
            height: Tokens.titlebar-height;
            visible: !root.csd;
            background: root.resolved-titlebar-bg;
            border-top-left-radius: root.corner-radius;
            border-top-right-radius: root.corner-radius;
            border-bottom-left-radius: 0px;
            border-bottom-right-radius: 0px;

            // Titlebar click-to-activate / double-click-to-maximise touch
            // area. Sized to cover the LEFT region of the titlebar only —
            // explicitly excluding the controls block at the right — so it
            // can never compete with the IconButton TouchAreas for the
            // close / minimize / maximize click events. Without this carve-
            // out the user's clicks on the close button were being eaten
            // by titlebar-touch (Slint's nested-TouchArea routing rules
            // depend on order and bounds; the cleanest fix is non-
            // overlapping bounds).
            titlebar-touch := TouchArea {
                x: 0; y: 0;
                width: parent.width
                     - (Tokens.control-size * 3 + Tokens.control-gap * 2)
                     - Tokens.control-inset * 2;
                height: parent.height;
                // CSD apps own their titlebar — clicks at y < 33 must reach
                // the wayland client (header-bar buttons, search, window
                // menu). Disable the SSD click-grab so the event falls
                // through to the compositor's surface_under routing.
                enabled: !root.csd;
                clicked => { root.title-clicked(); }
                double-clicked => { root.maximize-clicked(); }
            }

            // 0.5 px bottom divider (1 px at reduced alpha).
            Rectangle {
                x: 0;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: root.resolved-titlebar-border;
                opacity: 0.80;
            }

            // Title text — reserved bbox is symmetric around the titlebar's
            // horizontal centre. Width is parent minus 2× the right-side
            // controls block (so the same padding sits on each side); the
            // text element's `horizontal-alignment: center` then puts the
            // glyphs at the titlebar's true centre.
            property <length> reserve: Tokens.control-size * 3 + Tokens.control-gap * 2
                                     + Tokens.control-inset + 4px;
            Text {
                x: parent.reserve;
                y: 0;
                width: parent.width - parent.reserve * 2;
                height: parent.height;
                text: root.title;
                color: root.resolved-titlebar-fg;
                font-family: Tokens.font-family;
                font-size: Tokens.titlebar-font-size;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }

            // ── Window controls ──────────────────────────────────────────────
            controls := Rectangle {
                x: parent.width
                    - (Tokens.control-size * 3 + Tokens.control-gap * 2)
                    - Tokens.control-inset;
                y: Tokens.control-inset;
                width: Tokens.control-size * 3 + Tokens.control-gap * 2;
                height: Tokens.control-size;
                background: transparent;

                // Minimize (leftmost)
                minimize-btn := IconButton {
                    x: 0;
                    y: 0;
                    diameter: Tokens.control-size;
                    bg: root.resolved-control-bg;
                    bg-hover: root.resolved-control-bg-hover;
                    bg-pressed: root.resolved-control-bg-pressed;
                    icon: @image-url("assets/minimize.svg");
                    icon-tint: root.resolved-control-icon-tint;
                    clicked => { root.minimize-clicked(); }
                }

                // Maximize (middle)
                maximize-btn := IconButton {
                    x: Tokens.control-size + Tokens.control-gap;
                    y: 0;
                    diameter: Tokens.control-size;
                    bg: root.resolved-control-bg;
                    bg-hover: root.resolved-control-bg-hover;
                    bg-pressed: root.resolved-control-bg-pressed;
                    icon: @image-url("assets/maximize.svg");
                    icon-tint: root.resolved-control-icon-tint;
                    clicked => { root.maximize-clicked(); }
                }

                // Close (rightmost) — same neutral hover as the other
                // controls; the red-tint variant felt heavy.
                close-btn := IconButton {
                    x: (Tokens.control-size + Tokens.control-gap) * 2;
                    y: 0;
                    diameter: Tokens.control-size;
                    bg: root.resolved-control-bg;
                    bg-hover: root.resolved-control-bg-hover;
                    bg-pressed: root.resolved-control-bg-pressed;
                    icon: @image-url("assets/close.svg");
                    icon-tint: root.resolved-control-icon-tint;
                    clicked => { root.close-clicked(); }
                }
            }
        }

        // ── Client content area ───────────────────────────────────────────────
        // No background colour: the only thing visible here is the client
        // surface texture. Filling with `Theme.window-content-bg` showed a
        // theme-coloured rectangle behind the buffer wherever the client
        // committed transparent pixels (e.g. terminal apps that don't fill
        // every cell), which read as "the chrome is wider than the canvas".
        // Transparent background lets the wallpaper show through unused
        // buffer regions, matching how transparent terminals render on most
        // compositors.
        content-area := Rectangle {
            x: 0;
            // CSD clients fill the full chrome rect; SSD clients sit below
            // our titlebar so the chrome's titlebar stays visible above.
            y: root.csd ? 0px : Tokens.titlebar-height;
            width: parent.width;
            height: root.csd ? parent.height : parent.height - Tokens.titlebar-height;
            background: transparent;
            // For CSD the content-area covers the FULL window (including
            // where the titlebar would render), so it needs all four
            // corners rounded to match outer-frame's squircle. For SSD
            // only the bottom corners — the titlebar above carries the top
            // corners.
            border-top-left-radius:     root.csd ? root.corner-radius : 0px;
            border-top-right-radius:    root.csd ? root.corner-radius : 0px;
            border-bottom-left-radius:  root.corner-radius;
            border-bottom-right-radius: root.corner-radius;
            clip: true;

            // Legacy single-texture path — used when the per-surface
            // `surfaces` list is empty (a freshly-mapped window before
            // its first commit) AND while the window is resizing. During
            // a maximize / unmaximize / drag-resize the chrome animates
            // at 60 fps but the client re-commits its buffer far slower;
            // this single texture is `image-fit: fill` so it stretches to
            // the animating frame, keeping the content visually smooth
            // (it snaps back to the crisp per-surface path once settled).
            Image {
                visible: root.surfaces.length == 0 || root.resizing;
                width: parent.width;
                height: parent.height;
                source: root.content;
                source-clip-x: root.content-clip-w > 0 ? root.content-clip-x : 0;
                source-clip-y: root.content-clip-h > 0 ? root.content-clip-y : 0;
                source-clip-width:  root.content-clip-w > 0
                    ? root.content-clip-w : root.content.width;
                source-clip-height: root.content-clip-h > 0
                    ? root.content-clip-h : root.content.height;
                image-fit: fill;
                image-rendering: pixelated;
            }

            // Per-surface render path: each wl_surface positioned
            // independently with its own src-clip. When this list is
            // non-empty it covers the legacy Image above. Source-clip
            // honours wp_viewporter src crop and (for the toplevel)
            // xdg_surface.set_window_geometry. Hidden during a resize so
            // the stretched legacy texture above carries the animation.
            for s in root.surfaces: Image {
                visible: !root.resizing;
                x: s.x-in-window * 1px;
                y: s.y-in-window * 1px;
                width: s.w * 1px;
                height: s.h * 1px;
                source: s.texture;
                source-clip-x:      s.src-x;
                source-clip-y:      s.src-y;
                source-clip-width:  s.src-w;
                source-clip-height: s.src-h;
                image-fit: fill;
                image-rendering: pixelated;
            }
        }

        // ── Inner highlight overlay (on top of everything) ────────────────────
        // Subtle top-edge gradient that simulates top-down ambient light on
        // glass. Drawn flush with the outer-frame's edges (no 1 px inset)
        // so the chrome's content-bg can't bleed through between the
        // highlight and the rounded outline. Wrapped in a clip rect with
        // the same squircle radius as outer-frame so the gradient
        // respects the corners.
        highlight := Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            border-radius: root.corner-radius;
            background: transparent;
            border-width: 0;
            clip: true;
            // SSD only. For CSD the client paints its own headerbar / top
            // edge; stamping our white top-edge gradient over it reads as a
            // bright inner glow strip across the top of the window — the
            // "glow in CSD windows" the user reported.
            visible: !root.csd;

            // Top-edge highlight strip — fades over the first 12 px so it
            // reads as a soft glow, not a hard 2 px band.
            Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: 12px;
                background: @linear-gradient(180deg,
                    root.resolved-highlight-top 0%,
                    rgba(255, 255, 255, 0.00) 100%);
            }
        }

        // ── Alt-tab selection outline ─────────────────────────────────────────
        // A bright ring that appears when this window is selected in the
        // alt-tab switcher. Drawn on top of everything.
        if root.alt-tab-selected: Rectangle {
            x: -2px;
            y: -2px;
            width: parent.width + 4px;
            height: parent.height + 4px;
            border-radius: root.corner-radius + 2px;
            border-width: 2px;
            border-color: rgba(100, 180, 255, 0.90);
            background: transparent;
        }
    } // end outer-frame
}
