        Theme.motion-fade-style == 30 ? MotionCurves.c30 :
        MotionCurves.c4;

    // ── Z-order layers ────────────────────────────────────────────────────────
    //   wallpaper:  0
    //   windows:   10
    //   layers-bg: 20
    //   layers-top: 30
    //   dock:       40
    //   panel:      50
}

// ── Spacing scale ─────────────────────────────────────────────────────────────
// The 4px spacing scale from the slint-design skill. Reference these named
// lengths from layout `padding`/`spacing` instead of magic numbers so the whole
// shell shares one rhythm. See .claude/skills/slint-design/SKILL.md §1.
//
//   xs  →  4px   tight pairs (label↔value, icon↔text in a chip)
//   sm  →  8px   between buttons, list-row inset, chip padding
//   md  → 12px   icon↔text in a row, inter-group spacing
//   lg  → 16px   default container padding (cards, popouts, rows)
//   xl  → 24px   section separation, generous card padding
//   xxl → 32px   page-level gutters
export global Spacing {
    out property <length> xs:   4px;
    out property <length> sm:   8px;
    out property <length> md:  12px;
    out property <length> lg:  16px;
    out property <length> xl:  24px;
    out property <length> xxl: 32px;
}

// ── Corner radius scale ───────────────────────────────────────────────────────
// Nesting radii from the slint-design skill (§4 "Radii nest"): an inner radius
// is smaller than the outer one. A button (sm) inside a card (lg) reads right.
//
//   sm →  8px   buttons, chips, inner controls
//   md → 12px   tiles, small surfaces
//   lg → 14px   cards, popout containers
export global Radius {
    out property <length> sm:  8px;
    out property <length> md: 12px;
    out property <length> lg: 14px;
}

// ── Motion scale ──────────────────────────────────────────────────────────────
// A complete, NAMED duration + easing scale matching the slint-design skill's
// duration bands (§6 "Motion & animation"). Reference these from `animate`
// blocks so the whole shell shares one motion vocabulary instead of retyping
// magic millisecond values.
//
// This global is ADDITIVE — it complements the existing `Tokens.motion-*`
// overlay/fade tokens (which remain the source of truth for overlay open/close
// choreography) by giving every other interaction a named band to reach for.
//
//   Durations (skill §6):
//     fast    → 120ms   hover / press / micro-feedback (band 80–150ms)
//     medium  → 200ms   state changes, toggles, small moves (band 150–250ms)
//     overlay → 240ms   menu / popout / dialog enter-exit (band 200–300ms)
//
//   Easing (skill §6 — never `linear` for UI):
//     ease-out-curve    → arriving / appearing / hover-in (decelerate in)
//     ease-in-curve     → leaving
//     ease-in-out-curve → moving / morphing between two on-screen states
export global Motion {
    // ── Durations ─────────────────────────────────────────────────────────────
    out property <duration> fast:    1ms * Theme.motion-fast-ms * Theme.motion-scale;
    out property <duration> medium:  1ms * Theme.motion-medium-ms * Theme.motion-scale;
    out property <duration> overlay: 1ms * Theme.motion-overlay-ms * Theme.motion-scale;
    out property <duration> page:    1ms * Theme.motion-page-ms * Theme.motion-scale;

    // ── Easing curves ─────────────────────────────────────────────────────────
    out property <easing> fast-curve:
        Theme.motion-fast-style == 0  ? MotionCurves.c0  :
        Theme.motion-fast-style == 1  ? MotionCurves.c1  :
        Theme.motion-fast-style == 2  ? MotionCurves.c2  :
        Theme.motion-fast-style == 3  ? MotionCurves.c3  :
