// ComponentZoo.slint — preview surface for reusable layer-shell primitives.
//
// This is a development aid for humans and agents: when a new popout, dock
// affordance, or toolbar needs controls, start from these primitives instead of
// inventing fresh button/tile chrome in the feature file.

import { Tokens, Theme, ShellPalette, Spacing } from "./Tokens.slint";
import { ShellRoundButton, ShellSliderRow, ShellTile } from "./Popouts.slint";

export component LayerShellComponentZoo inherits Rectangle {
    in-out property <float> volume-value: 0.62;

    width: 420px;
    height: 360px;
    background: Theme.surface-bg;
    border-radius: Tokens.popout-corner-radius;

    VerticalLayout {
        x: Spacing.lg;
        y: Spacing.lg;
        width: parent.width - 2 * Spacing.lg;
        height: parent.height - 2 * Spacing.lg;
        spacing: Spacing.md;

        Text {
            text: "Layer Shell Primitives";
            color: ShellPalette.fg;
            font-family: Tokens.font-family;
            font-size: 15px;
            font-weight: 700;
        }

        HorizontalLayout {
            spacing: Spacing.sm;
            ShellRoundButton { icon: @image-url("../assets/icons/symbolic/user.svg"); }
            ShellRoundButton { icon: @image-url("../assets/icons/symbolic/settings.svg"); }
            ShellRoundButton { icon: @image-url("../assets/icons/symbolic/lock.svg"); }
            ShellRoundButton { icon: @image-url("../assets/icons/symbolic/power.svg"); }
        }

        HorizontalLayout {
            spacing: Spacing.sm;
            ShellTile {
                icon: @image-url("../assets/icons/symbolic/ethernet.svg");
                title: "Wired";
                active: true;
            }
            ShellTile {
                icon: @image-url("../assets/icons/symbolic/wifi.svg");
                title: "Wi-Fi";
                subtitle: "Network";
                active: true;
            }
        }

        ShellSliderRow {
            icon: @image-url("../assets/icons/symbolic/volume.svg");
            label: "Output";
            value <=> root.volume-value;
        }

        HorizontalLayout {
            spacing: Spacing.sm;
            ShellTile {
                compact: true;
                show-chevron: false;
                icon: @image-url("../assets/icons/symbolic/bell-off.svg");
                title: "Do Not Disturb";
            }
            ShellTile {
                compact: true;
                show-chevron: false;
                icon: @image-url("../assets/icons/symbolic/moon.svg");
                title: "Night Light";
            }
        }
    }
}
