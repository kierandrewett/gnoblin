// IconButton.slint — Reusable clickable icon button with hover/press colour
// feedback. Used by WindowChrome control buttons and dock icons.

import { Tokens, Theme, Motion } from "../Tokens.slint";

export component IconButton {
    in property <length> diameter: 28px;
    in property <color>  bg: transparent;
    in property <color>  bg-hover: rgba(255, 255, 255, 0.15);
    in property <color>  bg-pressed: rgba(255, 255, 255, 0.25);
    in property <image>  icon;
    in property <color>  icon-tint: rgba(255, 255, 255, 0.80);

    callback clicked();

    width: diameter;
    height: diameter;

    // Resolved background depending on interaction state.
    property <color> resolved-bg: touch.pressed
        ? bg-pressed
        : (touch.has-hover ? bg-hover : bg);

    // Circular button background.
    circle := Rectangle {
        width: root.diameter;
        height: root.diameter;
        border-radius: root.diameter / 2;
        background: root.resolved-bg;

        animate background {
            duration: Motion.fast;
            easing: Motion.fast-curve;
        }

        icon-img := Image {
            width: root.diameter * 0.62;
            height: self.width;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            source: root.icon;
            colorize: root.icon-tint;
            image-fit: contain;

            animate width {
                duration: Motion.fast;
                easing: Motion.fast-curve;
            }
        }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}
