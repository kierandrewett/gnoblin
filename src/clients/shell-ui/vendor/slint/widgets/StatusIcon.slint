// StatusIcon.slint — a panel status glyph (network, audio, power, etc.).
// Renders the symbolic `icon` image, tinted via `colorize`; falls back to a
// small rounded square only when no image is provided.

import { Tokens, Theme, Motion } from "../Tokens.slint";

export component StatusIcon {
    // Symbolic icon image — optional.  If empty the fallback square is shown.
    in property <image>  icon;
    in property <string> name;          // for accessibility / tooltip (future)
    in property <color>  tint: Tokens.panel-fg;
    in property <length> icon-size: 16px;

    width: icon-size;
    height: icon-size;

    // Fallback coloured square when no icon image is available.
    fallback := Rectangle {
        visible: root.icon.width == 0 || root.icon.height == 0;
        width: root.icon-size;
        height: root.icon-size;
        background: root.tint;
        border-radius: 4px;
        opacity: 0.80;

        animate background {
            duration: Motion.fast;
            easing: Motion.fast-curve;
        }
    }

    // Actual icon image — shown when the Rust side feeds a real Image.
    icon-img := Image {
        visible: !fallback.visible;
        width: root.icon-size;
        height: root.icon-size;
        source: root.icon;
        colorize: root.tint;
        image-fit: contain;

        animate colorize {
            duration: Motion.fast;
            easing: Motion.fast-curve;
        }
    }
}
