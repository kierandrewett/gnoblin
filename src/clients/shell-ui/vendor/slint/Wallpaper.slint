// Wallpaper.slint — Full-screen desktop background image.
// The Rust side loads a PNG/JPG and pushes it via the `source` property.
// Falls back to a solid dark colour when no image is provided.

import { Theme } from "./Tokens.slint";

export component Wallpaper {
    // The wallpaper image.  Rust sets this after loading the file.
    in property <image> source;

    width: 100%;
    height: 100%;

    // Fallback background colour, visible before image loads.
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.wallpaper-fallback-bg;
    }

    // Wallpaper image — shown on top of the fallback once loaded.
    Image {
        width: parent.width;
        height: parent.height;
        source: root.source;
        image-fit: cover;
    }
}
