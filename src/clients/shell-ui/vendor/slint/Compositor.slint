// Compositor.slint — Top-level component for the Slint-based Wayland compositor.
// Composes: wallpaper, layer-shell background, layer-shell bottom,
//           windows/chrome, layer-shell top, internal shell chrome,
//           layer-shell overlay, client popups, cursor.
//
// The Rust side owns the event loop (calloop) and feeds all data through the
// exported properties below.  Callbacks fire user interactions back to Rust.
//
// ── Rust-bindable contract ──────────────────────────────────────────────────
//   in property <[WindowItem]>  windows    — ordered list of toplevels
//   in property <[LayerItem]>   layers     — external layer-shell surfaces
//   in property <string>        focused-app
//   in property <string>        clock-text
//   in property <image>         wallpaper
//   in property <[DockItem]>    dock-items
//   in property <TokenMode>     theme-mode — set from Rust to switch light/dark
//   Callbacks: close-window, minimize-window, maximize-window,
//              activate-window, launch-app
//
// Z-order (Slint requires integer literals for `z`):
//   0  — wallpaper
//   1  — layer-shell background
//   5  — layer-shell bottom
//   10 — windows
//   30 — layer-shell top
//   40-88 — built-in shell chrome and debug UI
//   90 — layer-shell overlay
//   92 — client popups
//   99 — cursor

import { Tokens, Theme, TokenMode, Motion } from "./Tokens.slint";
import { Wallpaper } from "./Wallpaper.slint";
import { Panel, GlobalMenuTopItem } from "./Panel.slint";
import { Dock, DockItem } from "./Dock.slint";
import { WindowChrome } from "./WindowChrome.slint";
import { SurfaceItem } from "./SurfaceItem.slint";
import { LayerSurface } from "./LayerSurface.slint";
import { DatetimePopout, ControlCentrePopout, CalendarDay, CalendarWeekday } from "./Popouts.slint";
import { LayerShellComponentZoo } from "./ComponentZoo.slint";
import { ContextMenu, MenuItem } from "./widgets/ContextMenu.slint";
import { TrayIconItem } from "./widgets/TrayItem.slint";

// Re-export so Rust bindings see these structs.
export { MenuItem }
export { TrayIconItem }
export { LayerShellComponentZoo }

// ── Cursor overlay ────────────────────────────────────────────────────────────
// The cursor image is rendered as a Slint Image at the top of the z-stack.
// Rust feeds the rasterised cursor icon (already the right shape+rotation) and
// the current pointer position.  We hide the OS cursor so ours is the only one.

// ── Shared data structures ────────────────────────────────────────────────────

// A single toplevel window fed by the Rust compositor state.
export struct WindowItem {
    id:      int,
    title:   string,
    // Geometry in compositor-space pixels.
    x:       int,
    y:       int,
    w:       int,
    h:       int,
    focused: bool,
    // Legacy single-texture path: the surface tree CPU-composited into
    // one buffer. Phase 1 of the per-surface rewrite keeps this populated
    // alongside `surfaces` so we can flip the WindowChrome render path
    // independently. Once `surfaces` is in use everywhere, this is
    // removed.
    texture: image,
    // Per-surface render elements. One entry per wl_surface in this
    // window's tree, ordered back-to-front (toplevel first, subsurfaces
    // stacking above). Empty during the transition for windows that
    // haven't been migrated to the per-surface path yet — readers must
    // fall back to `texture` when this is empty.
    surfaces: [SurfaceItem],
    // Optional application icon.
    icon:    image,
    // Animation values driven by the Rust spring engine (0.0–1.0).
    // The Slint WindowChrome reads these to drive opacity / scale.
    anim-opacity: float,   // 0.0 = invisible, 1.0 = fully visible
    anim-scale:   float,   // 0.92 = shrunk, 1.0 = full size
    // Whether this window is currently selected in the alt-tab ring.
    alt-tab-selected: bool,
    // Visible-window rect *within* the client's buffer (in buffer pixel
    // coords). CSD clients (GTK / libadwaita / Firefox) paint shadow + border
    // + rounded corners INTO their surface; xdg_surface.set_window_geometry
    // tells us the inner rect to actually display. We crop the texture down
    // to this rect so we can wrap the bare client surface in our own SSD
    // border / shadow / corners. SSD clients leave this equal to the buffer.
    geom-x: int,
    geom-y: int,
    geom-w: int,
    geom-h: int,
    // True when the client requested ClientSide decorations via xdg-decoration
    // (Firefox / GTK apps with their own header bar). When set, WindowChrome
    // skips its own titlebar / border / shadow and shows only the buffer —
    // the client paints its full chrome inside the surface.
    csd: bool,
    // True when the window is maximized. WindowChrome drops its
    // drop-shadow so the window sits flush to the screen edges.
    maximized: bool,
    // Animated outer corner radius in logical px. Rust springs this
    // between the themed radius and 0 as the window maximizes /
    // unmaximizes, so the corners round off and square up smoothly.
    corner-radius: float,
    // True while the window geometry is animating (maximize / unmaximize)
    // or being drag-resized. WindowChrome renders the legacy single
    // texture stretched to fill the animating frame instead of the
    // fixed-size per-surface elements — the client commits new buffers
    // far slower than 60 fps, so without the stretch the content visibly
    // steps while the chrome animates smoothly.
    resizing: bool,
}

// A layer-shell surface from an external client.
export struct LayerItem {
    id:            int,
    surface:       image,
    // Resolved screen position (Rust computes from anchor + exclusive zone).
    x:             int,
    y:             int,
    w:             int,
    h:             int,
    // wlr-layer-shell layer ordinal: 0=background, 1=bottom, 2=top, 3=overlay.
    layer-ordinal: int,
}

// A mapped xdg_popup (context menu, dropdown, autocomplete). Position is in
// compositor-space pixels — Rust resolves parent-relative offsets per-frame
// in `update_windows`.
//
// `texture` is the legacy composite (kept while popups transition to the
// per-surface model — empty when surfaces[] is populated). `surfaces` is
// the per-surface render-element list, same model as WindowItem; this is
// what unlocks libadwaita popover transitions / animated subsurfaces.
export struct PopupItem {
    id:      int,
    x:       int,
    y:       int,
    w:       int,
    h:       int,
    texture: image,
    surfaces: [SurfaceItem],
    // Buffer dimensions and the VISIBLE rect within the buffer (from
    // xdg_surface.set_window_geometry). When set, the legacy texture path
    // crops the buffer to (vis-x, vis-y, w, h) so we don't render the
    // client's own drop-shadow gutter as a second border around our chrome.
    // Zero `buf-w/h` → use the whole buffer (no client-side gutter).
    buf-w:   int,
    buf-h:   int,
    vis-x:   int,
    vis-y:   int,
}

// TrayIconItem now lives in widgets/TrayItem.slint so Panel can import it.

// Re-export DockItem so importers of Compositor.slint can use it directly.
export { DockItem }
// Re-export GlobalMenuTopItem (defined in Panel.slint) for Rust bindings.
export { GlobalMenuTopItem }
// Re-export TokenMode for Rust bindings.
export { TokenMode }

// ── Top-level Compositor component ───────────────────────────────────────────
export component Compositor inherits Window {
    // ── Inbound properties (Rust → Slint) ─────────────────────────────────────
    in property <[WindowItem]>     windows;
    in property <[LayerItem]>      layers;
    in property <[PopupItem]>      popups;
    in property <[TrayIconItem]>   tray-items;
    callback tray-clicked(int);
    callback tray-right-clicked(int);
    in property <string>        focused-app: "";
    in property <string>        clock-text: "00:00";
    /// Short date string for the panel's clock zone (e.g. "Wed 29 Apr").
    in property <string>        panel-date-text: "";
    in property <image>         wallpaper;
    in property <[DockItem]>    dock-items;
    // Theme mode — Rust writes this; Theme global reads it.
    in property <TokenMode>     theme-mode: TokenMode.Dark;
    // Pre-blurred wallpaper used as the panel/dock backdrop.
    in property <image>         wallpaper-blurred;

    // ── Popouts ───────────────────────────────────────────────────────────────
    in-out property <bool>      datetime-popout-open: false;
    in-out property <bool>      control-centre-open:  false;
    in property <string>        popout-date-text: "";
    in property <string>        popout-day-text:  "";
    /// Header for the calendar widget — e.g. "April 2026".
    in property <string>        popout-calendar-month-text: "";
    /// 42-cell calendar grid (6 rows × 7 cols).
    in property <[CalendarDay]> popout-calendar-days;
    /// Six ISO week labels, one per visible calendar row.
    in property <[int]>         popout-calendar-week-numbers;
    /// Seven localized weekday labels, Monday first.
    in property <[CalendarWeekday]> popout-weekday-labels;
    /// Calendar navigation — Rust handles the offset accounting.
    callback popout-calendar-prev();
    callback popout-calendar-next();
    callback popout-calendar-day-clicked(int);

    // ── Window (per-titlebar) context menu ───────────────────────────────────
    // Right-clicking a window's titlebar opens this. Same machinery as the
    // desktop menu — Rust pushes items + position, slint owns the open
    // animation + click-absorber + flicker. `window-menu-target-id` is the
    // WM id of the window the menu was opened for, fed back through
    // `window-menu-clicked` so Rust can route the action to the right
    // window without lookup tables.
    in-out property <bool>           window-menu-open: false;
    in-out property <int>            window-menu-x: 0;
    in-out property <int>            window-menu-y: 0;
    in-out property <int>            window-menu-w: 220;
    in-out property <int>            window-menu-h: 0;
    in-out property <int>            window-menu-origin-x: 0;
    in-out property <int>            window-menu-origin-y: 0;
    in-out property <int>            window-menu-target-id: -1;
    in-out property <int>            window-menu-selected: -1;
    in property      <[MenuItem]>    window-menu-items;
    callback window-menu-clicked(int, int);  // (target-id, action-id)

    // ── Global menu (KDE-style appmenu) ──────────────────────────────────────
    // Top-level menu bar for the focused window, rendered in the panel's
    // left zone. Empty when the focused app exports no global menu.
    in property      <[GlobalMenuTopItem]> global-menu-bar;
    // The submenu popup — a ContextMenu dropped below the clicked bar entry.
    in property      <[MenuItem]>    global-menu-items;
    in-out property  <bool>          global-menu-open: false;
    in-out property  <int>           global-menu-x: 0;
    in-out property  <int>           global-menu-y: 0;
    in-out property  <int>           global-menu-selected: -1;
    // Index of the bar entry whose submenu is currently open (-1 = none) —
    // the panel highlights it.
    in-out property  <int>           global-menu-open-index: -1;
    // Bar entry clicked: (dbusmenu node id, screen x of the entry).
    callback global-menu-entry-clicked(int, length);
    // Submenu row activated: dbusmenu node id.
    callback global-menu-item-activated(int);

    // ── Desktop context menu ─────────────────────────────────────────────────
    in-out property <bool>           desktop-menu-open: false;
    in-out property <int>            desktop-menu-x:    0;
    in-out property <int>            desktop-menu-y:    0;
    in property      <[MenuItem]>    desktop-menu-items;
    /// Keyboard-driven selection index (Up/Down arrows). Rust mutates
    /// this directly while the menu is open; -1 means "no selection".
    /// Reset on close.
    in-out property <int>            desktop-menu-selected: -1;
    /// True when Rust's right-click handler placed the menu *above* the
    /// cursor (i.e. cursor was too close to the bottom of the screen).
    /// Drives `transform-origin`: the scale should grow out of the
    /// click point, which is bottom-left when flipped, top-left when
    /// not. Push from Rust the same time as the menu position.
    /// Scale-origin for the open/close animation, in menu-local coords.
    /// Rust pushes the cursor's offset *inside* the menu rect — the
    /// menu itself is clamped to the screen edge (GNOME-style), so
    /// the cursor sits somewhere within the menu rather than on its
    /// corner. Scaling outward from there feels like the menu is
    /// pulled out by the click point.
    in-out property <int>            desktop-menu-origin-x: 0;
    in-out property <int>            desktop-menu-origin-y: 0;
    /// Rendered menu height — Rust pushes it so the dock right-click
    /// flip-up math has a real number to subtract.
    in-out property <int>            desktop-menu-h: 0;
    callback desktop-menu-clicked(int);

    // ── App launcher overlay (Super+Space) ───────────────────────────────────
    in-out property <bool>     launcher-open: false;
    in-out property <string>   launcher-query: "";
    callback launcher-submit(string);

    // ── Dock per-app context menu ────────────────────────────────────────────
    in-out property <bool>           dock-menu-open: false;
    in-out property <int>            dock-menu-x: 0;
    in-out property <int>            dock-menu-y: 0;
    in-out property <string>         dock-menu-app-id: "";
    in property      <[MenuItem]>    dock-menu-items;
    /// Rendered height of the dock context menu, in logical pixels.
    /// Pushed from Rust (`compute_menu_height`) so the icon-right-click
    /// flip-up math anchors the menu's BOTTOM at the cursor instead of
    /// guessing a hardcoded 280 px and leaving a visible gap.
    in property <int>                dock-menu-h: 0;
    in-out property <int>            dock-menu-selected: -1;
    callback dock-menu-clicked(string, int);

    // ── Tray (StatusNotifierItem / DBusMenu) per-icon menu ──────────────────
    // The tray-row right-clicks a tray icon → Rust kicks off a DBusMenu
    // GetLayout fetch on a worker thread, then populates `tray-menu-items`
    // + flips `tray-menu-open` on the next event-loop tick. `tray-menu-id`
    // is the SNI item id so `tray-menu-clicked` can route the Event call
    // back to the right service without a separate lookup table.
    in-out property <bool>           tray-menu-open: false;
    in-out property <int>            tray-menu-x: 0;
    in-out property <int>            tray-menu-y: 0;
    in-out property <int>            tray-menu-id: 0;
    in property      <[MenuItem]>    tray-menu-items;
    in-out property <int>            tray-menu-selected: -1;
    callback tray-menu-clicked(int, int);

    // ── Snap preview overlay ─────────────────────────────────────────────────
    in property <bool>          snap-preview-visible: false;
    in property <int>           snap-preview-x:  0;
    in property <int>           snap-preview-y:  0;
    in property <int>           snap-preview-w:  0;
    in property <int>           snap-preview-h:  0;

    // ── Debug + help overlays ────────────────────────────────────────────────
    in-out property <bool>      debug-overlay-visible: false;
    in property <string>        debug-text: "";
    // Sliding window of per-frame render durations (ms). Rust pushes one
    // sample per render; the debug overlay draws it as a bar chart.
    in property <[float]>       debug-frame-times: [];
    in-out property <bool>      help-overlay-visible: false;

    // ── Cursor overlay (Rust → Slint) ─────────────────────────────────────────
    // The rasterised cursor icon (correct shape, rotation already baked in).
    in property <image>         cursor-image;
    // Current pointer position in compositor logical pixels.
    in property <float>         cursor-x: 0.0;
    in property <float>         cursor-y: 0.0;
    // Hotspot offset within the cursor image (pixels from top-left of icon).
    in property <float>         cursor-hotspot-x: 4.0;
    in property <float>         cursor-hotspot-y: 2.0;
    // Cursor icon size (square).
    in property <float>         cursor-size: 32.0;
    /// True when our compositor cursor should render. Clients can request
    /// "hide cursor" via `wl_pointer.set_cursor(NULL)` (e.g. video players
    /// in fullscreen, drawing apps); this property toggles the overlay.
    in property <bool>          cursor-visible: true;

    // ── Callbacks (Slint → Rust) ───────────────────────────────────────────────
    callback close-window(int);
    callback minimize-window(int);
    callback maximize-window(int);
    callback activate-window(int);
    callback launch-app(string);

    // Panel forwarding.
    callback toggle-datetime-popout();
    callback toggle-control-centre();
    // Theme-mode toggle (control centre tile).
    callback toggle-theme();

    // ── Root geometry ─────────────────────────────────────────────────────────
    // The Rust side sets the window to fullscreen; default to 1920×1080 for
    // slint-viewer preview.
    preferred-width:  1920px;
    preferred-height: 1080px;
    background: transparent;
    no-frame: true;

    // ── Theme mode binding ────────────────────────────────────────────────────
    // Rust calls ui.set_theme_mode(TokenMode::Light) which sets this property.
    // We watch changes to theme-mode and forward them to Theme.mode so all
    // components that reference Theme.mode pick up the new value and animate.
    // This uses a property-change reactive binding via the changed pseudoevent.
    changed theme-mode => { Theme.mode = root.theme-mode; }


    // ── Layer 0: Wallpaper ────────────────────────────────────────────────────
    Wallpaper {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        source: root.wallpaper;
        z: 0;
    }

    // ── Protocol layer-shell: Background ─────────────────────────────────────
    for layer in root.layers: LayerSurface {
        visible: layer.layer-ordinal == 0;
        surface: layer.surface;
        surface-x: layer.x * 1px;
        surface-y: layer.y * 1px;
        surface-width: layer.w * 1px;
        surface-height: layer.h * 1px;
        z: 1;
    }

    // ── Protocol layer-shell: Bottom ─────────────────────────────────────────
    for layer in root.layers: LayerSurface {
        visible: layer.layer-ordinal == 1;
        surface: layer.surface;
        surface-x: layer.x * 1px;
        surface-y: layer.y * 1px;
        surface-width: layer.w * 1px;
        surface-height: layer.h * 1px;
        z: 5;
    }

    // ── Layer 2: Windows with SSD chrome ─────────────────────────────────────
    // Wrapped in a clipping rectangle that clips ONLY the top edge (panel) —
    // windows are allowed to extend behind the dock. The post-chrome dock
    // re-blit already overlays the dock pixels on top, so windows running
    // "under" the dock visually disappear behind it without us hard-cutting
    // them off (which made the user lose the bottom of windows when dragged
    // down).
    Rectangle {
        x: 0;
        y: Tokens.panel-height;
        width: parent.width;
        height: parent.height - Tokens.panel-height;
        background: transparent;
        clip: true;
        z: 10;

        for win in root.windows: WindowChrome {
            // Coordinates are still in compositor (output) space, so subtract
            // the parent's y offset to convert into the clip rect's local space.
            //
            // Size from the client's `xdg_surface.set_window_geometry` rect
            // (the visible content, excluding any CSD-baked shadow padding)
            // plus our 33 px SSD titlebar when applicable. Using geom_w/h
            // makes the chrome footprint match what the user actually sees
            // and lets the buffer render 1:1 inside `content-area` (no
            // image-fit stretching → text stays crisp).
            x: win.x * 1px;
            y: win.y * 1px - parent.y;
            // Chrome size tracks the ANIMATED w/h (set instantly during
            // resize) rather than `geom-w/geom-h` (which only update on
            // client commit, ~16 ms later). Without this, dragging
            // a corner whose math anchors the opposite edge — e.g.
            // SouthWest, where the right edge should stay fixed — the
            // chrome's right edge would visibly drift right by `dx`
            // every frame because we used (instant new x) + (lagging
            // old geom-w). Now the chrome shrinks/grows in lockstep
            // with the position update; the buffer briefly stretches
            // by a few percent until the client commits at the new
            // size, which is far less perceptible than the drift.
            width: max(1px, win.w * 1px);
            height: max(1px, (win.h + (win.csd ? 0 : 33)) * 1px);
            title: win.title;
            focused: win.focused;
            content: win.texture;
            content-clip-x: win.geom-x;
            content-clip-y: win.geom-y;
            content-clip-w: win.geom-w;
            content-clip-h: win.geom-h;
            // Per-surface render-element list (Phase 4). If empty,
            // WindowChrome falls back to the legacy single `content`
            // texture path. As clients commit on the new path, their
            // surfaces[] list populates and the Repeater inside
            // WindowChrome takes over.
            surfaces: win.surfaces;
            anim-opacity: win.anim-opacity;
            anim-scale: win.anim-scale;
            alt-tab-selected: win.alt-tab-selected;
            csd: win.csd;
            maximized: win.maximized;
            resizing: win.resizing;
            corner-radius-px: win.corner-radius;

            close-clicked    => { root.close-window(win.id); }
            minimize-clicked => { root.minimize-window(win.id); }
            maximize-clicked => { root.maximize-window(win.id); }
            title-clicked    => { root.activate-window(win.id); }
        }
    }

    // ── Protocol layer-shell: Top ────────────────────────────────────────────
    for layer in root.layers: LayerSurface {
        visible: layer.layer-ordinal == 2;
        surface: layer.surface;
        surface-x: layer.x * 1px;
        surface-y: layer.y * 1px;
        surface-width: layer.w * 1px;
        surface-height: layer.h * 1px;
        z: 30;
    }

    // ── Layer 4: Dock ─────────────────────────────────────────────────────────
    dock := Dock {
        x: 0;
        y: parent.height - self.height;
        width: parent.width;
        z: 40;
        items: root.dock-items;
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        backdrop-offset-y: -(parent.height - self.height);
        icon-clicked(app-id) => { root.launch-app(app-id); }
        icon-right-clicked(app-id) => {
            // Open the dock context menu above the cursor (220 px wide).
            // The menu's actual height comes from `dock-menu-h` (pushed
            // by Rust based on the items model) so the bottom edge sits
            // exactly at the cursor instead of leaving a 60–110 px gap.
            // 8 px breathing room between the menu bottom and cursor for
            // visual separation.
            root.dock-menu-app-id = app-id;
            root.dock-menu-x = clamp(root.cursor-x - 110, 8,
                parent.width / 1px - 228);
            root.dock-menu-y = clamp(root.cursor-y - root.dock-menu-h - 8,
                40, parent.height / 1px - root.dock-menu-h - 10);
            root.dock-menu-open = true;
        }
    }

    // ── Layer 5: Panel ────────────────────────────────────────────────────────
    panel := Panel {
        x: 0; y: 0;
        width: parent.width;
        z: 50;
        focused-app: root.focused-app;
        clock-text: root.clock-text;
        date-text: root.panel-date-text;
        tray-items: root.tray-items;
        tray-clicked(id) => { root.tray-clicked(id); }
        tray-right-clicked(id) => { root.tray-right-clicked(id); }
        global-menu-bar: root.global-menu-bar;
        global-menu-open-index: root.global-menu-open-index;
        global-menu-clicked(id, x) => { root.global-menu-entry-clicked(id, x); }
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        toggle-datetime-popout => {
            root.datetime-popout-open = !root.datetime-popout-open;
            if (root.datetime-popout-open) { root.control-centre-open = false; }
            root.toggle-datetime-popout();
        }
        toggle-control-centre => {
            root.control-centre-open = !root.control-centre-open;
            if (root.control-centre-open) { root.datetime-popout-open = false; }
            root.toggle-control-centre();
        }
    }

    // ── Layer 5c: Desktop / appindicator context menu ────────────────────────
    // Click-absorber for OUTSIDE clicks. Use `clicked` (left-only,
    // respects z-order grab) instead of `pointer-event` — the latter
    // fires for events grabbed by higher-z TouchAreas (like a menu
    // row), which short-circuits the row's flicker and dismisses the
    // menu before the click registers. Right-click dismiss is handled
    // in the winit `MouseInput` pre-dispatch so we don't need this
    // absorber to catch right-down.
    if root.desktop-menu-open: TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 79;
        clicked => {
            root.desktop-menu-open = false;
            root.desktop-menu-selected = -1;
        }
    }
    desktop-menu := ContextMenu {
        x: root.desktop-menu-x * 1px;
        y: root.desktop-menu-y * 1px;
        z: 80;
        items: root.desktop-menu-items;
        open: root.desktop-menu-open;
        selected-index: root.desktop-menu-selected;
        // Scale-origin = cursor offset within the menu (Rust pushes it).
        origin-x: root.desktop-menu-origin-x * 1px;
        origin-y: root.desktop-menu-origin-y * 1px;
        // Backdrop blur — full-screen wallpaper image + this menu's
        // own screen position so the slice inside the rounded clip is
        // the slice behind it on the actual screen.
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        menu-x: root.desktop-menu-x * 1px;
        menu-y: root.desktop-menu-y * 1px;
        item-clicked(id) => {
            root.desktop-menu-open = false;
            root.desktop-menu-selected = -1;
            root.desktop-menu-clicked(id);
        }
        dismiss => {
            root.desktop-menu-open = false;
            root.desktop-menu-selected = -1;
        }
    }

    // ── Dock per-app context menu (separate so it can have its own items) ─
    if root.dock-menu-open: TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 81;
        clicked => {
            root.dock-menu-open = false;
            root.dock-menu-selected = -1;
        }
    }
    dock-menu := ContextMenu {
        x: root.dock-menu-x * 1px;
        y: root.dock-menu-y * 1px;
        z: 82;
        items: root.dock-menu-items;
        open: root.dock-menu-open;
        selected-index: root.dock-menu-selected;
        // Dock menus always flip up out of the icon — origin is
        // bottom-left so the scale grows out of the icon, not down
        // from the menu's top edge.
        origin-x: 0px;
        origin-y: root.dock-menu-h * 1px;
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        menu-x: root.dock-menu-x * 1px;
        menu-y: root.dock-menu-y * 1px;
        item-clicked(id) => {
            root.dock-menu-open = false;
            root.dock-menu-selected = -1;
            root.dock-menu-clicked(root.dock-menu-app-id, id);
        }
        dismiss => {
            root.dock-menu-open = false;
            root.dock-menu-selected = -1;
        }
    }

    // ── Tray DBusMenu popup (separate ContextMenu instance) ─────────────────
    if root.tray-menu-open: TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 83;
        clicked => {
            root.tray-menu-open = false;
            root.tray-menu-selected = -1;
        }
    }
    // ── Window (titlebar) context menu ──────────────────────────────────────
    if root.window-menu-open: TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 85;
        clicked => {
            root.window-menu-open = false;
            root.window-menu-selected = -1;
        }
    }
    window-menu := ContextMenu {
        x: root.window-menu-x * 1px;
        y: root.window-menu-y * 1px;
        z: 86;
        items: root.window-menu-items;
        open: root.window-menu-open;
        selected-index: root.window-menu-selected;
        origin-x: root.window-menu-origin-x * 1px;
        origin-y: root.window-menu-origin-y * 1px;
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        menu-x: root.window-menu-x * 1px;
        menu-y: root.window-menu-y * 1px;
        item-clicked(id) => {
            root.window-menu-open = false;
            root.window-menu-selected = -1;
            root.window-menu-clicked(root.window-menu-target-id, id);
        }
        dismiss => {
            root.window-menu-open = false;
            root.window-menu-selected = -1;
        }
    }

    tray-menu := ContextMenu {
        x: root.tray-menu-x * 1px;
        y: root.tray-menu-y * 1px;
        z: 84;
        items: root.tray-menu-items;
        open: root.tray-menu-open;
        selected-index: root.tray-menu-selected;
        // Tray menu drops out of the panel's right side — origin
        // top-right so the scale grows out of the tray icon row.
        origin-x: 220px;
        origin-y: 0px;
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        menu-x: root.tray-menu-x * 1px;
        menu-y: root.tray-menu-y * 1px;
        item-clicked(id) => {
            root.tray-menu-open = false;
            root.tray-menu-selected = -1;
            root.tray-menu-clicked(root.tray-menu-id, id);
        }
        dismiss => {
            root.tray-menu-open = false;
            root.tray-menu-selected = -1;
        }
    }

    // ── Global menu submenu popup (KDE appmenu) ─────────────────────────────
    // Dropped below the panel from whichever bar entry was clicked.
    if root.global-menu-open: TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 87;
        clicked => {
            root.global-menu-open = false;
            root.global-menu-selected = -1;
            root.global-menu-open-index = -1;
        }
    }
    global-menu := ContextMenu {
        x: root.global-menu-x * 1px;
        y: root.global-menu-y * 1px;
        z: 88;
        items: root.global-menu-items;
        open: root.global-menu-open;
        selected-index: root.global-menu-selected;
        // Drops straight down out of the panel bar entry.
        origin-x: 0px;
        origin-y: 0px;
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        menu-x: root.global-menu-x * 1px;
        menu-y: root.global-menu-y * 1px;
        item-clicked(id) => {
            root.global-menu-open = false;
            root.global-menu-selected = -1;
            root.global-menu-open-index = -1;
            root.global-menu-item-activated(id);
        }
        dismiss => {
            root.global-menu-open = false;
            root.global-menu-selected = -1;
            root.global-menu-open-index = -1;
        }
    }

    // ── Protocol layer-shell: Overlay ────────────────────────────────────────
    for layer in root.layers: LayerSurface {
        visible: layer.layer-ordinal == 3;
        surface: layer.surface;
        surface-x: layer.x * 1px;
        surface-y: layer.y * 1px;
        surface-width: layer.w * 1px;
        surface-height: layer.h * 1px;
        z: 90;
    }

    // ── Protocol client popups: xdg_popup and layer-shell popups ─────────────
    // Drawn after the four layer-shell protocol bands. Position is
    // compositor-space — Rust resolves parent-relative offsets when
    // populating PopupItem each frame.
    for popup in root.popups: Rectangle {
        x: popup.x * 1px;
        y: popup.y * 1px;
        width: popup.w * 1px;
        height: popup.h * 1px;
        z: 92;
        clip: true;
        // No background / border / drop-shadow on this container — modern
        // popup clients (Firefox, Chromium, libadwaita) paint their own
        // chrome into the buffer. Stacking ours on top doubles the border
        // and shadow, which manifests as a "thick frame around the menu".
        // Legacy single-texture path — used when surfaces[] is empty
        // (X11 override-redirect popups, or popups before first commit).
        Image {
            visible: popup.surfaces.length == 0;
            width: parent.width;
            height: parent.height;
            source: popup.texture;
            image-fit: fill;
            // Crop the buffer to the VISIBLE rect set via
            // xdg_surface.set_window_geometry. Zero buf-w/h means the
            // whole buffer is visible (client didn't set a window-geometry).
            source-clip-x: popup.vis-x;
            source-clip-y: popup.vis-y;
            source-clip-width: popup.buf-w > 0 ? popup.w : 0;
            source-clip-height: popup.buf-h > 0 ? popup.h : 0;
        }
        // Per-surface render path: lets libadwaita / GTK popovers
        // animate their internal subsurfaces (transitions on dropdown
        // menus, search results, etc.).
        for s in popup.surfaces: Image {
            x: s.x-in-window * 1px;
            y: s.y-in-window * 1px;
            width: s.w * 1px;
            height: s.h * 1px;
            source: s.texture;
            source-clip-x:      s.src-x;
            source-clip-y:      s.src-y;
            source-clip-width:  s.src-w;
            source-clip-height: s.src-h;
            image-fit: fill;
            image-rendering: pixelated;
        }
    }

    // ── Layer 6: Snap preview overlay ────────────────────────────────────────
    snap-preview := Rectangle {
        x: root.snap-preview-x * 1px;
        y: root.snap-preview-y * 1px;
        width: root.snap-preview-w * 1px;
        height: root.snap-preview-h * 1px;
        z: 45;
        border-radius: 12px;
        border-width: 2px;
        border-color: rgba(96, 165, 250, 0.85);
        background: rgba(96, 165, 250, 0.18);
        opacity: root.snap-preview-visible ? 1.0 : 0.0;
        animate opacity { duration: Motion.fast; easing: Motion.fast-curve; }
    }

    // ── Layer 6: Popouts ─────────────────────────────────────────────────────
    if root.datetime-popout-open || root.control-centre-open: TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 55;
        clicked => {
            root.datetime-popout-open = false;
            root.control-centre-open  = false;
        }
    }

    datetime-popout := DatetimePopout {
        x: (parent.width - self.width) / 2;
        y: Tokens.panel-height + 6px;
        z: 60;
        open: root.datetime-popout-open;
        clock-text: root.clock-text;
        date-text: root.popout-date-text;
        day-text: root.popout-day-text;
        calendar-month-text: root.popout-calendar-month-text;
        calendar-days: root.popout-calendar-days;
        calendar-week-numbers: root.popout-calendar-week-numbers;
        weekday-labels: root.popout-weekday-labels;
        // Centred under the clock — scale grows out of the top-centre,
        // i.e. the panel edge directly above where the clock lives.
        origin-x: self.width / 2;
        origin-y: 0px;
        // Backdrop blur — pass the full-screen blurred wallpaper plus
        // the popout's own screen position so the inner Image samples
        // the right slice.
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        popout-x: self.x;
        popout-y: self.y;
        prev-month => { root.popout-calendar-prev(); }
        next-month => { root.popout-calendar-next(); }
        day-clicked(day) => { root.popout-calendar-day-clicked(day); }
    }

    control-centre-popout := ControlCentrePopout {
        x: parent.width - self.width - 14px;
        y: Tokens.panel-height + 6px;
        z: 60;
        open: root.control-centre-open;
        theme-toggle-clicked => {
            root.toggle-theme();
            // Don't auto-close so the user can immediately see the
            // accent / icon-bg flip on the Dark Style tile.
        }
        // Anchored to the panel's right edge (system icons cluster) —
        // origin top-right so the panel "unfolds out" of the icons.
        origin-x: self.width;
        origin-y: 0px;
        backdrop: root.wallpaper-blurred;
        backdrop-screen-w: parent.width;
        backdrop-screen-h: parent.height;
        popout-x: self.x;
        popout-y: self.y;
    }

    // ── Layer 69: Hit-rect inspector (visual) ────────────────────────────────
    // When debug overlay is on, draw the WM hit-rect for every window as a
    // bright outline with a label. EDGE_ZONE band is shown as a faint inner
    // ring. Use this to compare what the hit-test thinks against the visual
    // chrome and to diagnose stray resize-cursor zones.
    if root.debug-overlay-visible: Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 69;
        background: transparent;

        for win in root.windows: Rectangle {
            // Outer hit-rect — must match WindowManager::surface_under and
            // pointer_click_focus in wm/mod.rs, which gate on geom_w/geom_h
            // (the visible content rect, excluding any CSD shadow padding).
            // Drawing using win.w/win.h here would falsely show the buffer
            // bounds, which can be wider than the rect we actually accept
            // pointer events inside.
            x: win.x * 1px;
            y: win.y * 1px;
            width: win.geom-w * 1px;
            height: (win.geom-h + (win.csd ? 0 : 33)) * 1px;
            background: transparent;
            border-width: 1px;
            border-color: rgba(255, 220, 0, 0.85);

            // Tiny corner label so multiple windows don't overlap text.
            Rectangle {
                x: 0; y: 0;
                width: 130px;
                height: 14px;
                background: rgba(0, 0, 0, 0.75);
                Text {
                    x: 4px; y: 0;
                    width: parent.width - 8px;
                    height: parent.height;
                    text: "WM #" + win.id + "  " + win.geom-w + "×" + win.geom-h
                          + (win.csd ? " CSD" : " SSD");
                    color: #ffd400;
                    font-family: "monospace";
                    font-size: 9px;
                    vertical-alignment: center;
                }
            }

            // Inner faint ring at EDGE_ZONE = 12 px to show the resize band.
            Rectangle {
                x: 12px; y: 12px;
                width: parent.width - 24px;
                height: parent.height - 24px;
                background: transparent;
                border-width: 1px;
                border-color: rgba(255, 220, 0, 0.30);
            }
        }
    }

    // ── Layer 68: App launcher overlay (Spotlight-style) ─────────────────────
    if root.launcher-open: TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 67;
        clicked => { root.launcher-open = false; }
    }
    if root.launcher-open: Rectangle {
        x: (parent.width - self.width) / 2;
        y: 120px;
        width: 540px;
        height: 64px;
        z: 68;
        background: transparent;
        border-radius: Tokens.menu-corner-radius;
        clip: false;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.chrome-shadow-source;
            border-radius: Tokens.menu-corner-radius;
            drop-shadow-blur: Tokens.menu-shadow-blur;
            drop-shadow-offset-y: Tokens.menu-shadow-offset-y;
            drop-shadow-color: Theme.chrome-shadow;
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.menu-bg;
            border-radius: Tokens.menu-corner-radius;
            clip: true;

            Rectangle {
                x: Tokens.menu-corner-radius;
                y: Tokens.chrome-hairline-width / 2;
                width: parent.width - 2 * Tokens.menu-corner-radius;
                height: Tokens.chrome-highlight-height;
                background: Theme.menu-highlight;
            }
        }

        Rectangle {
            x: Tokens.chrome-hairline-width;
            y: Tokens.chrome-hairline-width;
            width: parent.width - 2 * Tokens.chrome-hairline-width;
            height: parent.height - 2 * Tokens.chrome-hairline-width;
            background: transparent;
            border-radius: Tokens.menu-corner-radius - Tokens.chrome-hairline-width;
            border-width: Tokens.chrome-hairline-width;
            border-color: Theme.menu-border;
        }

        Image {
            x: 16px;
            y: (parent.height - 22px) / 2;
            width: 22px;
            height: 22px;
            source: @image-url("../assets/icons/symbolic/search.svg");
            colorize: Theme.mode == TokenMode.Dark
                ? rgba(255, 255, 255, 0.55)
                : rgba(0, 0, 0, 0.45);
        }

        launcher-input := TextInput {
            x: 50px;
            y: 0;
            width: parent.width - 60px;
            height: parent.height;
            text <=> root.launcher-query;
            color: Theme.mode == TokenMode.Dark
                ? rgba(255, 255, 255, 0.95)
                : rgba(0, 0, 0, 0.92);
            font-family: Tokens.font-family;
            font-size: 18px;
            single-line: true;
            vertical-alignment: center;
            accepted => {
                root.launcher-submit(root.launcher-query);
                root.launcher-open = false;
                root.launcher-query = "";
            }
        }
    }

    // ── Layer 70: Debug overlay (devtools) ───────────────────────────────────
    if root.debug-overlay-visible: Rectangle {
        x: 12px;
        y: Tokens.panel-height + 12px;
        width: 360px;
        height: parent.height - Tokens.panel-height - 96px;
        z: 70;
        background: transparent;
        border-radius: Tokens.popout-corner-radius;
        clip: false;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.chrome-shadow-source;
            border-radius: Tokens.popout-corner-radius;
            drop-shadow-blur: Tokens.popout-shadow-blur;
            drop-shadow-offset-y: Tokens.popout-shadow-offset-y;
            drop-shadow-color: Theme.chrome-shadow;
        }

        content := Rectangle {
            x: 0; y: 0;
            width: parent.width;
            height: parent.height;
            background: Theme.surface-bg;
            border-radius: Tokens.popout-corner-radius;
            clip: true;

            Rectangle {
                x: Tokens.popout-corner-radius;
                y: Tokens.chrome-hairline-width / 2;
                width: parent.width - 2 * Tokens.popout-corner-radius;
                height: Tokens.chrome-highlight-height;
                background: Theme.menu-highlight;
            }

            Rectangle {
                x: 0; y: 0;
                width: parent.width;
                height: 32px;
                background: Theme.mode == TokenMode.Dark
                    ? rgba(255, 255, 255, 0.04)
                    : rgba(0, 0, 0, 0.03);
                Text {
                    x: 14px; y: 0;
                    width: parent.width - 28px;
                    height: parent.height;
                    text: "Debug";
                    color: Theme.mode == TokenMode.Dark
                        ? rgba(255, 255, 255, 0.85)
                        : rgba(0, 0, 0, 0.80);
                    font-family: Tokens.font-family;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }

            // ── FPS chart ────────────────────────────────────────────────────
            // Bars = per-frame render duration. y-axis: 0ms (bottom) → 50ms
            // (top). Faint horizontal lines mark the 60fps (16.67ms) and 30fps
            // (33.33ms) thresholds. Bars colour green/yellow/red against those
            // same thresholds — so spikes pop visually even if the line markers
            // wash out against the panel background.
            Rectangle {
                x: 14px;
                y: 40px;
                width: parent.width - 28px;
                height: 64px;
                background: Theme.mode == TokenMode.Dark
                    ? rgba(0, 0, 0, 0.35)
                    : rgba(0, 0, 0, 0.06);
                border-radius: 6px;
                clip: true;

                // 60fps reference line.
                Rectangle {
                    x: 0; width: parent.width;
                    y: parent.height * (1.0 - 16.67 / 50.0) - 0.5px;
                    height: 1px;
                    background: rgba(120, 220, 140, 0.35);
                }
                // 30fps reference line.
                Rectangle {
                    x: 0; width: parent.width;
                    y: parent.height * (1.0 - 33.34 / 50.0) - 0.5px;
                    height: 1px;
                    background: rgba(220, 200, 80, 0.35);
                }

                // The bars. Slot width is fixed at chart_w / FRAME_HISTORY_LEN
                // (120) so partial buffers cluster on the left and the chart
                // visually scrolls left as new samples arrive.
                for time[i] in root.debug-frame-times: Rectangle {
                    property <length> slot-w: parent.width / 120;
                    property <float> norm: min(time / 50.0, 1.0);
                    x: i * self.slot-w;
                    width: self.slot-w - 0.5px;
                    height: parent.height * self.norm;
                    y: parent.height - self.height;
                    background: time < 16.67
                        ? rgba(120, 220, 140, 0.85)
                        : (time < 33.34
                            ? rgba(240, 200, 80, 0.9)
                            : rgba(240, 90, 90, 0.95));
                }
            }

            Text {
                x: 14px;
                y: 112px;
                width: parent.width - 28px;
                height: parent.height - 124px;
                text: root.debug-text;
                color: Theme.mode == TokenMode.Dark
                    ? rgba(255, 255, 255, 0.78)
                    : rgba(0, 0, 0, 0.78);
                font-family: "monospace";
                font-size: 11px;
                wrap: word-wrap;
                vertical-alignment: top;
            }
        }

        Rectangle {
            x: Tokens.chrome-hairline-width;
            y: Tokens.chrome-hairline-width;
            width: parent.width - 2 * Tokens.chrome-hairline-width;
            height: parent.height - 2 * Tokens.chrome-hairline-width;
            background: transparent;
            border-radius: Tokens.popout-corner-radius - Tokens.chrome-hairline-width;
            border-width: Tokens.chrome-hairline-width;
            border-color: Theme.surface-border;
        }
    }

    // ── Layer 75: Help overlay (Super+/) ─────────────────────────────────────
    if root.help-overlay-visible: TouchArea {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        z: 75;
        clicked => { root.help-overlay-visible = false; }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 480px;
            height: 360px;
            background: transparent;
            border-radius: Tokens.popout-corner-radius;
            clip: false;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: Theme.chrome-shadow-source;
                border-radius: Tokens.popout-corner-radius;
                drop-shadow-blur: Tokens.popout-shadow-blur;
                drop-shadow-offset-y: Tokens.popout-shadow-offset-y;
                drop-shadow-color: Theme.chrome-shadow;
            }

            content := Rectangle {
                width: parent.width;
                height: parent.height;
                background: Theme.surface-bg;
                border-radius: Tokens.popout-corner-radius;
                clip: true;

                Rectangle {
                    x: Tokens.popout-corner-radius;
                    y: Tokens.chrome-hairline-width / 2;
                    width: parent.width - 2 * Tokens.popout-corner-radius;
                    height: Tokens.chrome-highlight-height;
                    background: Theme.menu-highlight;
                }

                Text {
                    x: 24px; y: 18px;
                    width: parent.width - 48px;
                    height: 28px;
                    text: "Keyboard Shortcuts";
                    color: Theme.mode == TokenMode.Dark
                        ? rgba(255, 255, 255, 0.92)
                        : rgba(0, 0, 0, 0.85);
                    font-family: Tokens.font-family;
                    font-size: 18px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Text {
                    x: 24px; y: 60px;
                    width: parent.width - 48px;
                    height: parent.height - 80px;
                    font-family: Tokens.font-family;
                    font-size: 13px;
                    color: Theme.mode == TokenMode.Dark
                        ? rgba(255, 255, 255, 0.78)
                        : rgba(0, 0, 0, 0.72);
                    wrap: word-wrap;
                    vertical-alignment: top;
                    text:
                        "Super + T          Toggle light / dark theme\n"
                        + "Super + I          Toggle debug overlay\n"
                        + "Super + ?          Toggle this help\n"
                        + "Super + Space      App launcher (Spotlight-style)\n"
                        + "Super + W          Close focused window\n"
                        + "Super + M          Minimise focused window\n"
                        + "Super + D          Show desktop / minimise all\n"
                        + "Super + drag       Move window from anywhere\n"
                        + "Alt + Tab          Cycle windows (MRU)\n"
                        + "Esc                Dismiss menus / popouts / help\n"
                        + "Right-click desk   Open desktop context menu\n"
                        + "Right-click dock   Per-app menu (Quit / Show All)\n"
                        + "Double-click bar   Maximise window\n"
                        + "Drag → screen edge Snap to half / quarter\n"
                        + "Drag → top edge    Maximise (snap)\n"
                        + "Edge / corner      Resize window\n"
                        + "Click panel clock  Datetime popout\n"
                        + "Click panel right  Control centre\n"
                        + "\n"
                        + "Click outside this card to close.";
                }
            }

            Rectangle {
                x: Tokens.chrome-hairline-width;
                y: Tokens.chrome-hairline-width;
                width: parent.width - 2 * Tokens.chrome-hairline-width;
                height: parent.height - 2 * Tokens.chrome-hairline-width;
                background: transparent;
                border-radius: Tokens.popout-corner-radius - Tokens.chrome-hairline-width;
                border-width: Tokens.chrome-hairline-width;
                border-color: Theme.surface-border;
            }
        }
    }

    // ── Layer 99: Custom cursor overlay ──────────────────────────────────────
    // Painted at the highest z-order so it's always on top of everything.
    // The image is positioned such that cursor-hotspot-{x,y} is at the pointer.
    Image {
        z: 99;
        x: (root.cursor-x - root.cursor-hotspot-x) * 1px;
        y: (root.cursor-y - root.cursor-hotspot-y) * 1px;
        width: root.cursor-size * 1px;
        height: root.cursor-size * 1px;
        source: root.cursor-image;
        visible: root.cursor-visible;
        image-fit: fill;
    }
}
