// The window menu (WM right-click / titlebar menu) as an on-demand, modal
// full-screen overlay surface: a scrim that dismisses on any outside click +
// de's ContextMenu rendered at the compositor-provided anchor point. Entries
// come from [menu] config; each picks a gnoblin action dispatched at the
// target window.
import { ContextMenu, MenuItem } from "../../shell-ui/vendor/slint/widgets/ContextMenu.slint";
import { Theme, TokenMode, Tokens } from "../../shell-ui/vendor/slint/Tokens.slint";
export { MenuItem, Theme, TokenMode }

export component WindowMenu inherits Window {
    in property <[MenuItem]> items;
    in property <length> menu-x: 0px;
    in property <length> menu-y: 0px;
    in property <image>  backdrop;
    in property <length> backdrop-screen-w: 1px;
    in property <length> backdrop-screen-h: 1px;
    callback item-activated(int);
    callback dismiss();
    background: transparent;
    default-font-family: Tokens.font-family;

    // Any click outside the menu dismisses it (the surface is modal).
    TouchArea {
        width: 100%;
        height: 100%;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                root.dismiss();
            }
        }
    }

    ContextMenu {
        x: root.menu-x;
        y: root.menu-y;
        items: root.items;
        open: true;
        origin-x: 0px;
        origin-y: 0px;
        backdrop: root.backdrop;
        backdrop-screen-w: root.backdrop-screen-w;
        backdrop-screen-h: root.backdrop-screen-h;
        menu-x: root.menu-x;
        menu-y: root.menu-y;
        item-clicked(id) => { root.item-activated(id); }
        dismiss => { root.dismiss(); }
    }
}
