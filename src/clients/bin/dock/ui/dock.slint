// Window wrapper so de's Dock can be a layer-shell top-level. de's Dock reused.
//
// The surface is taller than the dock band (BarConfig.height = band + headroom)
// so a right-click context menu can render ABOVE an icon, inside our own
// surface, without a separate popup. The band is bottom-anchored; the empty
// headroom above it is click-through (the Rust side restricts `input_rects` to
// the band + the open menu).
import { Dock, DockItem } from "../../../crates/gnoblin-runtime/vendor/slint/Dock.slint";
import { Tokens, Theme, TokenMode } from "../../../crates/gnoblin-runtime/vendor/slint/Tokens.slint";
import { ContextMenu, MenuItem } from "../../../crates/gnoblin-runtime/vendor/slint/widgets/ContextMenu.slint";
export { DockItem, MenuItem, Theme, TokenMode }

export component DockBar inherits Window {
    in property <[DockItem]> items;
    in property <image>      backdrop;
    in property <length>     backdrop-screen-w: 1px;
    in property <length>     backdrop-screen-h: 1px;
    in property <length>     backdrop-offset-y: 0px;

    // Right-click menu, driven by Rust (it builds Open/Close from running
    // state, sets the anchor, and toggles `menu-open`).
    in property <[MenuItem]> menu-items;
    in property <length>     menu-anchor-x;   // slot centre, window space
    in property <bool>       menu-open: false;

    callback icon-clicked(string);
    /// app-id, slot-centre x (window space) — Rust opens the menu.
    callback icon-right-clicked(string, length);
    callback menu-item-clicked(int);
    callback menu-dismiss();

    // Height of the dock band itself (pill + outer padding). The surface is
    // taller; the band sits flush at the bottom edge.
    property <length> band-h: Tokens.dock-height;

    background: transparent;
    default-font-family: Tokens.font-family;

    dock := Dock {
        x: 0;
        y: parent.height - root.band-h;
        width: 100%;
        height: root.band-h;
        items: root.items;
        backdrop: root.backdrop;
        backdrop-screen-w: root.backdrop-screen-w;
        backdrop-screen-h: root.backdrop-screen-h;
        backdrop-offset-y: root.backdrop-offset-y;
        icon-clicked(id) => { root.icon-clicked(id); }
        icon-right-clicked(id, ax) => { root.icon-right-clicked(id, ax); }
    }

    // Full-surface dismiss catcher — only live while the menu is open (the
    // Rust side widens `input_rects` to the whole surface then). Sits below the
    // menu so menu clicks win; a click anywhere else closes the menu.
    if root.menu-open: TouchArea {
        x: 0; y: 0;
        width: 100%;
        height: 100%;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                root.menu-dismiss();
            }
        }
    }

    menu := ContextMenu {
        items: root.menu-items;
        open: root.menu-open;
        // Anchor under the icon, clamped to stay on-screen (8 px inset).
        x: max(8px, min(root.menu-anchor-x - self.width / 2,
                        root.width - self.width - 8px));
        // Float just above the dock band.
        y: parent.height - root.band-h - self.height - 6px;
        // Backdrop sampling coords = the menu's own window position.
        menu-x: self.x;
        menu-y: self.y;
        backdrop: root.backdrop;
        backdrop-screen-w: root.backdrop-screen-w;
        backdrop-screen-h: root.backdrop-screen-h;
        // Scale-open from the bottom-centre (the icon side), so it grows
        // upward out of the dock.
        origin-x: self.width / 2;
        origin-y: self.height;
        item-clicked(id) => { root.menu-item-clicked(id); }
        dismiss() => { root.menu-dismiss(); }
    }
}
