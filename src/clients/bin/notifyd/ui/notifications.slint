// Notification popups: Rust owns one content-sized layer surface per active
// card. The compositor owns card chrome (rounding, border, shadow, blur); this
// Slint surface only paints the translucent tint and notification content.
import { Theme, TokenMode, Tokens, Spacing, Radius, Motion } from "../../../crates/gnoblin-runtime/vendor/slint/Tokens.slint";
export { Theme, TokenMode }

export struct NotifAction {
    id:    string,
    label: string,
}

export struct NotifCard {
    id:       int,
    summary:  string,
    body:     string,
    icon:     image,
    has-icon: bool,
    critical: bool,
    actions:  [NotifAction],
    card-h:   length,
}

export component NotificationHost inherits Window {
    background: transparent;
    default-font-family: Tokens.font-family;
}

component NotificationCardContent inherits Rectangle {
    in property <NotifCard> card;
    callback dismissed(int);
    callback action-invoked(int, string);

    width: 360px;
    height: root.card.card-h;
    background: Theme.surface-bg;
    clip: false;

    // Critical urgency accent — a red bar down the leading edge.
    if root.card.critical: Rectangle {
        x: 0;
        width: 4px;
        height: parent.height;
        background: Theme.critical-accent;
    }

    // Full-card dismiss target, behind the content. Action button TouchAreas sit
    // on top and capture their own clicks.
    TouchArea {
        clicked => { root.dismissed(root.card.id); }
    }

    VerticalLayout {
        padding: Spacing.lg;
        spacing: Spacing.lg;

        // Header — icon + title/body.
        HorizontalLayout {
            spacing: Spacing.md;
            alignment: stretch;

            if root.card.has-icon: Image {
                width: 36px;
                height: 36px;
                y: 2px;
                source: root.card.icon;
            }

            VerticalLayout {
                spacing: Spacing.xs;
                alignment: center;

                Text {
                    text: root.card.summary;
                    color: Theme.text-primary;
                    font-size: 15px;
                    font-weight: 700;
                    overflow: elide;
                    horizontal-alignment: left;
                }
                if root.card.body != "": Text {
                    text: root.card.body;
                    color: Theme.text-secondary;
                    font-size: 13px;
                    overflow: elide;
                    wrap: word-wrap;
                    horizontal-alignment: left;
                    max-height: 34px;
                }
            }
        }

        // Action buttons row (when the app declared actions).
        if root.card.actions.length > 0: HorizontalLayout {
            spacing: Spacing.sm;

            for action[ai] in root.card.actions: Rectangle {
                height: 38px;
                background: btn-touch.has-hover ? Theme.surface-hover-bg : Theme.surface-raised-bg;
                border-radius: Radius.sm;
                border-width: Tokens.chrome-hairline-width;
                border-color: Theme.surface-border;
                animate background { duration: Motion.fast; easing: Motion.fast-curve; }
                btn-touch := TouchArea {
                    clicked => { root.action-invoked(root.card.id, action.id); }
                }
                Text {
                    text: action.label;
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 500;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}

export component NotificationCardSurface inherits Window {
    in property <NotifCard> card;
    callback dismissed(int);
    callback action-invoked(int, string);

    background: transparent;
    default-font-family: Tokens.font-family;
    width: 360px;
    height: root.card.card-h;

    NotificationCardContent {
        width: parent.width;
        height: parent.height;
        card: root.card;
        dismissed(id) => { root.dismissed(id); }
        action-invoked(id, action) => { root.action-invoked(id, action); }
    }
}
