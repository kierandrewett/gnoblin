// The power menu: an on-demand, modal full-screen overlay — a scrim that
// dismisses on any outside click + de's ContextMenu centred on screen. Entries
// (Lock / Log Out / Suspend / Restart / Shut Down) run system commands.
import { ContextMenu, MenuItem } from "../../crates/gnoblin-runtime/vendor/slint/widgets/ContextMenu.slint";
import { Theme, TokenMode, Tokens } from "../../crates/gnoblin-runtime/vendor/slint/Tokens.slint";
export { MenuItem, Theme, TokenMode }

export component PowerMenu inherits Window {
    in property <[MenuItem]> items;
    in property <length> menu-x: 0px;
    in property <length> menu-y: 0px;
    in property <image>  backdrop;
    in property <length> backdrop-screen-w: 1px;
    in property <length> backdrop-screen-h: 1px;
    callback item-activated(int);
    callback dismiss();
    background: transparent;
    default-font-family: Tokens.font-family;

    // Any click outside the menu dismisses it (the surface is modal).
    TouchArea {
        width: 100%;
        height: 100%;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                root.dismiss();
            }
        }
    }

    ContextMenu {
        x: root.menu-x;
        y: root.menu-y;
        items: root.items;
        open: true;
        origin-x: self.width / 2;
        origin-y: self.height / 2;
        backdrop: root.backdrop;
        backdrop-screen-w: root.backdrop-screen-w;
        backdrop-screen-h: root.backdrop-screen-h;
        menu-x: root.menu-x;
        menu-y: root.menu-y;
        item-clicked(id) => { root.item-activated(id); }
        dismiss => { root.dismiss(); }
    }
}
