#!/usr/bin/env bash
# gnoblin Wi-Fi plugin (oneshot). Real NetworkManager integration via nmcli.
# Tile = radio state + active SSID; submenu lists nearby networks (tap to join),
# a Wi-Fi power toggle, and a Network Settings action. No fallback.
set -euo pipefail

evt="${GNOBLIN_QS_EVENT:-}"
case "$evt" in
    *'"event":"toggle"'*'wifi-power'*)
        case "$evt" in *'"value":true'*) nmcli radio wifi on ;; *) nmcli radio wifi off ;; esac ;;
    *'"event":"row"'*'"id":"settings"'*)
        setsid -f gnome-control-center wifi ;;
    *'"event":"row"'*'"id":"net:'*)
        ssid=$(printf '%s' "$evt" | sed -n 's/.*"id":"net:\(.*\)".*/\1/p')
        [ -n "$ssid" ] && nmcli device wifi connect "$ssid" ;;
esac

json_esc() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

radio=$(nmcli -t radio wifi)
if [ "$radio" = enabled ]; then on=true; else on=false; fi
active=$(nmcli -t -f active,ssid device wifi | sed -n 's/^yes://p' | head -1)
if [ "$on" = true ]; then sub="${active:-Not connected}"; else sub="Off"; fi

rows='{"type":"toggle","id":"wifi-power","label":"Wi-Fi","value":'"$on"'},{"type":"section","label":"Networks"}'
if [ "$on" = true ]; then
    while IFS=':' read -r a ssid signal sec; do
        [ -z "$ssid" ] && continue
        if [ "$a" = yes ]; then cur=true; else cur=false; fi
        e=$(json_esc "$ssid")
        seclabel="${sec:-Open}"
        rows="$rows,{\"type\":\"item\",\"id\":\"net:$e\",\"label\":\"$e\",\"sublabel\":\"$seclabel · ${signal}%\",\"icon\":\"network-wireless-symbolic\",\"on\":$cur}"
    done < <(nmcli -t -f active,ssid,signal,security device wifi | head -12)
fi
rows="$rows,{\"type\":\"separator\"},{\"type\":\"action\",\"id\":\"settings\",\"label\":\"Network Settings…\",\"icon\":\"preferences-system-symbolic\"}"

printf '{"tile":{"icon":"network-wireless-symbolic","title":"Wi-Fi","subtitle":"%s","active":%s,"chevron":true,"layout":"toggle","span":2},"menu":{"title":"Wi-Fi","rows":[%s]}}\n' "$(json_esc "$sub")" "$on" "$rows"
