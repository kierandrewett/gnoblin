#!/usr/bin/env bash
# gnoblin Power Mode plugin (oneshot). Shows + cycles the active power profile via
# powerprofilesctl. No fallback: if power-profiles-daemon is absent it fails.
set -euo pipefail
case "${GNOBLIN_QS_EVENT:-}" in
    *'"event":"tile-clicked"'*)
        case "$(powerprofilesctl get)" in
            power-saver) powerprofilesctl set balanced ;;
            balanced)    powerprofilesctl set performance ;;
            *)           powerprofilesctl set power-saver ;;
        esac ;;
esac
p="$(powerprofilesctl get)"
label="$(printf '%s' "$p" | sed 's/-/ /g')"
printf '{"tile":{"icon":"power-profile-balanced-symbolic","title":"Power Mode","subtitle":"%s","chevron":true,"layout":"row","span":4}}\n' "$label"
