#!/usr/bin/env bash
# gnoblin Output volume plugin (oneshot, slider). wpctl drives the volume; the
# chevron opens a device picker (pactl sinks) — tap a device to make it default.
# No fallback: needs wpctl + pactl (PipeWire/pulse).
set -euo pipefail
SINK="@DEFAULT_AUDIO_SINK@"
evt="${GNOBLIN_QS_EVENT:-}"
case "$evt" in
    *'"event":"slider"'*)
        v=$(printf '%s' "$evt" | sed -n 's/.*"value":\([0-9.]*\).*/\1/p')
        [ -n "$v" ] && wpctl set-volume "$SINK" "$v" ;;
    *'"event":"row"'*'"id":"sink:'*)
        name=$(printf '%s' "$evt" | sed -n 's/.*"id":"sink:\(.*\)".*/\1/p')
        [ -n "$name" ] && pactl set-default-sink "$name" ;;
esac

vol=$(wpctl get-volume "$SINK" | awk '{print $2}')
default=$(pactl get-default-sink)
# One pass over `pactl list sinks`: emit an item row per sink (Name + friendly
# Description), the active one toggled on.
rows=$(pactl list sinks | awk -v def="$default" '
    /^[[:space:]]*Name:/ { name=$2 }
    /^[[:space:]]*Description:/ {
        $1=""; sub(/^[[:space:]]+/,""); desc=$0;
        gsub(/\\/,"\\\\",desc); gsub(/"/,"\\\"",desc);
        on=(name==def)?"true":"false";
        printf ",{\"type\":\"item\",\"id\":\"sink:%s\",\"label\":\"%s\",\"icon\":\"audio-card-symbolic\",\"on\":%s}", name, desc, on;
    }')
printf '{"tile":{"icon":"audio-volume-high-symbolic","title":"Output","chevron":true,"layout":"slider","span":4,"value":%s},"menu":{"title":"Output Device","rows":[{"type":"section","label":"Output Device"}%s]}}\n' "$vol" "$rows"
