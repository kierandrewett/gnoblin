# gnoblin.conf — the gnoblin compositor configuration.
#
# Location: $XDG_CONFIG_HOME/gnoblin/gnoblin.conf  (or set $GNOBLIN_CONFIG).
# Watched live: saving the file re-applies it (keybindings, animations, …) —
# no restart needed. Format is `[section]` headers + `key = value` lines.

[startup]
# Persistent layer-shell apps to launch with the shell. One `exec` per app;
# saving a new line launches it (already-running ones are left alone). Run
# verbatim — write the full command (the binary is its own role).
#
#   exec            — one single instance for the whole session.
#   exec_per_output — one instance PER monitor, each pinned to its output
#                     (the compositor appends `--output <connector>` and
#                     respawns/cleans up as monitors are plugged/unplugged).
#
# Panels/docks/wallpapers belong on every screen, so they use exec_per_output;
# session-global daemons (notifications) use exec.
exec_per_output = gnoblin-topbar   # Slint top panel (clock, tray, global appmenu)
exec_per_output = gnoblin-dock     # Slint dock (pinned + running apps)
exec_per_output = gnoblin-wallpaper # background layer-shell surface per monitor
exec = gnoblin-notifyd             # notification daemon (org.freedesktop.Notifications)
exec = gnoblin-night-light         # warms screen gamma when Night Light is toggled on

[roles]
# On-demand UI roles the compositor invokes for you, passing context on the
# command line (--role/--window/--x/--y/--reason) so the client positions
# itself and knows what it was called for. Point a role at any binary that
# understands the contract; unset = that role is disabled (no native fallback).
window-menu = gnoblin-window-menu   # WM menu (right-click titlebar / window-menu action)

[features]
# Toggle shell APIs on/off. Off means the compositor stops offering the API, so
# any client honouring it drops the feature.
appmenu = on                # the focused window's GTK menu, shown in the topbar

[appearance]
background = "#1d1f21"        # desktop colour (shows through while a wallpaper loads)
# wallpaper = /path/to/image.jpg   # drawn by the background layer over the colour
# wallpaper-style = zoom           # zoom | scaled | centered | stretched | spanned | tiled
# accent = "#3584e466"             # snap-zone highlight colour (#rrggbb or #rrggbbaa)
rounding = 12                      # rounded window corners, radius in px (0 = off)
# gaps = 8                         # inset snapped/tiled windows by N px from the
                                   # screen edges and each other (0 = flush)
# blur = 24                        # blur-behind radius in px (0 = off). The
                                   # Overview shows a blurred desktop behind its
                                   # tint instead of an opaque backdrop. GPU
                                   # effect; needs a real session to look its best.
# theme = dark                     # Slint client theme: dark | light (the
                                   # control-centre's Dark Style tile toggles it live)
# font-family = system             # system | auto | explicit family name
                                   # unset/system reads GNOME's UI font
# night-light-temperature = 4000   # warmth (Kelvin) when the Night Light tile is
                                   # on: lower = warmer (~3000), 6500 = neutral
# Slint shell chrome colours (#rgb, #rgba, #rrggbb, #rrggbbaa). Defaults use a
# soft material fill, an inset hairline, a short top highlight, and a blurred
# elevation shadow so rounded menu/dock corners do not show clipped strokes.
# panel-background = "#242424db"
# panel-foreground = "#ffffffe0"
# panel-border = "#ffffff14"
# dock-background = "#202122c4"
# dock-border = "#ffffff18"
# dock-highlight = "#ffffff16"
# surface-background = "#262627f0"
# surface-raised-background = "#343436f2"
# surface-hover-background = "#ffffff14"
# surface-active-background = "#3584e4f2"
# critical-accent = "#e0492ff2"
# wallpaper-fallback-background = "#1e1e2eff"
# surface-border = "#ffffff1a"
# text-primary = "#ffffffeb"
# text-secondary = "#ffffff9e"
# menu-background = "#262628ed"
# menu-border = "#ffffff1a"
# menu-highlight = "#ffffff14"
# chrome-shadow = "#0000002a"
# chrome-shadow-source = "#00000003"  # hidden shape that casts menu/dock shadows
# dock-corner-radius = 20px
# menu-corner-radius = 12px
# popout-corner-radius = 18px
# tooltip-corner-radius = 10px
# control-corner-radius = 8px
# chrome-hairline-width = 1px
# chrome-highlight-height = 1px
# dock-shadow-blur = 36px
# dock-shadow-offset-y = 9px
# menu-shadow-blur = 28px
# menu-shadow-offset-y = 8px
# popout-shadow-blur = 34px
# popout-shadow-offset-y = 9px
# tooltip-shadow-blur = 18px
# tooltip-shadow-offset-y = 6px
# control-shadow-blur = 4px
# control-shadow-offset-y = 1px
# window-shadow-blur = 36px
# window-shadow-offset-y = 12px

# Soft drop shadow on windows and dialogs. Defined as CSS box-shadow layers:
# `offset-x offset-y blur [spread] colour` (colour = #rrggbb[aa] / rgb() /
# rgba()). Menu/popover surfaces normally provide their own toolkit shadow; set
# `shadow.popup-menu`, `shadow.dropdown-menu`, `shadow.menu`, or `shadow.combo`
# to opt compositor shadows into those transient window types.
shadow = "0 20px 48px -20px rgba(0,0,0,.22), 0 4px 12px -6px rgba(0,0,0,.14)"

[effects]
# Global defaults for gnoblin's compositor-managed visual effects (corner
# rounding, borders, blur). Per-window/-surface overrides live in [window-rules]
# (see below). Everything here is opt-in: with no [effects] keys set, windows
# look exactly as they do from [appearance] rounding alone.
#
# Corner rounding ------------------------------------------------------------
# rounding = 12                  # default radius in px (falls back to
                                 # [appearance] rounding; 0 = off)
# corner-style = squircle        # circular (classic round) | squircle (macOS
                                 # superellipse / continuous corner)
# corner-smoothing = 0.6         # 0..1 Figma-style smoothing. For circular it
                                 # blends toward a squircle; for squircle it
                                 # sets the corner-smoothing strength.
#
# Borders --------------------------------------------------------------------
# border-style = ring            # line (flat stroke) | lip (macOS raised bevel:
                                 # light inner highlight, brighter at the top,
                                 # plus a faint dark outer hairline) | ring (the
                                 # default — a two-layer Tailwind-style edge:
                                 # inner `border` + outer `ring`, drawn INSIDE
                                 # the rounded corner, focus- and theme-aware) |
                                 # none (no border)
# border-width = 1               # default thickness for the line/lip styles (0 = off)
# border-color = "#ffffff20"     # line/lip colour (#rrggbb / #rrggbbaa)
#
# The RING style is the shipped default (see gnoblin.defaults.conf). Its whole
# palette is config-driven — override any of these to retune or recolour it.
# Widths are in logical px; both bands draw inside the rounded edge:
# ring-border-width = 1
# ring-width = 1
# Dark theme (faint white inner border + dark outer ring; *-focused strengthen
# on focus). Light theme uses the -light keys.
# ring-border-color-dark         = "#ffffff14"
# ring-border-color-focused-dark = "#ffffff29"
# ring-color-dark                = "#000000e0"
# ring-color-focused-dark        = "#000000f5"
# ring-border-color-light         = "#0000001a"   # outer: subtle gray hairline
# ring-border-color-focused-light = "#00000026"
# ring-color-light                = "#ffffffff"    # inner: pure-white highlight
# ring-color-focused-light        = "#ffffffff"
# Turn the whole thing off with `border-style = none`.
#
# Blur -----------------------------------------------------------------------
# blur = 24                      # compositor-side blur-behind radius in px for
                                 # translucent windows/surfaces (0 = off). This
                                 # is the per-window blur; [appearance] blur is
                                 # the separate Overview backdrop.
#
# The blur is a REAL content-behind frost: it captures the pixels already painted
# behind the surface — wallpaper AND any windows stacked underneath — blurs them,
# and masks the result to the surface's rounded-rect (so the frost follows the
# corner style) and to where the surface actually has content (so a translucent
# panel never frosts its empty gaps).
#
# blur-alpha-threshold = 1.0     # only frost pixels that are translucent enough:
#                                # the frost is applied where the surface's OWN
#                                # alpha is BELOW this cutoff (0..1). E.g. 0.9
#                                # frosts pixels that are >=10% transparent and
#                                # shows near-opaque pixels directly (no wasted
#                                # blur under solid UI). 1.0 (default) frosts
#                                # wherever the surface has any coverage.
#
# gnoblin's own chrome (topbar, dock, control-centre/datetime popouts, OSD,
# notifications, launcher, power-menu — any layer surface whose namespace matches
# ^gnoblin-) is frosted by DEFAULT, EXCLUDING the wallpaper/background layer. Tune
# or turn it off here; a matching [window-rules] `layer~=^gnoblin-` rule overrides
# it per surface:
# gnoblin-chrome-blur = on        # master toggle for the default chrome frost
# gnoblin-chrome-blur-radius = 32 # default chrome blur radius in px
# gnoblin-chrome-rounding = 14    # corner radius the chrome frost is masked to
#
# libadwaita/libhandy apps (Nautilus, most GNOME apps) already draw their own
# rounded corners + shadow. gnoblin rounds them anyway (so they get the ring),
# using SMART CORNER FILL: the shader fills the client's own transparent corner
# with its edge colour, so our rounded corner + ring read cleanly with no gap.
# Set this off to instead skip those apps entirely (no compositor rounding/ring,
# they keep only their own corners):
# round-self-rounding-apps = on
#
# Keep effects while maximized/fullscreen (off by default — maximized windows
# normally drop rounding so corners aren't clipped at the screen edge):
# keep-rounded-for-maximized = off
# keep-rounded-for-fullscreen = off

[dock]
# Pinned apps for the Slint dock (gnoblin-dock) — comma-separated .desktop
# ids; their icons are resolved from the system icon theme. Unset = a default set.
# A running app shows a dot under its icon; the focused one a wider pill (state
# polled from the compositor over dev.gnoblin.Shell).
# favorites = firefox, org.gnome.Nautilus, org.gnome.TextEditor, foot, org.gnome.Settings

[topbar]
# Topbar layout: each area is a comma-separated list of widget IDs, inspired by
# Firefox CustomizableUI placement arrays. Special widgets are first-class:
# `spacer:N` is fixed pixels, `spring[:N]` flexes, and `separator` draws a
# hairline. Available widgets: workspaces, focused-app, appmenu, clock,
# notifications, tray, status, launcher.
left = workspaces, focused-app, appmenu, spring
center = clock
right = launcher, tray, status
# height = 34
# exclusive_zone = 34   # reserved workarea at the top edge; default = height
# width = 0             # 0/full output, or a fixed px width for a floating bar
# align = center        # left | center | right, used when width is fixed
# offset-x = 0px        # optical nudge after alignment
# padding-left = 12px
# padding-right = 12px
# clock-padding = 12px
# status-padding = 4px
# status-icon-gap = 5px
# quick-settings-offset-x = 6px
# quick-settings-offset-y = -4px
# clock-format = "%a %d %b  %H:%M:%S"  # locale-aware strftime pattern

# Global menu backend shown by the `appmenu` widget: auto | gtk | kde | both |
# off. `gtk` reads org.gtk.Menus from GTK apps; `kde` reads KDE/Qt DBusMenu
# addresses advertised through the org_kde_kwin_appmenu Wayland protocol.
appmenu-backend = auto

# The focused-app widget opens the same application context menu as dock
# right-click: all windows, desktop-file actions, pin/unpin, app details, quit.
# The launcher widget opens the same app launcher as Super+Space. The topbar's
# clock opens the calendar and the status cluster opens quick settings
# (volume/mic, network, bluetooth, notification history) — all native Slint.
# These commands back topbar/quick-settings buttons (run via `sh -c`):
# launcher = gnoblin-launcher   # the search/launcher button
# account = gnome-control-center users
# control_centre = gnome-control-center   # the settings (gear) button
# power = gnoblin-power-menu   # control-centre power button (default: the gnoblin
                              # power menu — Lock/Log Out/Suspend/Restart/Shut Down)
# wired = nm-connection-editor
# wifi = nm-connection-editor
# bluetooth = blueman-manager
# background_apps = gnome-control-center applications

# ── Quick-settings plugins ────────────────────────────────────────────────────
# EVERY control-centre tile is a plugin — there are no hardcoded built-ins. gnoblin
# ships a default set (wifi, bluetooth, output, mic, nightlight, dnd, darkstyle,
# powermode, backgroundapps) as `gnoblin-qs-*` commands declared in a bundled
# defaults config that THIS file is layered on top of. So you can:
#   • reorder every tile:        [quicksettings] order = output, mic, wifi, dnd, …
#   • override a default:        re-declare its [qs-plugin.NAME] with a new command
#   • disable a default:         [qs-plugin.bluetooth]  → enabled = off
#   • add your own:              a new [qs-plugin.NAME] (appended after the defaults)
#
# Add your own tiles to the control centre, driven by an external command. The
# command speaks a small JSON protocol on stdout; the shell renders a tile plus
# an optional submenu, and forwards interactions back to the command.
#
#   [qs-plugin.NAME]
#   command  = my-qs-script       # binary/script, run via `sh -c` (env prefixes OK)
#   mode     = persistent         # persistent (stays alive, ndjson over stdio)
#                                 # | oneshot (re-run on interval + on each event)
#   interval = 5s                 # poll cadence for oneshot (5s default; ms/s/m/h)
#
# PROTOCOL — process → shell (stdout). One JSON object; persistent mode emits one
# ndjson line per update:
#   {"tile":{"icon":"network-wireless","title":"Wi-Fi","subtitle":"MyNet",
#            "active":true,"chevron":true},
#    "menu":{"title":"Wi-Fi","rows":[
#       {"id":"net-1","type":"item","label":"MyNet","sublabel":"80%","icon":"network-wireless","on":true},
#       {"id":"enabled","type":"toggle","label":"Enable Wi-Fi","value":true},
#       {"id":"vol","type":"slider","label":"Volume","value":0.42},
#       {"type":"separator"},
#       {"type":"section","label":"Other"},
#       {"id":"settings","type":"action","label":"Network Settings…"} ]}}
# Row types: item | toggle | slider | action | separator | section. `menu` is
# optional (a tile-only plugin omits it). `icon` is an icon name resolved by the
# shell. `value` is the slider position (0..1) or the toggle's boolean.
#
# PROTOCOL — shell → process (events). Persistent: ndjson written to the
# process's stdin. Oneshot: passed as the GNOBLIN_QS_EVENT env var and re-run.
#   {"event":"tile-clicked"}            tile body clicked
#   {"event":"row","id":"net-1"}        an item/action row clicked
#   {"event":"toggle","id":"enabled","value":false}
#   {"event":"slider","id":"vol","value":0.42}
#   {"event":"opened"}  {"event":"closed"}   control centre shown / hidden
#
# Real-system examples (COMMENTED OUT — uncomment to drive from live tools):
# [qs-plugin.wifi]
# command = nmcli-qs           # your wrapper around `nmcli -t -f ... device`
# mode = oneshot
# interval = 5s
# [qs-plugin.media]
# command = playerctl-qs       # a persistent wrapper around `playerctl --follow`
# mode = persistent
# [qs-plugin.bluetooth]
# command = bluetoothctl-qs    # wraps `bluetoothctl devices Connected`
# mode = oneshot

# ── Data-only providers (shorthand) ───────────────────────────────────────────
# A simpler form for one-shot, data-only tiles: each `get-NAME = cmd` becomes a
# oneshot plugin named NAME. The command's stdout must be the same tile/menu
# JSON object as above (this is just a terser way to declare a oneshot plugin).
# [providers]
# get-audio     = wpctl-qs       # wrap `wpctl get-volume @DEFAULT_AUDIO_SINK@`
# get-battery   = battery-qs     # wrap `upower -i …` / read /sys/class/power_supply

# ── Launcher providers (process/command search sources) ──────────────────────
# The Spotlight launcher can search anything: declare a command that receives
# the (prefix-stripped) query in the $GNOBLIN_QUERY env var — a separate script
# reads that; an inline command can also use "$1" — and prints one result per
# line as TAB-separated fields:  title <TAB> subtitle <TAB> icon <TAB> action
#   icon   = a theme icon name (or empty)
#   action = a shell command run on activation (empty → the title is copied)
# `prefix` is an optional keyword the query must start with (stripped before the
# command runs) — keeps app searches from spawning processes. Omit to run on
# every query. The launcher also has a built-in calculator (just type maths).
# [launcher-provider.files]
# command = ~/.config/gnoblin/providers/launcher-files
# prefix  = "f "
# [launcher-provider.web]
# command = ~/.config/gnoblin/providers/launcher-web
# prefix  = "g "
# [launcher-provider.emoji]
# command = ~/.config/gnoblin/providers/launcher-emoji   # "e love" → 😍, ⏎ copies
# prefix  = "e "
# [launcher-provider.kill]
# command = ~/.config/gnoblin/providers/launcher-kill    # "k firefox" → ⏎ SIGTERMs
# prefix  = "k "
# [launcher-provider.clip]
# command = ~/.config/gnoblin/providers/launcher-clipboard   # needs cliphist
# prefix  = "v "
# [launcher-provider.convert]
# command = ~/.config/gnoblin/providers/launcher-convert # "c 10 km to mi", ⏎ copies
# prefix  = "c "
# [launcher-provider.color]
# command = ~/.config/gnoblin/providers/launcher-color   # "# ff8800" → rgb/hsl, ⏎ copies
# prefix  = "# "
# [launcher-provider.base]
# command = ~/.config/gnoblin/providers/launcher-base    # "b 0xff" → dec/hex/oct/bin
# prefix  = "b "
# [launcher-provider.time]
# command = ~/.config/gnoblin/providers/launcher-time    # "t tokyo" → world clock
# prefix  = "t "
# Example provider scripts live in tests/devkit/providers/launcher-* (web, files,
# emoji, kill, clipboard, convert, color, base, time). Other ideas (all just
# commands): dictionary define, ssh hosts, window switcher.
# Opt-in web-search fallback: when nothing else matches, offer to search the web
# (Spotlight-style). %s is the URL-encoded query. Unset = no fallback.
# [launcher]
# web-search = https://duckduckgo.com/?q=%s

[animations]
# By default animations follow the STANDARD desktop setting
# `org.gnome.desktop.interface enable-animations` — the same toggle GTK/other
# apps honour — so one switch (or a software/headless session) reduces motion
# across the compositor AND every client. Uncomment to force on/off regardless:
# enabled = on
# Debug: global playback-speed multiplier applied to EVERY animation. 1.0 is
# normal; 0.1 runs everything at a tenth speed (10x longer — for inspecting a
# transition frame by frame); 2.0 runs twice as fast. Values <= 0 are ignored.
# animation-speed = 0.1
# Per effect: `<effect> = DURATION_MS, CURVE[, START_OR_END_SCALE]`.
# Size-change effects (`resize`, `maximize`, `unmaximize`) use the duration and
# curve fields; open/close/minimize also use the scale field.
# Curves: linear, ease-out,
# ease-in, ease-in-out, and ease-{in,out,in-out}-{quad,cubic,quart,quint,sine,
# expo,circ,back,bounce,elastic} (back/elastic/bounce overshoot).
# Use `<effect>.<window-type>` to target window families: normal, dialog,
# modal-dialog, utility, menu, dropdown-menu, popup-menu and combo.
# Menu-like surfaces get small compositor entrance animations; close animations
# stay to stable toplevel-style windows because Mutter can destroy popup actors
# synchronously during protocol validation.
# Entrances ease-out, exits ease-in, keep durations under ~300ms.
open = 150, ease-out-cubic, 0.985
close = 110, ease-in-cubic, 0.985
open.dialog = 105, ease-out-cubic, 0.985
close.dialog = 80, ease-in-cubic, 0.985
open.modal-dialog = 105, ease-out-cubic, 0.985
close.modal-dialog = 80, ease-in-cubic, 0.985
open.utility = 105, ease-out-cubic, 0.985
close.utility = 80, ease-in-cubic, 0.985
open.menu = 80, ease-out-quad, 0.995
open.dropdown-menu = 80, ease-out-quad, 0.995
open.popup-menu = 80, ease-out-quad, 0.995
open.combo = 80, ease-out-quad, 0.995
minimize = 160, ease-in-cubic, 0
resize = 160, ease-out-quint
maximize = 300, ease-out-quart       # cross-fades a freeze-frame of the old rect into the live target rect
unmaximize = 280, ease-out-quart     # cross-fades the old (maximized) rect back into the restored rect
# How the old-contents freeze-frame hands off to the live window during the grow:
#   zoom      (default) - macOS feel: old contents hold opaque and zoom as one image, resolving to live at the tail
#   crossfade           - GNOME feel: old contents fade out early, new layout blends in across the grow
maximize-style = zoom
workspace = 250, ease-out-quint   # the slide when switching workspaces
tile = 140, ease-out             # the snap-zone highlight when dragging to an edge
overview = 250, ease-out-quint    # windows glide into the overview grid

# Native Slint shell chrome motion. These drive hover feedback, topbar/dock
# micro-interactions, launcher/OSD/notification movement, and built-in Slint
# popouts/menus. Values accept `MS[, CURVE]`; curves use the same named style
# vocabulary as compositor effects, plus `standard` and `spring`.
# `slint-overlay-open/close` control popout/menu enter and exit separately.
# slint-fast = 120, ease-out
# slint-medium = 200, ease-in-out
# slint-overlay = 240, ease-out
# slint-overlay-open = 160, standard
# slint-overlay-close = 160, spring
# slint-fade = 200, ease-in-out
# slint-page = 420, ease-out-expo   # QS carousel / submenu slide (buttery)
# slint-ease-out = ease-out
# slint-ease-in = ease-in
# slint-ease-in-out = ease-in-out
# slint-overlay-slide = 8px
# slint-overlay-scale-from = 0.95

[input]
# gnoblin is the window manager, so the keybindings below are authoritative —
# mutter's built-in shortcuts are disabled. Set to off to keep mutter's instead.
take-over-keybindings = on

# Keyboard, pointer and touchpad settings. gnoblin maps these onto the
# org.gnome.desktop GSettings mutter's input backend reads (re-applied on every
# config reload and on device hotplug). Only the keys you set here are touched.
# keyboard-layout = us           # xkb layout (e.g. us, gb, de, fr)
# keyboard-variant =             # xkb variant (e.g. dvorak, colemak)
# keyboard-options = ctrl:nocaps # comma/space list of xkb options
# repeat-rate = 25               # key repeats per second
# repeat-delay = 600             # ms before repeat starts
# natural-scroll = true          # reverse scroll direction (touchpad + mouse)
# tap-to-click = true            # touchpad tap = click
# disable-while-typing = true    # ignore the touchpad while typing
# accel-profile = adaptive       # pointer accel: default | flat | adaptive
# pointer-speed = 0.0            # -1.0 (slow) .. 1.0 (fast)
# focus-follows-mouse = false    # true = sloppy focus (hover to focus)

# Per-monitor layout, keyed by connector name (run `gnoblin-shell` once and check
# the log, or use any wlr-randr-style tool, to find your connector names like
# eDP-1 / HDMI-A-1 / DP-2). Each value is a comma-separated list of:
#   mode WxH | mode WxH@HZ | scale N | position X Y | transform <0|90|180|270|
#   flipped|flipped-90|flipped-180|flipped-270> | primary | disable
# Applied via mutter's DisplayConfig at startup and on hotplug; only listed
# connectors are touched, and a requested mode/scale must be one the monitor
# advertises (otherwise it is skipped with a warning).
# [output]
# eDP-1    = mode 2560x1600@60, scale 2, position 0 0, primary
# HDMI-A-1 = mode 1920x1080, scale 1, position 2560 0
# DP-2     = disable

[bind]
# Accelerator = action [arg]. These are the same actions gnoblinctl and the
# dev.gnoblin.Shell D-Bus API expose; run `gnoblinctl actions` for the list.
Super+Q = close
Super+Up = maximize
Super+M = minimize
Super+F = fullscreen

# Launch any command (Hyprland-style exec bind). Super+Space opens the search
# launcher; Super+A opens the full-screen app grid (same apps, icon layout).
Super+Space = spawn gnoblin-launcher
Super+A = spawn gnoblin-launcher --grid
Super+L = lock              # lock the session (password via PAM)

# Developer inspector dump (browser-devtools-style shortcut): writes the live
# scene JSON to $XDG_RUNTIME_DIR/gnoblin-inspect/scene.json.
Super+F12 = spawn sh -c 'mkdir -p "${XDG_RUNTIME_DIR:-/tmp}/gnoblin-inspect"; gnoblinctl inspect --pretty "${XDG_RUNTIME_DIR:-/tmp}/gnoblin-inspect/scene.json"'

# Media + brightness keys (the `spawn` action — needs wpctl, brightnessctl and
# playerctl). The volume/brightness ones also pop the gnoblin-osd overlay.
XF86AudioRaiseVolume = spawn sh -c "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+; gnoblin-osd volume"
XF86AudioLowerVolume = spawn sh -c "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-; gnoblin-osd volume"
XF86AudioMute = spawn sh -c "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle; gnoblin-osd volume"
XF86MonBrightnessUp = spawn sh -c "brightnessctl -c backlight set 5%+; gnoblin-osd brightness"
XF86MonBrightnessDown = spawn sh -c "brightnessctl -c backlight set 5%-; gnoblin-osd brightness"
XF86AudioPlay = spawn playerctl play-pause
XF86AudioNext = spawn playerctl next
XF86AudioPrev = spawn playerctl previous

# Screenshots (via wlr-screencopy — gnoblin-screenshot wraps grim/slurp/wl-copy).
# Saved to ~/Pictures/Screenshots; the -copy variants go to the clipboard.
Print = spawn gnoblin-screenshot full
Shift+Print = spawn gnoblin-screenshot region
Ctrl+Print = spawn gnoblin-screenshot full-copy
Super+Shift+S = spawn gnoblin-screenshot region-copy

Super+Left = snap left
Super+Right = snap right
Super+T = snap top
Super+Return = snap center
Super+C = center                 # centre the window on its monitor

# Keyboard half-tiling with cycling: pressing the same direction again cycles
# the window through half -> two-thirds -> one-third on that side.
Super+Ctrl+Left = tile left
Super+Ctrl+Up = tile up
Super+Ctrl+Down = tile down

# Visual window switcher: a centred panel of live thumbnails of the windows on
# the active workspace, in most-recently-used order. Hold the modifier and tap
# the key to cycle the highlight; release the modifier to commit (Enter/click
# also commit, Escape cancels). Works like GNOME's / KDE's Alt+Tab.
Alt+Tab = switcher next
Alt+Shift+Tab = switcher prev

# `focus next/prev` is the instant, no-UI alternative (raises the next window
# immediately with no panel) if you prefer that to the visual switcher:
# Alt+grave = focus next

# Overview: a full-screen grid of live thumbnails of every window on the active
# workspace. Click a thumbnail to focus that window; Escape or a click on the
# backdrop dismisses it. Press the bind again to toggle it shut.
Super+Tab = overview

# Multi-monitor: move the window to / focus the next monitor, swap two windows.
Super+Shift+Right = move-to-monitor next
Super+Ctrl+Right = focus-monitor next
Super+S = swap                   # swap geometry with the next window

# Workspaces: switch by number or next/prev, and move the focused window.
Super+1 = workspace 1
Super+2 = workspace 2
Super+3 = workspace 3
Super+Page_Up = workspace prev
Super+Page_Down = workspace next
Super+Shift+1 = move-to-workspace 1
Super+Shift+2 = move-to-workspace 2

# Scratchpad (named off-screen holding pen, like Hyprland's special workspaces):
# stash the focused window into it, then toggle the whole set in/out of view.
Super+grave = scratchpad scratch              # toggle the "scratch" scratchpad
Super+Shift+grave = scratchpad-stash scratch  # stash the focused window into it

# Also built in (from mutter): Super+drag to move a window, Super+drag to
# resize, and drag-to-edge tiling.

[workspaces]
# Optional index->name labels (1-based). The topbar renders these instead of
# bare numbers (exposed over dev.gnoblin.Shell.WorkspaceNames). Unlisted
# workspaces stay numbered.
# 1 = Web
# 2 = Code
# 3 = Chat

[gestures]
# enabled = true                 # set false to remove the touchpad-gesture hook
#                                  entirely (the `gesture` action still works)
# Map touchpad swipes/pinches to actions (same verbs as [bind]). Keys are
# `swipe-<fingers>-<left|right|up|down>` and `pinch-<fingers>-<in|out>`. Set a
# key to `none` to disable it. Defaults (when unset): swipe-3-left/right switch
# workspaces, swipe-3-up / swipe-4-up open the Overview.
# swipe-3-left = workspace next
# swipe-3-right = workspace prev
# swipe-4-up = overview
# swipe-3-down = none

[menu]
# Entries for the window menu (the `window-menu` role — right-click a titlebar,
# or the `window-menu` action). Read by gnoblin-window-menu; styling follows the
# Slint theme. Each `item` is `Label | action [arg]` using the same verbs as
# [bind] and gnoblinctl; a bare `-` is a separator. Omit every `item` for the
# built-in set (minimise / maximise / move / resize / snap / always-on-top / close).
# item = Minimise | minimize
# item = Maximise | maximize
# item = -
# item = Snap Left | snap left
# item = Snap Right | snap right
# item = -
# item = Close | close

[snap]
# Custom snap regions: name = x y w h  (fractions of the monitor work area).
# Override a built-in (left/right/top/bottom/top-left/.../center/full) or add
# your own, then `snap <name>` from a keybinding or gnoblinctl.
left-third = 0 0 0.333 1
center-half = 0.25 0 0.5 1

[window-rules]
# Per-app rules applied when a window opens — gnoblin's `for_window` / windowrule.
# One `rule` per line: `matchers | actions`. ALL matchers must hit. Each matcher
# is `key=value` (case-insensitive SUBSTRING) or `key~=pattern` (case-insensitive
# REGEX, GLib/PCRE; unanchored — use ^/$ for whole-string). Keys:
#   app-id=<id>   the app id (Wayland xdg app_id / GTK app id)
#   class=<cls>   the X11/Wayland window class
#   title=<text>  the window title
#   layer=<ns>    the wlr-layer-shell namespace (panels/dock; e.g. gnoblin-dock)
# Regex examples: class~=^firefox$ , title~=(Private|Incognito) , layer~=^gnoblin-
# Placement/state actions (comma-separated): float, size WxH, position X,Y,
#   center, workspace N, monitor N, sticky, above, maximize, fullscreen,
#   minimize, opacity N, inactive-opacity N (0-100), no-shadow, no-round.
# Visual-effect actions (override the [effects] global defaults per window):
#   rounding N                    corner radius in px (0 = square; like no-round)
#   corner-style circular|squircle
#   smoothing F                   0..1 corner smoothing
#   border W [#color]             border width in px + optional colour
#   border-style line|lip         flat stroke, or the macOS raised lip
#   no-border                     drop the border
#   blur [N] | no-blur            enable (optional radius) / disable blur-behind
#   blur-alpha-threshold F        frost only where surface alpha < F (0..1)
# rule = app-id=org.gnome.Calculator | float, size 360x500, center
# rule = title=Picture-in-Picture | sticky, above, opacity 92, no-shadow
# rule = class=foot | opacity 96, inactive-opacity 88
# rule = class=foot | rounding 16, corner-style squircle, smoothing 0.6
# rule = class=foot | border 1 "#ffffff22", border-style lip
# rule = layer=gnoblin-dock | rounding 18, border 1 "#ffffff20", border-style lip
# regex matchers (~=):
# rule = class~=^firefox$ | opacity 98
# rule = title~=(Private Browsing|Incognito) | above, no-shadow
# override the default chrome frost for one panel (e.g. a fatter dock blur):
# rule = layer~=^gnoblin-dock$ | blur 48, rounding 18
# rule = layer~=^gnoblin-topbar$ | no-blur
# only frost the translucent parts of a surface, not its solid UI:
# rule = class=foot | blur 32, blur-alpha-threshold 0.9

[protocols]
# Wayland protocols (all on by default). Turn one off to stop advertising it,
# which disables the matching tools (e.g. ext-data-control -> cliphist).
wlr-layer-shell = on
wlr-screencopy = on
ext-idle-notify = on
ext-foreign-toplevel-list = on
wlr-foreign-toplevel-management = on
wlr-gamma-control = on
wlr-output-power-management = on
ext-data-control = on
kde-appmenu = on
