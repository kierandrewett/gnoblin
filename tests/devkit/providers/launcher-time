#!/bin/sh
# Launcher provider: world clock. Query in $GNOBLIN_QUERY.
# "t tokyo" / "t new york" / "t utc" / "t berlin"  ->  current time in matching
# timezones (matched against the system tzdata). ⏎ copies the "HH:MM zone" line.
q="$GNOBLIN_QUERY"
[ -z "$q" ] && exit 0

zoneinfo=/usr/share/zoneinfo
[ -d "$zoneinfo" ] || exit 0

# tzdata uses underscores for spaces (America/New_York); match case-insensitively
# on the zone path, preferring the leaf (city) name.
qz=$(printf '%s' "$q" | tr ' ' '_')

find "$zoneinfo" -type f 2>/dev/null \
  | sed "s|$zoneinfo/||" \
  | grep -iE '^[A-Z]' \
  | grep -i -- "$qz" \
  | grep -vE 'posix/|right/|SystemV/' \
  | head -8 \
  | while IFS= read -r z; do
      t=$(TZ="$z" date '+%H:%M  ·  %a %d %b' 2>/dev/null) || continue
      city=$(printf '%s' "$z" | sed 's|.*/||; s|_| |g')
      # copy the bare "HH:MM" — single-quoted in the action so the colon is literal.
      hm=${t%% *}
      printf '%s\t%s — %s\tappointment-soon\twl-copy '"'"'%s'"'"'\n' "$t" "$city" "$z" "$hm"
    done
