#!/bin/sh
# Launcher provider: clipboard history. Needs `cliphist` + wl-clipboard
# (`cliphist store` running via your clipboard watcher). Query in $GNOBLIN_QUERY;
# ⏎ copies the chosen entry back to the clipboard.
command -v cliphist >/dev/null 2>&1 || exit 0
q="$GNOBLIN_QUERY"
cliphist list 2>/dev/null | grep -i -- "$q" | head -12 | while IFS= read -r line; do
  id=${line%%	*}      # cliphist id (first TAB-separated field)
  text=${line#*	}     # preview (rest of the line)
  printf '%s\tPaste from clipboard history\tedit-paste\tcliphist decode %s | wl-copy\n' "$text" "$id"
done
