#!/bin/sh
# Launcher provider: number-base converter. Query in $GNOBLIN_QUERY.
# "b 255" / "b 0xff" / "b 0b1010" / "b 0o17"  ->  DEC / HEX / OCT / BIN rows,
# each ⏎-copyable. (Uses gawk's strtonum — the default awk on Fedora/most distros.)
q="$GNOBLIN_QUERY"
[ -z "$q" ] && exit 0

printf '%s\n' "$q" | awk '
function tobin(n,  s){ if(n==0)return "0"; s=""; while(n>0){ s=(n%2) s; n=int(n/2) } return s }
{
  t=tolower($1)
  if (t ~ /^0x[0-9a-f]+$/)   n=strtonum(t)
  else if (t ~ /^0b[01]+$/)  { b=substr(t,3); n=0; for(i=1;i<=length(b);i++) n=n*2+substr(b,i,1) }
  else if (t ~ /^0o[0-7]+$/) n=strtonum("0" substr(t,3))
  else if (t ~ /^[0-9]+$/)   n=t+0
  else exit
  if (n<0) exit
  dec=sprintf("%d", n); hex=sprintf("0x%x", n); oct=sprintf("0o%o", n); bin="0b" tobin(n)
  # values are bare tokens (no spaces) so they need no shell quoting in the action.
  printf "%s\tDEC · enter copies\tutilities-calculator\tprintf %%s %s | wl-copy\n", dec, dec
  printf "%s\tHEX · enter copies\tutilities-calculator\twl-copy %s\n", hex, hex
  printf "%s\tOCT · enter copies\tutilities-calculator\twl-copy %s\n", oct, oct
  printf "%s\tBIN · enter copies\tutilities-calculator\twl-copy %s\n", bin, bin
}
'
