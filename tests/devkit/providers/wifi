#!/usr/bin/env bash
# Dummy Wi-Fi quick-settings provider (ONESHOT) for the gnoblin devkit.
#
# Emits FAKE network data so the devkit NEVER touches the host's real NetworkManager
# / nmcli. It prints one protocol JSON object on stdout and exits. The shell re-runs
# it on its [qs-plugin] interval and on each interaction (the event is passed in
# $GNOBLIN_QS_EVENT). Events are logged so callbacks can be verified.
set -euo pipefail

LOG="${GNOBLIN_QS_LOG:-${TMPDIR:-/tmp}/gnoblin-qs-events.log}"
STATE="${GNOBLIN_QS_STATE:-${TMPDIR:-/tmp}/gnoblin-qs-wifi.state}"

# Persisted "connected to" SSID (fake), so toggling/selecting peers survives re-runs.
ssid="$(cat "$STATE" 2>/dev/null || echo 'Gnoblin Dev Net')"

if [[ -n "${GNOBLIN_QS_EVENT:-}" ]]; then
    printf '%s wifi %s\n' "$(date -Iseconds)" "$GNOBLIN_QS_EVENT" >>"$LOG"
    # If a peer row was clicked, "connect" to that SSID (fake).
    case "$GNOBLIN_QS_EVENT" in
        *'"event":"row"'*'net-home'*)   ssid='Gnoblin Dev Net'; echo "$ssid" >"$STATE" ;;
        *'"event":"row"'*'net-guest'*)  ssid='Guest WiFi';      echo "$ssid" >"$STATE" ;;
        *'"event":"row"'*'net-lab'*)    ssid='Lab 5GHz';        echo "$ssid" >"$STATE" ;;
    esac
fi

active_row() { [[ "$1" == "$ssid" ]] && echo true || echo false; }

# One JSON object on a single line (oneshot: the shell takes the last line).
printf '%s\n' "{\"tile\":{\"icon\":\"network-wireless-symbolic\",\"title\":\"Wi-Fi\",\"subtitle\":\"$ssid\",\"active\":true,\"chevron\":true},\"menu\":{\"title\":\"Wi-Fi Networks\",\"rows\":[{\"type\":\"section\",\"label\":\"Available networks\"},{\"id\":\"net-home\",\"type\":\"item\",\"label\":\"Gnoblin Dev Net\",\"sublabel\":\"Secured · 80%\",\"icon\":\"network-wireless-symbolic\",\"on\":$(active_row 'Gnoblin Dev Net')},{\"id\":\"net-guest\",\"type\":\"item\",\"label\":\"Guest WiFi\",\"sublabel\":\"Open · 55%\",\"icon\":\"network-wireless-symbolic\",\"on\":$(active_row 'Guest WiFi')},{\"id\":\"net-lab\",\"type\":\"item\",\"label\":\"Lab 5GHz\",\"sublabel\":\"Secured · 42%\",\"icon\":\"network-wireless-symbolic\",\"on\":$(active_row 'Lab 5GHz')},{\"type\":\"separator\"},{\"id\":\"wifi-enabled\",\"type\":\"toggle\",\"label\":\"Enable Wi-Fi\",\"value\":true},{\"id\":\"wifi-settings\",\"type\":\"action\",\"label\":\"Network Settings…\",\"icon\":\"preferences-system-symbolic\"}]}}"
