#!/bin/sh
# Launcher provider: unit conversion. Query in $GNOBLIN_QUERY.
# Patterns: "<num> <unit> to <unit>"  or  "<num> <unit> in <unit>"
#   e.g. "10 km to mi", "72 f to c", "5 gb to mb", "90 min to h", "180 lb to kg"
# Result subtitle is copyable on ⏎ (wl-copy the bare number).
q="$GNOBLIN_QUERY"
[ -z "$q" ] && exit 0

printf '%s\n' "$q" | awk '
function canon(u) {
  u = tolower(u)
  # length (base: metre)
  if (u=="mm")  {cat="len"; k=0.001}        else if (u=="cm")  {cat="len"; k=0.01}
  else if (u=="m"||u=="metre"||u=="meter"||u=="meters") {cat="len"; k=1}
  else if (u=="km") {cat="len"; k=1000}      else if (u=="in"||u=="inch"||u=="inches") {cat="len"; k=0.0254}
  else if (u=="ft"||u=="foot"||u=="feet") {cat="len"; k=0.3048}
  else if (u=="yd"||u=="yard"||u=="yards") {cat="len"; k=0.9144}
  else if (u=="mi"||u=="mile"||u=="miles") {cat="len"; k=1609.344}
  # mass (base: gram)
  else if (u=="mg") {cat="mass"; k=0.001}    else if (u=="g"||u=="gram"||u=="grams") {cat="mass"; k=1}
  else if (u=="kg") {cat="mass"; k=1000}     else if (u=="t"||u=="tonne"||u=="tonnes") {cat="mass"; k=1000000}
  else if (u=="oz"||u=="ounce"||u=="ounces") {cat="mass"; k=28.349523125}
  else if (u=="lb"||u=="lbs"||u=="pound"||u=="pounds") {cat="mass"; k=453.59237}
  else if (u=="st"||u=="stone") {cat="mass"; k=6350.29318}
  # data (base: byte, binary 1024)
  else if (u=="b"||u=="byte"||u=="bytes") {cat="data"; k=1}
  else if (u=="kb"||u=="kib") {cat="data"; k=1024}
  else if (u=="mb"||u=="mib") {cat="data"; k=1048576}
  else if (u=="gb"||u=="gib") {cat="data"; k=1073741824}
  else if (u=="tb"||u=="tib") {cat="data"; k=1099511627776}
  # time (base: second)
  else if (u=="ms") {cat="time"; k=0.001}    else if (u=="s"||u=="sec"||u=="secs"||u=="second"||u=="seconds") {cat="time"; k=1}
  else if (u=="min"||u=="mins"||u=="minute"||u=="minutes") {cat="time"; k=60}
  else if (u=="h"||u=="hr"||u=="hrs"||u=="hour"||u=="hours") {cat="time"; k=3600}
  else if (u=="d"||u=="day"||u=="days") {cat="time"; k=86400}
  else if (u=="wk"||u=="week"||u=="weeks") {cat="time"; k=604800}
  # temperature handled separately (non-linear)
  else if (u=="c"||u=="celsius") {cat="temp"; k=0}
  else if (u=="f"||u=="fahrenheit") {cat="temp"; k=1}
  else if (u=="k"||u=="kelvin") {cat="temp"; k=2}
  else {cat=""; k=0}
  return k
}
function fmt(x) {
  if (x==int(x) && (x<1e15 && x>-1e15)) return sprintf("%d", x)
  s = sprintf("%.6g", x); return s
}
{
  # normalise "in" -> "to"; collapse the separator
  line = $0
  n = split(line, w, /[ \t]+/)
  # find the separator word index. Start at 3 (value + source-unit precede it) so
  # an "in" SOURCE unit — e.g. "1 in to cm" — is not mistaken for the separator.
  sep = 0
  for (i=3;i<=n;i++) if (w[i]=="to"||w[i]=="in"||w[i]=="as") { sep=i; break }
  if (sep<3 || sep>=n) exit
  val = w[1]+0
  if (w[1] !~ /^-?[0-9]*\.?[0-9]+$/) exit
  from=""; for (i=2;i<sep;i++) from=from w[i]
  to="";   for (i=sep+1;i<=n;i++) to=to w[i]
  k1 = canon(from); c1 = cat
  k2 = canon(to);   c2 = cat
  if (c1=="" || c2=="" || c1!=c2) exit
  if (c1=="temp") {
    # to celsius
    if (k1==0) cel=val; else if (k1==1) cel=(val-32)*5/9; else cel=val-273.15
    if (k2==0) out=cel; else if (k2==1) out=cel*9/5+32; else out=cel+273.15
  } else {
    out = val * k1 / k2
  }
  res = fmt(out)
  # res is a bare number (no spaces) so it needs no shell quoting in the action.
  printf "%s %s = %s %s\tConvert · enter copies %s\tutilities-calculator\tprintf %%s %s | wl-copy\n", fmt(val), from, res, to, res, res
}
'
