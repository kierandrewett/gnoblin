#!/usr/bin/env python3
"""Dummy MPRIS / now-playing quick-settings provider (PERSISTENT) for the devkit.

Stays alive, emits one ndjson protocol line per update on stdout, and reads
ndjson event lines on stdin. Uses FAKE track data — the devkit NEVER runs
playerctl or talks to the host's real media players. Logs events so callbacks
can be verified.
"""
import json
import os
import sys
import threading
import time

LOG = os.environ.get("GNOBLIN_QS_LOG",
                     os.path.join(os.environ.get("TMPDIR", "/tmp"),
                                  "gnoblin-qs-events.log"))

TRACKS = [
    ("Midnight City", "M83"),
    ("Strobe", "deadmau5"),
    ("Teardrop", "Massive Attack"),
]

state = {"idx": 0, "playing": True}
lock = threading.Lock()


def log(msg):
    try:
        with open(LOG, "a") as fh:
            fh.write(f"{time.strftime('%FT%T')} mpris {msg}\n")
    except OSError:
        pass


def emit():
    with lock:
        title, artist = TRACKS[state["idx"] % len(TRACKS)]
        playing = state["playing"]
    update = {
        "tile": {
            "icon": "audio-x-generic-symbolic",
            "title": title,
            "subtitle": ("Playing" if playing else "Paused") + " · " + artist,
            "active": playing,
            "chevron": True,
            "span": 4,
            "layout": "media",
        },
        "menu": {
            "title": "Now Playing",
            "rows": [
                {"id": "prev", "type": "action", "label": "Previous",
                 "icon": "media-skip-backward-symbolic"},
                {"id": "playpause", "type": "toggle",
                 "label": "Pause" if playing else "Play", "value": playing},
                {"id": "next", "type": "action", "label": "Next",
                 "icon": "media-skip-forward-symbolic"},
                {"type": "separator"},
                {"id": "track", "type": "item", "label": title,
                 "sublabel": artist, "icon": "emblem-music-symbolic"},
            ],
        },
    }
    sys.stdout.write(json.dumps(update) + "\n")
    sys.stdout.flush()


def handle(event):
    log(json.dumps(event))
    ev = event.get("event")
    rid = event.get("id", "")
    with lock:
        if ev == "row" and rid == "next" or (ev == "toggle" and rid == "next"):
            state["idx"] += 1
        elif ev == "row" and rid == "prev":
            state["idx"] -= 1
        elif rid == "playpause":
            state["playing"] = bool(event.get("value", not state["playing"]))
    emit()


def reader():
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            handle(json.loads(line))
        except (ValueError, KeyError):
            pass


def main():
    threading.Thread(target=reader, daemon=True).start()
    emit()
    # Keep the process alive; re-emit periodically to prove persistent updates flow.
    while True:
        time.sleep(15)
        emit()


if __name__ == "__main__":
    try:
        main()
    except (BrokenPipeError, KeyboardInterrupt):
        pass
