#!/bin/sh
# Launcher provider: file search under $HOME. Query in $1.
q="$1"
[ -z "$q" ] && exit 0
if command -v fd >/dev/null 2>&1; then
  fd -tf -d5 -i --max-results 12 -- "$q" "$HOME" 2>/dev/null
else
  find "$HOME" -maxdepth 5 -type f -iname "*$q*" 2>/dev/null | head -12
fi | while IFS= read -r p; do
  printf '%s\t%s\ttext-x-generic\txdg-open "%s"\n' "${p##*/}" "$p" "$p"
done
