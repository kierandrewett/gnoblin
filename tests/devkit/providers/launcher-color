#!/bin/sh
# Launcher provider: colour converter. Query in $GNOBLIN_QUERY.
# Accepts:  "#ff8800" / "ff8800" / "#f80"     -> emits HEX, RGB, HSL (each ⏎-copyable)
#           "255,136,0" / "rgb(255,136,0)"     -> same
# (Uses gawk's strtonum for hex parsing — the default awk on Fedora/most distros.)
q="$GNOBLIN_QUERY"
[ -z "$q" ] && exit 0

printf '%s\n' "$q" | awk '
function clamp(x){ if(x<0)return 0; if(x>255)return 255; return x }
function hx(n,  s){ s=sprintf("%02x", clamp(int(n+0.5))); return s }
function rgb2hsl(r,g,b,  mx,mn,d,h,s,l){
  r=r/255; g=g/255; b=b/255
  mx=r; if(g>mx)mx=g; if(b>mx)mx=b
  mn=r; if(g<mn)mn=g; if(b<mn)mn=b
  l=(mx+mn)/2; d=mx-mn
  if(d==0){h=0;s=0}
  else{
    s = (l>0.5) ? d/(2-mx-mn) : d/(mx+mn)
    if(mx==r) h=(g-b)/d + (g<b?6:0)
    else if(mx==g) h=(b-r)/d + 2
    else h=(r-g)/d + 4
    h=h*60
  }
  HSL_H=int(h+0.5); HSL_S=int(s*100+0.5); HSL_L=int(l*100+0.5)
}
{
  s = tolower($0)
  gsub(/[ \t]/,"",s); gsub(/rgb\(|\)|hsl\(/,"",s)
  r=-1; g=-1; b=-1
  # hex forms
  hex=s; sub(/^#/,"",hex)
  if (hex ~ /^[0-9a-f]{6}$/) {
    r=strtonum("0x" substr(hex,1,2)); g=strtonum("0x" substr(hex,3,2)); b=strtonum("0x" substr(hex,5,2))
  } else if (hex ~ /^[0-9a-f]{3}$/) {
    r=strtonum("0x" substr(hex,1,1) substr(hex,1,1))
    g=strtonum("0x" substr(hex,2,1) substr(hex,2,1))
    b=strtonum("0x" substr(hex,3,1) substr(hex,3,1))
  } else if (s ~ /^[0-9]+,[0-9]+,[0-9]+$/) {
    n=split(s,p,","); r=p[1]+0; g=p[2]+0; b=p[3]+0
  }
  if (r<0 || r>255 || g<0 || g>255 || b<0 || b>255) exit
  hexv = "#" hx(r) hx(g) hx(b)
  rgbv = sprintf("rgb(%d, %d, %d)", r, g, b)
  rgbc = sprintf("%d,%d,%d", r, g, b)
  rgb2hsl(r,g,b)
  hslv = sprintf("hsl(%d, %d%%, %d%%)", HSL_H, HSL_S, HSL_L)
  # Copy via wl-copy with single-quoted argv — safe for spaces, parens and %.
  printf "%s\tHEX · enter copies\tapplications-graphics\twl-copy '"'"'%s'"'"'\n", hexv, hexv
  printf "%s\tRGB · enter copies\tapplications-graphics\twl-copy '"'"'%s'"'"'\n", rgbv, rgbc
  printf "%s\tHSL · enter copies\tapplications-graphics\twl-copy '"'"'%s'"'"'\n", hslv, hslv
}
'
