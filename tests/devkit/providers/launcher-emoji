#!/bin/sh
# Launcher provider: emoji search. Query in $GNOBLIN_QUERY; ⏎ copies the emoji (wl-copy).
q=$(printf '%s' "$GNOBLIN_QUERY" | tr '[:upper:]' '[:lower:]')
[ -z "$q" ] && exit 0
emoji_table() {
cat <<'EOF'
😀 grinning smile happy
😂 joy laugh cry funny lol
😍 heart eyes love
🥰 love hearts adore
😎 cool sunglasses
🤔 thinking hmm
😭 sob cry sad
😱 scream shock
👍 thumbs up yes ok good
👎 thumbs down no bad
🙏 pray thanks please
👏 clap applause
🔥 fire lit hot
✨ sparkles shiny magic
🎉 party tada celebrate
💯 hundred perfect
❤️ red heart love
⭐ star
✅ check tick done ok
❌ cross no wrong fail
⚠️ warning caution
🚀 rocket launch ship deploy
💡 idea bulb light
🐛 bug error
☕ coffee
🎵 music note song
💻 laptop computer code dev
📦 package box ship
🔑 key
🔒 lock secure
👀 eyes look watch
🤖 robot bot ai
😴 sleep tired zzz
🤯 mind blown exploding
🫠 melt hot
🙃 upside down silly
EOF
}
emoji_table | grep -i -- "$q" | head -12 | while read -r emo rest; do
  first=${rest%% *}
  printf '%s  %s\tCopy emoji\t\tprintf %%s %s | wl-copy\n' "$emo" "$first" "'$emo'"
done
