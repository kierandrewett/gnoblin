+
+/* gnoblin: per-app persistent ScreenCast / RemoteDesktop grants. */
+
+static char *
+gnoblin_portal_grants_dir (void)
+{
+  return g_build_filename (g_get_user_config_dir (),
+                           "gnoblin", "portal-grants", NULL);
+}
+
+/* Map an arbitrary id (app_id or executable basename) onto a safe filename,
+ * so a grant can never escape the grants directory. Returns NULL if nothing
+ * usable remains. */
+static char *
+gnoblin_portal_sanitize_id (const char *raw)
+{
+  GString *sanitized;
+  const char *p;
+
+  if (raw == NULL || *raw == '\0')
+    return NULL;
+
+  sanitized = g_string_new (NULL);
+  for (p = raw; *p != '\0'; p++)
+    {
+      char c = *p;
+
+      if (g_ascii_isalnum (c) || c == '.' || c == '-' || c == '_')
+        g_string_append_c (sanitized, c);
+      else
+        g_string_append_c (sanitized, '_');
+    }
+
+  if (sanitized->len == 0 ||
+      g_strcmp0 (sanitized->str, ".") == 0 ||
+      g_strcmp0 (sanitized->str, "..") == 0)
+    {
+      g_string_free (sanitized, TRUE);
+      return NULL;
+    }
+
+  return g_string_free (sanitized, FALSE);
+}
+
+char *
+gnoblin_portal_grant_id (const char            *app_id,
+                         GDBusMethodInvocation *invocation)
+{
+  g_autofree char *raw = NULL;
+
+  if (app_id != NULL && *app_id != '\0')
+    {
+      raw = g_strdup (app_id);
+    }
+  else if (invocation != NULL)
+    {
+      GDBusConnection *connection;
+      const char *sender;
+      g_autoptr(GVariant) reply = NULL;
+      g_autoptr(GError) error = NULL;
+      guint32 pid = 0;
+
+      /* Unsandboxed apps hand us an empty app_id, so fall back to the sender's
+       * executable basename for a stable per-binary id. */
+      sender = g_dbus_method_invocation_get_sender (invocation);
+      connection = g_dbus_method_invocation_get_connection (invocation);
+      if (connection != NULL && sender != NULL)
+        {
+          reply =
+            g_dbus_connection_call_sync (connection,
+                                         "org.freedesktop.DBus",
+                                         "/org/freedesktop/DBus",
+                                         "org.freedesktop.DBus",
+                                         "GetConnectionUnixProcessID",
+                                         g_variant_new ("(s)", sender),
+                                         G_VARIANT_TYPE ("(u)"),
+                                         G_DBUS_CALL_FLAGS_NONE,
+                                         -1, NULL, &error);
+          if (reply != NULL)
+            g_variant_get (reply, "(u)", &pid);
+          else
+            g_debug ("gnoblin: could not resolve sender pid: %s",
+                     error ? error->message : "unknown error");
+        }
+
+      if (pid > 0)
+        {
+          g_autofree char *exe_link = NULL;
+          g_autofree char *exe_path = NULL;
+
+          exe_link = g_strdup_printf ("/proc/%u/exe", pid);
+          exe_path = g_file_read_link (exe_link, NULL);
+          if (exe_path != NULL)
+            raw = g_path_get_basename (exe_path);
+        }
+    }
+
+  return gnoblin_portal_sanitize_id (raw);
+}
+
+gboolean
+gnoblin_portal_app_granted (const char *grant_id)
+{
+  g_autofree char *dir = NULL;
+  g_autofree char *path = NULL;
+
+  if (grant_id == NULL || *grant_id == '\0')
+    return FALSE;
+
+  dir = gnoblin_portal_grants_dir ();
+  path = g_build_filename (dir, grant_id, NULL);
+
+  return g_file_test (path, G_FILE_TEST_EXISTS);
+}
+
+void
+gnoblin_portal_store_grant (const char *grant_id)
+{
+  g_autofree char *dir = NULL;
+  g_autofree char *path = NULL;
+
+  if (grant_id == NULL || *grant_id == '\0')
+    return;
+
+  dir = gnoblin_portal_grants_dir ();
+  if (g_mkdir_with_parents (dir, 0700) != 0)
+    {
+      g_warning ("gnoblin: failed to create portal grants dir %s", dir);
+      return;
+    }
+
+  path = g_build_filename (dir, grant_id, NULL);
+  if (!g_file_set_contents (path, "", 0, NULL))
+    g_warning ("gnoblin: failed to store portal grant %s", path);
+}
