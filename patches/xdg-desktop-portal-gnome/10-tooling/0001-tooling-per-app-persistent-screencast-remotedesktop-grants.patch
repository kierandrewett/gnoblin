     {
       ScreenCastDialogHandle *dialog_handle;
 
+      /* gnoblin: macOS-style per-app grant. If the user has previously ticked
+       * "Always allow this app" for this app, skip the source picker and grant
+       * every monitor, exactly as the accepted dialog would. Default (no stored
+       * grant) still shows the dialog. */
+      if (gnoblin_portal_app_granted (screen_cast_session->gnoblin_grant_id))
+        {
+          g_autoptr(GPtrArray) streams = NULL;
+          g_autoptr(GError) error = NULL;
+
+          g_debug ("gnoblin: screen cast auto-granted for '%s'",
+                   screen_cast_session->gnoblin_grant_id);
+
+          streams = screen_cast_select_all_monitors (&screen_cast_session->select);
+          if (streams && start_session (screen_cast_session, streams, &error))
+            {
+              if (request->exported)
+                request_unexport (request);
+              return TRUE;
+            }
+
+          g_warning ("gnoblin: screen cast grant fast path failed: %s",
+                     error ? error->message : "no shareable monitor");
+          cancel_start_session (screen_cast_session, 2);
+          if (request->exported)
+            request_unexport (request);
+          return TRUE;
+        }
+
       dialog_handle = create_screen_cast_dialog (screen_cast_session,
                                                  invocation,
                                                  request,
@@ -927,6 +1012,7 @@ screen_cast_session_finalize (GObject *object)
 
   g_clear_pointer (&screen_cast_session->streams_to_restore, g_ptr_array_unref);
   g_clear_pointer (&screen_cast_session->restored.data, g_variant_unref);
+  g_clear_pointer (&screen_cast_session->gnoblin_grant_id, g_free);
   g_clear_object (&screen_cast_session->gnome_screen_cast_session);
 
