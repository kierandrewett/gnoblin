+GPtrArray *
+screen_cast_select_all_monitors (ScreenCastSelection *selection)
+{
+  DisplayStateTracker *display_state_tracker = display_state_tracker_get ();
+  g_autoptr(GPtrArray) streams = NULL;
+  uint32_t id = 0;
+  GList *l;
+
+  if (!selection->source_types.monitor)
+    return NULL;
+
+  streams =
+    g_ptr_array_new_with_free_func ((GDestroyNotify) screen_cast_stream_info_free);
+
+  for (l = display_state_tracker_get_logical_monitors (display_state_tracker);
+       l;
+       l = l->next)
+    {
+      LogicalMonitor *logical_monitor = l->data;
+      GList *monitors = logical_monitor_get_monitors (logical_monitor);
+      ScreenCastStreamInfo *info;
+
+      if (!monitors)
+        continue;
+
+      info = g_new0 (ScreenCastStreamInfo, 1);
+      info->type = SCREEN_CAST_SOURCE_TYPE_MONITOR;
+      info->data.monitor = monitor_dup ((Monitor *) monitors->data);
+      info->id = id++;
+      g_ptr_array_add (streams, info);
+
+      if (!selection->multiple)
+        break;
+    }
+
+  if (streams->len == 0)
+    return NULL;
+
+  return g_steal_pointer (&streams);
+}
+
 static gboolean
 restore_stream_from_data (ScreenCastSession *screen_cast_session)
 {
@@ -664,10 +714,45 @@ handle_start (XdpImplScreenCast     *object,
 
   screen_cast_session->start_invocation = invocation;
 
+  /* gnoblin: remember who is asking so an approved "Always allow this app"
+   * checkbox can persist a grant, and so a previously stored grant can skip
