diff --git a/src/remotedesktop.c b/src/remotedesktop.c
index ad466a3..2a415c9 100644
--- a/src/remotedesktop.c
+++ b/src/remotedesktop.c
@@ -93,6 +93,10 @@ typedef struct _RemoteDesktopSession
 
   GDBusMethodInvocation *start_invocation;
   RemoteDesktopDialogHandle *dialog_handle;
+
+  /* gnoblin: stable per-app id for the persistent grant store, computed in
+   * handle_start() and consulted again when the dialog is approved. */
+  char *gnoblin_grant_id;
 } RemoteDesktopSession;
 
 typedef struct _RemoteDesktopSessionClass
@@ -258,6 +262,11 @@ remote_desktop_dialog_done (GtkWidget                 *widget,
     {
       g_autoptr(GError) error = NULL;
 
+      /* gnoblin: the user approved; if they also ticked "Always allow this
+       * app", persist a per-app grant so future sessions skip this dialog. */
+      if (remote_desktop_dialog_get_always_allow (REMOTE_DESKTOP_DIALOG (widget)))
+        gnoblin_portal_store_grant (dialog_handle->session->gnoblin_grant_id);
+
       if (!start_session (dialog_handle->session,
                           device_types,
                           streams,
@@ -816,10 +825,65 @@ handle_start (XdpImplRemoteDesktop *object,
 
   remote_desktop_session->start_invocation = invocation;
 
+  /* gnoblin: remember who is asking so an approved "Always allow this app"
+   * checkbox can persist a grant, and so a previously stored grant can skip
+   * the dialog below. */
+  g_clear_pointer (&remote_desktop_session->gnoblin_grant_id, g_free);
+  remote_desktop_session->gnoblin_grant_id =
+    gnoblin_portal_grant_id (arg_app_id, invocation);
+
   if (!restore_from_data (remote_desktop_session))
     {
       RemoteDesktopDialogHandle *dialog_handle;
 
+      /* gnoblin: macOS-style per-app grant. If the user has previously ticked
+       * "Always allow this app", skip the consent dialog and grant the
+       * requested devices (and, if screen cast was selected, every monitor),
+       * with persistence allowed. Default (no stored grant) shows the dialog. */
+      if (gnoblin_portal_app_granted (remote_desktop_session->gnoblin_grant_id))
+        {
+          g_autoptr(GPtrArray) streams = NULL;
+          g_autoptr(GError) error = NULL;
+          gboolean clipboard_enabled;
+
+          g_debug ("gnoblin: remote desktop auto-granted for '%s'",
+                   remote_desktop_session->gnoblin_grant_id);
+
+          if (remote_desktop_session->select.screen_cast_enable)
+            {
+              streams = screen_cast_select_all_monitors (
+                &remote_desktop_session->select.screen_cast);
+              if (!streams)
+                {
+                  g_warning ("gnoblin: remote desktop grant fast path failed: "
+                             "no shareable monitor");
+                  cancel_start_session (remote_desktop_session, 2);
+                  if (request->exported)
+                    request_unexport (request);
+                  return TRUE;
+                }
+            }
+
+          clipboard_enabled =
+            remote_desktop_session->clipboard.clipboard_requested;
+
+          if (!start_session (remote_desktop_session,
+                              remote_desktop_session->select.device_types,
+                              streams,
+                              clipboard_enabled,
+                              TRUE,
+                              &error))
+            {
+              g_warning ("gnoblin: remote desktop grant fast path failed: %s",
+                         error ? error->message : "unknown error");
+              cancel_start_session (remote_desktop_session, 2);
+            }
+
+          if (request->exported)
+            request_unexport (request);
+          return TRUE;
+        }
+
       dialog_handle = create_remote_desktop_dialog (remote_desktop_session,
                                                     invocation,
                                                     request,
@@ -1316,6 +1380,7 @@ remote_desktop_session_finalize (GObject *object)
   g_clear_pointer (&remote_desktop_session->streams_to_restore,
                    g_ptr_array_unref);
   g_clear_pointer (&remote_desktop_session->restored.data, g_variant_unref);
+  g_clear_pointer (&remote_desktop_session->gnoblin_grant_id, g_free);
   g_free (remote_desktop_session->mutter_session_path);
 
   G_OBJECT_CLASS (remote_desktop_session_parent_class)->finalize (object);
