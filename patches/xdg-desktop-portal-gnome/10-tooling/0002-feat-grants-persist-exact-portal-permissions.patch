diff --git a/src/gnoblin-portal-grants.c b/src/gnoblin-portal-grants.c
new file mode 100644
index 0000000..b12cbd7
--- /dev/null
+++ b/src/gnoblin-portal-grants.c
@@ -0,0 +1,547 @@
+/*
+ * SPDX-License-Identifier: LGPL-2.1-or-later
+ */
+
+#include "config.h"
+
+#include <errno.h>
+#include <glib/gstdio.h>
+#include <unistd.h>
+
+#include "gnoblin-portal-grants.h"
+
+#define PORTAL_DESKTOP_NAME "org.freedesktop.portal.Desktop"
+#define REQUEST_PATH_PREFIX "/org/freedesktop/portal/desktop/request/"
+#define GRANT_GROUP "Grant"
+#define GRANT_VERSION 1
+
+static const char *
+grant_kind_name (GnoblinPortalGrantKind kind)
+{
+  switch (kind)
+    {
+    case GNOBLIN_PORTAL_GRANT_SCREEN_CAST:
+      return "screen-cast";
+    case GNOBLIN_PORTAL_GRANT_REMOTE_DESKTOP:
+      return "remote-desktop";
+    }
+
+  g_assert_not_reached ();
+}
+
+static GVariant *
+call_bus_method (GDBusConnection    *connection,
+                 const char         *method,
+                 GVariant           *parameters,
+                 const GVariantType *reply_type,
+                 GError            **error)
+{
+  return g_dbus_connection_call_sync (connection,
+                                      "org.freedesktop.DBus",
+                                      "/org/freedesktop/DBus",
+                                      "org.freedesktop.DBus",
+                                      method,
+                                      parameters,
+                                      reply_type,
+                                      G_DBUS_CALL_FLAGS_NONE,
+                                      2000,
+                                      NULL,
+                                      error);
+}
+
+static char *
+portal_frontend_owner (GDBusConnection *connection)
+{
+  g_autoptr(GError) error = NULL;
+  g_autoptr(GVariant) reply = NULL;
+  const char *owner;
+
+  reply = call_bus_method (connection,
+                           "GetNameOwner",
+                           g_variant_new ("(s)", PORTAL_DESKTOP_NAME),
+                           G_VARIANT_TYPE ("(s)"),
+                           &error);
+  if (!reply)
+    {
+      g_debug ("gnoblin: cannot resolve the desktop portal owner: %s",
+               error->message);
+      return NULL;
+    }
+
+  g_variant_get (reply, "(&s)", &owner);
+  return g_strdup (owner);
+}
+
+static char *
+request_sender_from_handle (const char *request_handle)
+{
+  const char *component;
+  const char *component_end;
+  g_autofree char *decoded = NULL;
+  char *separator;
+
+  if (!request_handle || !g_str_has_prefix (request_handle, REQUEST_PATH_PREFIX))
+    return NULL;
+
+  component = request_handle + strlen (REQUEST_PATH_PREFIX);
+  component_end = strchr (component, '/');
+  if (!component_end || component_end == component || component_end[1] == '\0')
+    return NULL;
+
+  decoded = g_strndup (component, component_end - component);
+  separator = strchr (decoded, '_');
+  if (!separator || strchr (separator + 1, '_'))
+    return NULL;
+
+  for (const char *p = decoded; *p; p++)
+    {
+      if (p == separator)
+        continue;
+      if (!g_ascii_isdigit (*p))
+        return NULL;
+    }
+
+  if (separator == decoded || separator[1] == '\0')
+    return NULL;
+
+  *separator = '.';
+  return g_strconcat (":", decoded, NULL);
+}
+
+static gboolean
+connection_matches_user (GDBusConnection *connection,
+                         const char      *sender)
+{
+  g_autoptr(GError) error = NULL;
+  g_autoptr(GVariant) reply = NULL;
+  guint32 uid;
+
+  reply = call_bus_method (connection,
+                           "GetConnectionUnixUser",
+                           g_variant_new ("(s)", sender),
+                           G_VARIANT_TYPE ("(u)"),
+                           &error);
+  if (!reply)
+    {
+      g_debug ("gnoblin: cannot resolve portal requester %s: %s",
+               sender,
+               error->message);
+      return FALSE;
+    }
+
+  g_variant_get (reply, "(u)", &uid);
+  return uid == getuid ();
+}
+
+static char *
+host_executable_identity (GDBusConnection *connection,
+                          const char      *sender)
+{
+  g_autoptr(GError) error = NULL;
+  g_autoptr(GVariant) reply = NULL;
+  g_autofree char *proc_link = NULL;
+  g_autofree char *exe_path = NULL;
+  g_autofree char *canonical_path = NULL;
+  guint32 pid;
+
+  reply = call_bus_method (connection,
+                           "GetConnectionUnixProcessID",
+                           g_variant_new ("(s)", sender),
+                           G_VARIANT_TYPE ("(u)"),
+                           &error);
+  if (!reply)
+    {
+      g_debug ("gnoblin: cannot resolve host portal requester %s: %s",
+               sender,
+               error->message);
+      return NULL;
+    }
+
+  g_variant_get (reply, "(u)", &pid);
+  if (pid == 0)
+    return NULL;
+
+  proc_link = g_strdup_printf ("/proc/%u/exe", pid);
+  exe_path = g_file_read_link (proc_link, &error);
+  if (!exe_path)
+    {
+      g_debug ("gnoblin: cannot read host portal requester executable: %s",
+               error->message);
+      return NULL;
+    }
+
+  if (!g_path_is_absolute (exe_path))
+    return NULL;
+
+  canonical_path = g_canonicalize_filename (exe_path, NULL);
+  if (!g_file_test (canonical_path, G_FILE_TEST_IS_REGULAR))
+    return NULL;
+
+  return g_strconcat ("host-exe:", canonical_path, NULL);
+}
+
+char *
+gnoblin_portal_requester_identity (GDBusConnection *connection,
+                                    const char      *backend_sender,
+                                    const char      *app_id,
+                                    const char      *request_handle)
+{
+  g_autofree char *frontend_owner = NULL;
+  g_autofree char *request_sender = NULL;
+
+  g_return_val_if_fail (G_IS_DBUS_CONNECTION (connection), NULL);
+
+  frontend_owner = portal_frontend_owner (connection);
+  if (!frontend_owner || g_strcmp0 (frontend_owner, backend_sender) != 0)
+    {
+      g_debug ("gnoblin: refusing persistent grant from a direct backend caller");
+      return NULL;
+    }
+
+  request_sender = request_sender_from_handle (request_handle);
+  if (!request_sender || !connection_matches_user (connection, request_sender))
+    {
+      g_debug ("gnoblin: refusing persistent grant with an invalid or stale request handle");
+      return NULL;
+    }
+
+  if (app_id && *app_id)
+    {
+      if (!g_utf8_validate (app_id, -1, NULL))
+        return NULL;
+      return g_strconcat ("app-id:", app_id, NULL);
+    }
+
+  return host_executable_identity (connection, request_sender);
+}
+
+const char *
+gnoblin_portal_identity_name (const char *identity)
+{
+  const char *separator;
+
+  if (!identity)
+    return NULL;
+
+  separator = strchr (identity, ':');
+  return separator ? separator + 1 : NULL;
+}
+
+static char *
+grant_digest (const char *identity)
+{
+  g_autoptr(GChecksum) checksum = NULL;
+  const char *separator;
+
+  separator = strchr (identity, ':');
+  if (!separator || separator == identity || separator[1] == '\0')
+    return NULL;
+
+  checksum = g_checksum_new (G_CHECKSUM_SHA256);
+  g_checksum_update (checksum, (const guchar *) identity, separator - identity);
+  g_checksum_update (checksum, (const guchar *) "\0", 1);
+  g_checksum_update (checksum,
+                     (const guchar *) separator + 1,
+                     strlen (separator + 1));
+  return g_strdup (g_checksum_get_string (checksum));
+}
+
+static char *
+grant_path (GnoblinPortalGrantKind kind,
+            const char             *identity,
+            gboolean                create_directory,
+            GError                **error)
+{
+  g_autofree char *digest = NULL;
+  g_autofree char *directory = NULL;
+  g_autofree char *filename = NULL;
+
+  digest = grant_digest (identity);
+  if (!digest)
+    {
+      g_set_error_literal (error,
+                           G_IO_ERROR,
+                           G_IO_ERROR_INVALID_ARGUMENT,
+                           "Invalid portal grant identity");
+      return NULL;
+    }
+
+  directory = g_build_filename (g_get_user_data_dir (),
+                                "gnoblin",
+                                "portal-grants",
+                                grant_kind_name (kind),
+                                NULL);
+  if (create_directory)
+    {
+      if (g_mkdir_with_parents (directory, 0700) != 0)
+        {
+          g_set_error (error,
+                       G_IO_ERROR,
+                       g_io_error_from_errno (errno),
+                       "Failed to create portal grant directory %s: %s",
+                       directory,
+                       g_strerror (errno));
+          return NULL;
+        }
+      if (g_chmod (directory, 0700) != 0)
+        g_debug ("gnoblin: cannot tighten permissions on %s: %s",
+                 directory,
+                 g_strerror (errno));
+    }
+
+  filename = g_strconcat (digest, ".grant", NULL);
+  return g_build_filename (directory, filename, NULL);
+}
+
+void
+gnoblin_portal_grant_clear (GnoblinPortalGrant *grant)
+{
+  if (!grant)
+    return;
+
+  g_clear_pointer (&grant->identity, g_free);
+  g_clear_pointer (&grant->streams, g_variant_unref);
+  grant->device_types = 0;
+  grant->clipboard_enabled = FALSE;
+}
+
+static gboolean
+streams_are_exact_monitor_selection (GVariant *streams)
+{
+  g_autoptr(GVariantIter) iter = NULL;
+  g_autoptr(GVariant) data = NULL;
+  guint32 id;
+  guint32 source_type;
+
+  if (!streams)
+    return TRUE;
+
+  iter = g_variant_iter_new (streams);
+  while (g_variant_iter_next (iter, "(uuv)", &id, &source_type, &data))
+    {
+      if (source_type != 1 ||
+          !g_variant_check_format_string (data, "s", FALSE))
+        return FALSE;
+      g_clear_pointer (&data, g_variant_unref);
+    }
+
+  return TRUE;
+}
+
+static gboolean
+grant_is_valid (GnoblinPortalGrantKind  kind,
+                const char             *identity,
+                uint32_t                device_types,
+                gboolean                clipboard_enabled,
+                GVariant               *streams,
+                GError                **error)
+{
+  if (!gnoblin_portal_identity_name (identity))
+    {
+      g_set_error_literal (error,
+                           G_IO_ERROR,
+                           G_IO_ERROR_INVALID_ARGUMENT,
+                           "Invalid portal grant identity");
+      return FALSE;
+    }
+
+  if (streams &&
+      (!g_variant_is_of_type (streams,
+                             G_VARIANT_TYPE (GNOBLIN_PORTAL_GRANT_STREAMS_TYPE)) ||
+       g_variant_n_children (streams) == 0))
+    {
+      g_set_error_literal (error,
+                           G_IO_ERROR,
+                           G_IO_ERROR_INVALID_DATA,
+                           "Invalid portal grant stream selection");
+      return FALSE;
+    }
+
+  if (!streams_are_exact_monitor_selection (streams))
+    {
+      g_set_error_literal (error,
+                           G_IO_ERROR,
+                           G_IO_ERROR_INVALID_DATA,
+                           "Persistent grants only support exact monitor selections");
+      return FALSE;
+    }
+
+  if (kind == GNOBLIN_PORTAL_GRANT_SCREEN_CAST &&
+      (device_types != 0 || clipboard_enabled || !streams))
+    {
+      g_set_error_literal (error,
+                           G_IO_ERROR,
+                           G_IO_ERROR_INVALID_DATA,
+                           "Screen cast grant does not contain an exact stream selection");
+      return FALSE;
+    }
+
+  if (kind == GNOBLIN_PORTAL_GRANT_REMOTE_DESKTOP &&
+      device_types == 0 && !clipboard_enabled && !streams)
+    {
+      g_set_error_literal (error,
+                           G_IO_ERROR,
+                           G_IO_ERROR_INVALID_DATA,
+                           "Remote desktop grant contains no capabilities");
+      return FALSE;
+    }
+
+  return TRUE;
+}
+
+gboolean
+gnoblin_portal_grant_store (GnoblinPortalGrantKind  kind,
+                            const char              *identity,
+                            uint32_t                 device_types,
+                            gboolean                 clipboard_enabled,
+                            GVariant                *streams,
+                            GError                 **error)
+{
+  g_autoptr(GKeyFile) key_file = NULL;
+  g_autofree char *path = NULL;
+  g_autofree char *stream_text = NULL;
+  g_autofree char *contents = NULL;
+  gsize contents_length;
+
+  if (!grant_is_valid (kind,
+                       identity,
+                       device_types,
+                       clipboard_enabled,
+                       streams,
+                       error))
+    return FALSE;
+
+  path = grant_path (kind, identity, TRUE, error);
+  if (!path)
+    return FALSE;
+
+  key_file = g_key_file_new ();
+  g_key_file_set_integer (key_file, GRANT_GROUP, "version", GRANT_VERSION);
+  g_key_file_set_string (key_file, GRANT_GROUP, "portal", grant_kind_name (kind));
+  g_key_file_set_string (key_file, GRANT_GROUP, "identity", identity);
+  g_key_file_set_uint64 (key_file, GRANT_GROUP, "device-types", device_types);
+  g_key_file_set_boolean (key_file,
+                          GRANT_GROUP,
+                          "clipboard-enabled",
+                          clipboard_enabled);
+  if (streams)
+    {
+      stream_text = g_variant_print (streams, TRUE);
+      g_key_file_set_string (key_file, GRANT_GROUP, "streams", stream_text);
+    }
+
+  contents = g_key_file_to_data (key_file, &contents_length, error);
+  if (!contents || !g_file_set_contents (path, contents, contents_length, error))
+    return FALSE;
+
+  if (g_chmod (path, 0600) != 0)
+    {
+      g_set_error (error,
+                   G_IO_ERROR,
+                   g_io_error_from_errno (errno),
+                   "Failed to protect portal grant %s: %s",
+                   path,
+                   g_strerror (errno));
+      g_unlink (path);
+      return FALSE;
+    }
+
+  return TRUE;
+}
+
+gboolean
+gnoblin_portal_grant_load (GnoblinPortalGrantKind  kind,
+                           const char              *identity,
+                           GnoblinPortalGrant      *grant,
+                           GError                 **error)
+{
+  g_autoptr(GKeyFile) key_file = NULL;
+  g_autofree char *path = NULL;
+  g_autofree char *contents = NULL;
+  g_autofree char *stored_portal = NULL;
+  g_autofree char *stored_identity = NULL;
+  g_autofree char *stream_text = NULL;
+  g_autoptr(GVariant) streams = NULL;
+  g_autoptr(GError) local_error = NULL;
+  guint64 device_types;
+  gboolean clipboard_enabled;
+  int version;
+
+  g_return_val_if_fail (grant != NULL, FALSE);
+  gnoblin_portal_grant_clear (grant);
+
+  path = grant_path (kind, identity, FALSE, error);
+  if (!path)
+    return FALSE;
+  if (!g_file_test (path, G_FILE_TEST_EXISTS))
+    return FALSE;
+
+  if (!g_file_get_contents (path, &contents, NULL, error))
+    return FALSE;
+
+  key_file = g_key_file_new ();
+  if (!g_key_file_load_from_data (key_file, contents, -1, G_KEY_FILE_NONE, error))
+    return FALSE;
+
+  version = g_key_file_get_integer (key_file, GRANT_GROUP, "version", &local_error);
+  if (local_error || version != GRANT_VERSION)
+    goto invalid_record;
+
+  stored_portal = g_key_file_get_string (key_file, GRANT_GROUP, "portal", &local_error);
+  if (local_error || g_strcmp0 (stored_portal, grant_kind_name (kind)) != 0)
+    goto invalid_record;
+
+  stored_identity = g_key_file_get_string (key_file, GRANT_GROUP, "identity", &local_error);
+  if (local_error || g_strcmp0 (stored_identity, identity) != 0)
+    goto invalid_record;
+
+  device_types = g_key_file_get_uint64 (key_file,
+                                        GRANT_GROUP,
+                                        "device-types",
+                                        &local_error);
+  if (local_error || device_types > G_MAXUINT32)
+    goto invalid_record;
+
+  clipboard_enabled = g_key_file_get_boolean (key_file,
+                                              GRANT_GROUP,
+                                              "clipboard-enabled",
+                                              &local_error);
+  if (local_error)
+    goto invalid_record;
+
+  stream_text = g_key_file_get_string (key_file, GRANT_GROUP, "streams", NULL);
+  if (stream_text)
+    {
+      streams = g_variant_parse (G_VARIANT_TYPE (GNOBLIN_PORTAL_GRANT_STREAMS_TYPE),
+                                 stream_text,
+                                 NULL,
+                                 NULL,
+                                 &local_error);
+      if (!streams)
+        goto invalid_record;
+    }
+
+  if (!grant_is_valid (kind,
+                       stored_identity,
+                       device_types,
+                       clipboard_enabled,
+                       streams,
+                       &local_error))
+    goto invalid_record;
+
+  grant->identity = g_steal_pointer (&stored_identity);
+  grant->device_types = device_types;
+  grant->clipboard_enabled = clipboard_enabled;
+  grant->streams = g_steal_pointer (&streams);
+  return TRUE;
+
+invalid_record:
+  g_set_error (error,
+               G_IO_ERROR,
+               G_IO_ERROR_INVALID_DATA,
+               "Invalid %s portal grant for %s: %s",
+               grant_kind_name (kind),
+               identity,
+               local_error ? local_error->message : "record does not match its lookup key");
+  return FALSE;
+}
diff --git a/src/gnoblin-portal-grants.h b/src/gnoblin-portal-grants.h
new file mode 100644
index 0000000..e625047
--- /dev/null
+++ b/src/gnoblin-portal-grants.h
@@ -0,0 +1,59 @@
+/*
+ * SPDX-License-Identifier: LGPL-2.1-or-later
+ */
+
+#pragma once
+
+#include <gio/gio.h>
+#include <stdint.h>
+
+#define GNOBLIN_PORTAL_GRANT_STREAMS_TYPE "a(uuv)"
+
+typedef enum
+{
+  GNOBLIN_PORTAL_GRANT_SCREEN_CAST,
+  GNOBLIN_PORTAL_GRANT_REMOTE_DESKTOP,
+} GnoblinPortalGrantKind;
+
+typedef struct
+{
+  char *identity;
+  uint32_t device_types;
+  gboolean clipboard_enabled;
+  GVariant *streams;
+} GnoblinPortalGrant;
+
+void gnoblin_portal_grant_clear (GnoblinPortalGrant *grant);
+G_DEFINE_AUTO_CLEANUP_CLEAR_FUNC (GnoblinPortalGrant, gnoblin_portal_grant_clear)
+
+/*
+ * Verify that backend_sender owns org.freedesktop.portal.Desktop, recover the
+ * original caller from request_handle, and return a namespaced identity. The
+ * result is "app-id:<id>" when the trusted portal supplied an app id, or
+ * "host-exe:<canonical-path>" for a live unsandboxed caller. Any failed check
+ * returns NULL so callers retain one-shot consent and never persist a grant.
+ */
+char *gnoblin_portal_requester_identity (GDBusConnection *connection,
+                                         const char      *backend_sender,
+                                         const char      *app_id,
+                                         const char      *request_handle);
+
+/* Return the readable part of a verified namespaced identity. */
+const char *gnoblin_portal_identity_name (const char *identity);
+
+/*
+ * Load or store one portal-scoped grant. A record is keyed by a digest of its
+ * namespaced identity, and the stored identity and portal kind are validated
+ * again on load. A missing record returns FALSE without setting error.
+ */
+gboolean gnoblin_portal_grant_load (GnoblinPortalGrantKind  kind,
+                                    const char              *identity,
+                                    GnoblinPortalGrant      *grant,
+                                    GError                 **error);
+
+gboolean gnoblin_portal_grant_store (GnoblinPortalGrantKind  kind,
+                                     const char              *identity,
+                                     uint32_t                 device_types,
+                                     gboolean                 clipboard_enabled,
+                                     GVariant                *streams,
+                                     GError                 **error);
