-/* gnoblin: macOS-style per-app persistent ScreenCast / RemoteDesktop grants.
- *
- * Apps that round-trip a restore_token already skip the consent dialog. These
- * helpers add a gnoblin-owned per-app grant store so that apps which do NOT
- * restore (e.g. rustdesk) can be granted once ("Always allow this app") and
- * then connect unattended on every subsequent session. Grants live as marker
- * files under $XDG_CONFIG_HOME/gnoblin/portal-grants/<grant_id>.
- *
- * Default behaviour is unchanged: with no stored grant the dialog is shown.
- * A grant is only ever created when the user explicitly ticks the checkbox and
- * approves the dialog. Nothing is granted unconditionally. */
-
-/* Return a stable, filesystem-safe grant id for the requesting app, or NULL if
- * one cannot be derived. Uses app_id when non-empty; otherwise derives it from
- * the D-Bus sender's executable basename (GetConnectionUnixProcessID ->
- * /proc/PID/exe) so unsandboxed apps with an empty app_id still get a stable
- * per-binary id. Caller frees with g_free(). */
-char *gnoblin_portal_grant_id (const char            *app_id,
-                               GDBusMethodInvocation *invocation);
-
-/* TRUE if the given grant_id has a stored grant. NULL/empty grant_id -> FALSE. */
-gboolean gnoblin_portal_app_granted (const char *grant_id);
-
-/* Persist a grant for grant_id (creating the store dir). No-op on NULL/empty. */
-void gnoblin_portal_store_grant (const char *grant_id);
