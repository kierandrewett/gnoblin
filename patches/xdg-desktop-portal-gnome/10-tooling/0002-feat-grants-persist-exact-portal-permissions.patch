new file mode 100644
index 0000000..1b38fd7
--- /dev/null
+++ b/src/test-gnoblin-portal-grants.c
@@ -0,0 +1,335 @@
+/*
+ * SPDX-License-Identifier: LGPL-2.1-or-later
+ */
+
+#include "config.h"
+
+#include <gio/gio.h>
+#include <glib/gstdio.h>
+
+#include "gnoblin-portal-grants.h"
+
+static GVariant *
+test_streams (const char *monitor)
+{
+  GVariantBuilder builder;
+
+  g_variant_builder_init (&builder,
+                          G_VARIANT_TYPE (GNOBLIN_PORTAL_GRANT_STREAMS_TYPE));
+  g_variant_builder_add (&builder,
+                         "(uuv)",
+                         0,
+                         1,
+                         g_variant_new_string (monitor));
+  return g_variant_ref_sink (g_variant_builder_end (&builder));
+}
+
+static GDBusConnection *
+connect_test_bus (GTestDBus *bus)
+{
+  g_autoptr(GError) error = NULL;
+  GDBusConnection *connection;
+
+  connection = g_dbus_connection_new_for_address_sync (
+    g_test_dbus_get_bus_address (bus),
+    G_DBUS_CONNECTION_FLAGS_AUTHENTICATION_CLIENT |
+      G_DBUS_CONNECTION_FLAGS_MESSAGE_BUS_CONNECTION,
+    NULL,
+    NULL,
+    &error);
+  g_assert_no_error (error);
+  return connection;
+}
+
+static void
+own_portal_name (GDBusConnection *connection)
+{
+  g_autoptr(GError) error = NULL;
+  g_autoptr(GVariant) reply = NULL;
+  guint32 result;
+
+  reply = g_dbus_connection_call_sync (connection,
+                                       "org.freedesktop.DBus",
+                                       "/org/freedesktop/DBus",
+                                       "org.freedesktop.DBus",
+                                       "RequestName",
+                                       g_variant_new ("(su)",
+                                                      "org.freedesktop.portal.Desktop",
+                                                      0),
+                                       G_VARIANT_TYPE ("(u)"),
+                                       G_DBUS_CALL_FLAGS_NONE,
+                                       2000,
+                                       NULL,
+                                       &error);
+  g_assert_no_error (error);
+  g_variant_get (reply, "(u)", &result);
+  g_assert_cmpuint (result, ==, 1);
+}
+
+static char *
+request_handle_for_sender (const char *sender)
+{
+  g_autofree char *component = g_strdup (sender + 1);
+
+  for (char *p = component; *p; p++)
+    {
+      if (*p == '.')
+        *p = '_';
+    }
+
+  return g_strdup_printf ("/org/freedesktop/portal/desktop/request/%s/test",
+                          component);
+}
+
+static void
+test_requester_identity_rejects_direct_backend_spoof (void)
+{
+  g_autoptr(GTestDBus) bus = g_test_dbus_new (G_TEST_DBUS_NONE);
+  g_autoptr(GDBusConnection) portal = NULL;
+  g_autoptr(GDBusConnection) attacker = NULL;
+  g_autofree char *request_handle = NULL;
+  g_autofree char *identity = NULL;
+  const char *portal_sender;
+  const char *attacker_sender;
+
+  g_test_dbus_up (bus);
+  portal = connect_test_bus (bus);
+  attacker = connect_test_bus (bus);
+  own_portal_name (portal);
+
+  portal_sender = g_dbus_connection_get_unique_name (portal);
+  attacker_sender = g_dbus_connection_get_unique_name (attacker);
+  request_handle = request_handle_for_sender (attacker_sender);
+
+  identity = gnoblin_portal_requester_identity (portal,
+                                                 portal_sender,
+                                                 "org.example.Trusted",
+                                                 request_handle);
+  g_assert_cmpstr (identity, ==, "app-id:org.example.Trusted");
+
+  g_clear_pointer (&identity, g_free);
+  identity = gnoblin_portal_requester_identity (portal,
+                                                 attacker_sender,
+                                                 "org.example.Spoofed",
+                                                 request_handle);
+  g_assert_null (identity);
+
+  identity = gnoblin_portal_requester_identity (portal,
+                                                 portal_sender,
+                                                 "org.example.Trusted",
+                                                 "/org/freedesktop/portal/desktop/request/spoof/test");
+  g_assert_null (identity);
+
+  g_dbus_connection_close_sync (attacker, NULL, NULL);
+  g_dbus_connection_close_sync (portal, NULL, NULL);
+  g_test_dbus_down (bus);
+}
+
+static void
+test_requester_identity_resolves_host_executable (void)
+{
+  g_autoptr(GTestDBus) bus = g_test_dbus_new (G_TEST_DBUS_NONE);
+  g_autoptr(GDBusConnection) portal = NULL;
+  g_autoptr(GDBusConnection) caller = NULL;
+  g_autofree char *request_handle = NULL;
+  g_autofree char *identity = NULL;
+
+  g_test_dbus_up (bus);
+  portal = connect_test_bus (bus);
+  caller = connect_test_bus (bus);
+  own_portal_name (portal);
+  request_handle = request_handle_for_sender (
+    g_dbus_connection_get_unique_name (caller));
+
+  identity = gnoblin_portal_requester_identity (
+    portal,
+    g_dbus_connection_get_unique_name (portal),
+    "",
+    request_handle);
+  g_assert_nonnull (identity);
+  g_assert_true (g_str_has_prefix (identity, "host-exe:/"));
+
+  g_dbus_connection_close_sync (caller, NULL, NULL);
+  g_dbus_connection_close_sync (portal, NULL, NULL);
+  g_test_dbus_down (bus);
+}
+
+static void
+test_grants_are_scoped_and_round_trip_exact_values (void)
+{
+  g_autoptr(GVariant) streams = test_streams ("monitor-A");
+  g_auto(GnoblinPortalGrant) grant = { 0 };
+  g_autoptr(GError) error = NULL;
+  const char *identity = "app-id:org.example.App";
+
+  g_assert_true (gnoblin_portal_grant_store (
+    GNOBLIN_PORTAL_GRANT_REMOTE_DESKTOP,
+    identity,
+    3,
+    TRUE,
+    streams,
+    &error));
+  g_assert_no_error (error);
+
+  g_assert_true (gnoblin_portal_grant_load (
+    GNOBLIN_PORTAL_GRANT_REMOTE_DESKTOP,
+    identity,
+    &grant,
+    &error));
+  g_assert_no_error (error);
+  g_assert_cmpstr (grant.identity, ==, identity);
+  g_assert_cmpuint (grant.device_types, ==, 3);
+  g_assert_true (grant.clipboard_enabled);
+  g_assert_true (g_variant_equal (grant.streams, streams));
+
+  gnoblin_portal_grant_clear (&grant);
+  g_assert_false (gnoblin_portal_grant_load (
+    GNOBLIN_PORTAL_GRANT_SCREEN_CAST,
+    identity,
+    &grant,
+    &error));
+  g_assert_no_error (error);
+}
+
+static void
+test_grant_validation_rejects_invalid_or_empty_grants (void)
+{
+  g_autoptr(GVariant) monitor_streams = test_streams ("monitor-A");
+  g_autoptr(GVariant) window_streams = NULL;
+  g_autoptr(GError) error = NULL;
+  GVariantBuilder builder;
+
+  g_assert_false (gnoblin_portal_grant_store (
+    GNOBLIN_PORTAL_GRANT_SCREEN_CAST,
+    "app-id:org.example.App",
+    0,
+    FALSE,
+    NULL,
+    &error));
+  g_assert_error (error, G_IO_ERROR, G_IO_ERROR_INVALID_DATA);
+  g_clear_error (&error);
+
+  g_assert_false (gnoblin_portal_grant_store (
+    GNOBLIN_PORTAL_GRANT_REMOTE_DESKTOP,
+    "app-id:org.example.App",
+    0,
+    FALSE,
+    NULL,
+    &error));
+  g_assert_error (error, G_IO_ERROR, G_IO_ERROR_INVALID_DATA);
+  g_clear_error (&error);
+
+  g_assert_false (gnoblin_portal_grant_store (
+    GNOBLIN_PORTAL_GRANT_SCREEN_CAST,
+    "unscoped-identity",
+    0,
+    FALSE,
+    monitor_streams,
+    &error));
+  g_assert_error (error, G_IO_ERROR, G_IO_ERROR_INVALID_ARGUMENT);
+  g_clear_error (&error);
+
+  g_variant_builder_init (&builder,
+                          G_VARIANT_TYPE (GNOBLIN_PORTAL_GRANT_STREAMS_TYPE));
+  g_variant_builder_add (&builder,
+                         "(uuv)",
+                         0,
+                         2,
+                         g_variant_new_string ("window-title"));
+  window_streams = g_variant_ref_sink (g_variant_builder_end (&builder));
+  g_assert_false (gnoblin_portal_grant_store (
+    GNOBLIN_PORTAL_GRANT_SCREEN_CAST,
+    "app-id:org.example.App",
+    0,
+    FALSE,
+    window_streams,
+    &error));
+  g_assert_error (error, G_IO_ERROR, G_IO_ERROR_INVALID_DATA);
+}
+
+static void
+test_grant_digest_does_not_collapse_identity_characters (void)
+{
+  g_autoptr(GVariant) streams = test_streams ("monitor-A");
+  g_autoptr(GError) error = NULL;
+  g_autofree char *directory = NULL;
+  g_autoptr(GDir) dir = NULL;
+  guint count = 0;
+
+  g_assert_true (gnoblin_portal_grant_store (
+    GNOBLIN_PORTAL_GRANT_SCREEN_CAST,
+    "host-exe:/a/b",
+    0,
+    FALSE,
+    streams,
+    &error));
+  g_assert_no_error (error);
+  g_assert_true (gnoblin_portal_grant_store (
+    GNOBLIN_PORTAL_GRANT_SCREEN_CAST,
+    "host-exe:/a?b",
+    0,
+    FALSE,
+    streams,
+    &error));
+  g_assert_no_error (error);
+
+  directory = g_build_filename (g_get_user_data_dir (),
+                                "gnoblin",
+                                "portal-grants",
+                                "screen-cast",
+                                NULL);
+  dir = g_dir_open (directory, 0, &error);
+  g_assert_no_error (error);
+  while (g_dir_read_name (dir))
+    count++;
+  g_assert_cmpuint (count, ==, 2);
+}
+
+static void
+remove_tree (const char *path)
+{
+  g_autoptr(GDir) dir = NULL;
+  const char *name;
+
+  dir = g_dir_open (path, 0, NULL);
+  if (!dir)
+    {
+      g_remove (path);
+      return;
+    }
+
+  while ((name = g_dir_read_name (dir)))
+    {
+      g_autofree char *child = g_build_filename (path, name, NULL);
+
+      remove_tree (child);
+    }
+
+  g_rmdir (path);
+}
+
+int
+main (int argc, char **argv)
+{
+  g_autofree char *data_home = g_dir_make_tmp ("gnoblin-grants-XXXXXX", NULL);
+  int result;
+
+  g_assert_nonnull (data_home);
+  g_setenv ("XDG_DATA_HOME", data_home, TRUE);
+  g_test_init (&argc, &argv, NULL);
+
+  g_test_add_func ("/gnoblin/grants/direct-backend-spoof",
+                   test_requester_identity_rejects_direct_backend_spoof);
+  g_test_add_func ("/gnoblin/grants/host-executable",
+                   test_requester_identity_resolves_host_executable);
+  g_test_add_func ("/gnoblin/grants/scoped-round-trip",
+                   test_grants_are_scoped_and_round_trip_exact_values);
+  g_test_add_func ("/gnoblin/grants/invalid-or-empty",
+                   test_grant_validation_rejects_invalid_or_empty_grants);
+  g_test_add_func ("/gnoblin/grants/digest-collision",
+                   test_grant_digest_does_not_collapse_identity_characters);
+
+  result = g_test_run ();
+  remove_tree (data_home);
+  return result;
+}
