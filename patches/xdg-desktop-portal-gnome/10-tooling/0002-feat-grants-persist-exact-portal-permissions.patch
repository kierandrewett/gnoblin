diff --git a/src/remotedesktop.c b/src/remotedesktop.c
index 2a415c9..22ae17b 100644
--- a/src/remotedesktop.c
+++ b/src/remotedesktop.c
@@ -31,6 +31,7 @@
 #include "remotedesktopdialog.h"
 #include "screencastdialog.h"
 #include "gnomescreencast.h"
+#include "gnoblin-portal-grants.h"
 #include "request.h"
