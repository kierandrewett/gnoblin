From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Fri, 3 Jul 2026 02:46:39 +0100
Subject: [PATCH] tooling: opt-in unattended ScreenCast/RemoteDesktop
 auto-grant

Add a gnoblin-only, opt-in bypass of the ScreenCast source-picker and
RemoteDesktop consent dialogs so tools like rustdesk can connect without
a manual approval on every session.

Gated on gnoblin_portal_autogrant_enabled(): the env var
GNOBLIN_PORTAL_AUTOGRANT=1 (or true/yes) or the marker file
$XDG_CONFIG_HOME/gnoblin/portal-autogrant. When unset, behaviour is
identical to stock (the dialog is shown). Never grants unconditionally.

When enabled, handle_start() skips create_*_dialog() and completes the
request directly: ScreenCast selects every monitor (or the first when
multiple==FALSE); RemoteDesktop grants the already-selected device types,
selects every monitor when screen cast was requested, mirrors the
clipboard request, and allows persistence. The restore_token fast path
is untouched.
---
 src/remotedesktop.c | 46 +++++++++++++++++++++++++++++++
 src/screencast.c    | 66 +++++++++++++++++++++++++++++++++++++++++++++
 src/screencast.h    |  7 +++++
 src/utils.c         | 18 +++++++++++++
 src/utils.h         |  9 +++++++
 5 files changed, 146 insertions(+)

diff --git a/src/remotedesktop.c b/src/remotedesktop.c
index ad466a3..dbc167f 100644
--- a/src/remotedesktop.c
+++ b/src/remotedesktop.c
@@ -820,6 +820,52 @@ handle_start (XdpImplRemoteDesktop *object,
     {
       RemoteDesktopDialogHandle *dialog_handle;
 
+      /* gnoblin: opt-in unattended remote desktop. When the user has explicitly
+       * enabled it, skip the consent dialog and grant the requested devices
+       * (and, if screen cast was selected, every monitor). */
+      if (gnoblin_portal_autogrant_enabled ())
+        {
+          g_autoptr(GPtrArray) streams = NULL;
+          g_autoptr(GError) error = NULL;
+          gboolean clipboard_enabled;
+
+          g_debug ("gnoblin: auto-granting remote desktop (GNOBLIN_PORTAL_AUTOGRANT)");
+
+          if (remote_desktop_session->select.screen_cast_enable)
+            {
+              streams = screen_cast_select_all_monitors (
+                &remote_desktop_session->select.screen_cast);
+              if (!streams)
+                {
+                  g_warning ("gnoblin: auto-grant remote desktop failed: "
+                             "no shareable monitor");
+                  cancel_start_session (remote_desktop_session, 2);
+                  if (request->exported)
+                    request_unexport (request);
+                  return TRUE;
+                }
+            }
+
+          clipboard_enabled =
+            remote_desktop_session->clipboard.clipboard_requested;
+
+          if (!start_session (remote_desktop_session,
+                              remote_desktop_session->select.device_types,
+                              streams,
+                              clipboard_enabled,
+                              TRUE,
+                              &error))
+            {
+              g_warning ("gnoblin: auto-grant remote desktop failed: %s",
+                         error ? error->message : "unknown error");
+              cancel_start_session (remote_desktop_session, 2);
+            }
+
+          if (request->exported)
+            request_unexport (request);
+          return TRUE;
+        }
+
       dialog_handle = create_remote_desktop_dialog (remote_desktop_session,
                                                     invocation,
                                                     request,
diff --git a/src/screencast.c b/src/screencast.c
index 832a455..1da9d8f 100644
--- a/src/screencast.c
+++ b/src/screencast.c
@@ -593,6 +593,47 @@ restore_screen_cast_streams (GVariantIter        *streams_iter,
   return streams->len > 0 ? g_steal_pointer (&streams) : NULL;
 }
 
+GPtrArray *
+screen_cast_select_all_monitors (ScreenCastSelection *selection)
+{
+  DisplayStateTracker *display_state_tracker = display_state_tracker_get ();
+  g_autoptr(GPtrArray) streams = NULL;
+  uint32_t id = 0;
+  GList *l;
+
+  if (!selection->source_types.monitor)
+    return NULL;
+
+  streams =
+    g_ptr_array_new_with_free_func ((GDestroyNotify) screen_cast_stream_info_free);
+
+  for (l = display_state_tracker_get_logical_monitors (display_state_tracker);
+       l;
+       l = l->next)
+    {
+      LogicalMonitor *logical_monitor = l->data;
+      GList *monitors = logical_monitor_get_monitors (logical_monitor);
+      ScreenCastStreamInfo *info;
+
+      if (!monitors)
+        continue;
+
+      info = g_new0 (ScreenCastStreamInfo, 1);
+      info->type = SCREEN_CAST_SOURCE_TYPE_MONITOR;
+      info->data.monitor = monitor_dup ((Monitor *) monitors->data);
+      info->id = id++;
+      g_ptr_array_add (streams, info);
+
+      if (!selection->multiple)
+        break;
+    }
+
+  if (streams->len == 0)
+    return NULL;
+
+  return g_steal_pointer (&streams);
+}
+
 static gboolean
 restore_stream_from_data (ScreenCastSession *screen_cast_session)
 {
@@ -668,6 +709,31 @@ handle_start (XdpImplScreenCast     *object,
     {
       ScreenCastDialogHandle *dialog_handle;
 
+      /* gnoblin: opt-in unattended screen-share. When the user has explicitly
+       * enabled it, skip the source-picker dialog and grant every monitor. */
+      if (gnoblin_portal_autogrant_enabled ())
+        {
+          g_autoptr(GPtrArray) streams = NULL;
+          g_autoptr(GError) error = NULL;
+
+          g_debug ("gnoblin: auto-granting screen cast (GNOBLIN_PORTAL_AUTOGRANT)");
+
+          streams = screen_cast_select_all_monitors (&screen_cast_session->select);
+          if (streams && start_session (screen_cast_session, streams, &error))
+            {
+              if (request->exported)
+                request_unexport (request);
+              return TRUE;
+            }
+
+          g_warning ("gnoblin: auto-grant screen cast failed: %s",
+                     error ? error->message : "no shareable monitor");
+          cancel_start_session (screen_cast_session, 2);
+          if (request->exported)
+            request_unexport (request);
+          return TRUE;
+        }
+
       dialog_handle = create_screen_cast_dialog (screen_cast_session,
                                                  invocation,
                                                  request,
diff --git a/src/screencast.h b/src/screencast.h
index ae2beec..321d2d8 100644
--- a/src/screencast.h
+++ b/src/screencast.h
@@ -84,3 +84,10 @@ void serialize_screen_cast_streams_as_restore_data (GPtrArray       *streams,
 
 GPtrArray * restore_screen_cast_streams (GVariantIter *streams_iter,
                                          ScreenCastSelection *screen_cast_selection);
+
+/* gnoblin: build the stream list the consent dialog would produce if the user
+ * accepted with every monitor ticked. Used by the opt-in auto-grant path.
+ * Returns NULL if monitors are not among the requested source types or no
+ * monitor is available. When selection->multiple is FALSE only the first
+ * logical monitor is returned (matching the dialog's single-selection rule). */
+GPtrArray * screen_cast_select_all_monitors (ScreenCastSelection *selection);
diff --git a/src/utils.c b/src/utils.c
index 5e0485c..467d320 100644
--- a/src/utils.c
+++ b/src/utils.c
@@ -122,3 +122,21 @@ str_distance (const char *a,
 
   return v1[b_char_len];
 }
+
+gboolean
+gnoblin_portal_autogrant_enabled (void)
+{
+  const char *env;
+  g_autofree char *flag_path = NULL;
+
+  env = g_getenv ("GNOBLIN_PORTAL_AUTOGRANT");
+  if (env != NULL &&
+      (g_strcmp0 (env, "1") == 0 ||
+       g_ascii_strcasecmp (env, "true") == 0 ||
+       g_ascii_strcasecmp (env, "yes") == 0))
+    return TRUE;
+
+  flag_path = g_build_filename (g_get_user_config_dir (),
+                                "gnoblin", "portal-autogrant", NULL);
+  return g_file_test (flag_path, G_FILE_TEST_EXISTS);
+}
diff --git a/src/utils.h b/src/utils.h
index 3b73d68..5d3d8ce 100644
--- a/src/utils.h
+++ b/src/utils.h
@@ -46,3 +46,12 @@ GQuark  xdg_desktop_portal_error_quark (void);
 
 glong str_distance (const char *a,
                     const char *b);
+
+/* gnoblin: opt-in unattended screen-share / remote-desktop.
+ *
+ * Returns TRUE only when the user has explicitly opted in, either via the
+ * GNOBLIN_PORTAL_AUTOGRANT environment variable (1/true/yes) or by creating
+ * the marker file $XDG_CONFIG_HOME/gnoblin/portal-autogrant. When TRUE the
+ * ScreenCast / RemoteDesktop backends skip the consent dialog and grant the
+ * request automatically. Default (flag unset) behaviour is unchanged. */
+gboolean gnoblin_portal_autogrant_enabled (void);
