From 61c667b748e75d88ee0b04383661449c886bb412 Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Tue, 30 Jun 2026 19:20:39 +0100
Subject: [PATCH] Add tabular figure text property

---
 internal/compiler/builtins.slint             | 2 ++
 internal/compiler/passes/binding_analysis.rs | 4 ++++
 internal/core/graphics.rs                    | 2 ++
 internal/core/item_rendering.rs              | 1 +
 internal/core/items.rs                       | 2 ++
 internal/core/items/text.rs                  | 7 +++++++
 internal/core/textlayout/sharedparley.rs     | 5 +++++
 7 files changed, 23 insertions(+)

diff --git a/internal/compiler/builtins.slint b/internal/compiler/builtins.slint
index 71809271e..5dd8eaaea 100644
--- a/internal/compiler/builtins.slint
+++ b/internal/compiler/builtins.slint
@@ -109,6 +109,7 @@ component SimpleText inherits Empty {
 component ComplexText inherits SimpleText {
     in property <string> font-family;
     in property <bool> font-italic;
+    in property <bool> tabular;
     in property <TextOverflow> overflow;
     in property <TextWrap> wrap;
     in property <length> letter-spacing;
@@ -363,6 +364,7 @@ export component TextInput {
     in property <string> font-family;
     in property <length> font-size;
     in property <bool> font-italic;
+    in property <bool> tabular;
     in property <int> font-weight;
     in property <brush> color; // StyleMetrics.default-text-color  set in apply_default_properties_from_style
     in property <color> selection-foreground-color; // StyleMetrics.selection-foreground set in apply_default_properties_from_style
diff --git a/internal/compiler/passes/binding_analysis.rs b/internal/compiler/passes/binding_analysis.rs
index feddcf1f8..1f6a6ffba 100644
--- a/internal/compiler/passes/binding_analysis.rs
+++ b/internal/compiler/passes/binding_analysis.rs
@@ -737,6 +737,10 @@ fn recurse_expression(
                         &NamedReference::new(&item, SmolStr::new_static("font-italic")).into(),
                         ReadType::NativeRead,
                     );
+                    vis(
+                        &NamedReference::new(&item, SmolStr::new_static("tabular")).into(),
+                        ReadType::NativeRead,
+                    );
                 }
             }
             BuiltinFunction::GetWindowDefaultFontSize => {
diff --git a/internal/core/graphics.rs b/internal/core/graphics.rs
index 61c031255..fb4b71c42 100644
--- a/internal/core/graphics.rs
+++ b/internal/core/graphics.rs
@@ -100,6 +100,8 @@ pub struct FontRequest {
     pub letter_spacing: Option<LogicalLength>,
     /// Whether to select an italic face of the font family.
     pub italic: bool,
+    /// Whether to enable tabular figures through the OpenType `tnum` feature.
+    pub tabular: bool,
 }
 
 #[cfg(feature = "shared-fontique")]
diff --git a/internal/core/item_rendering.rs b/internal/core/item_rendering.rs
index 41b13c3a1..3bc4f94f6 100644
--- a/internal/core/item_rendering.rs
+++ b/internal/core/item_rendering.rs
@@ -387,6 +387,7 @@ fn font_request(self: Pin<&Self>, self_rc: &crate::items::ItemRc) -> FontRequest
             LogicalLength::default(),
             LogicalLength::default(),
             false,
+            false,
         )
     }
 }
diff --git a/internal/core/items.rs b/internal/core/items.rs
index 6161eed59..764d297ae 100644
--- a/internal/core/items.rs
+++ b/internal/core/items.rs
@@ -1428,6 +1428,7 @@ pub fn resolved_font_request(
         local_font_size: LogicalLength,
         local_letter_spacing: LogicalLength,
         local_italic: bool,
+        local_tabular: bool,
     ) -> FontRequest {
         let Some(window_item_rc) = next_window_item(self_rc) else {
             return FontRequest::default();
@@ -1466,6 +1467,7 @@ pub fn resolved_font_request(
             },
             letter_spacing: Some(local_letter_spacing),
             italic: local_italic,
+            tabular: local_tabular,
         }
     }
 
diff --git a/internal/core/items/text.rs b/internal/core/items/text.rs
index 393b44c77..bff87fdc5 100644
--- a/internal/core/items/text.rs
+++ b/internal/core/items/text.rs
@@ -53,6 +53,7 @@ pub struct ComplexText {
 
     pub font_family: Property<SharedString>,
     pub font_italic: Property<bool>,
+    pub tabular: Property<bool>,
     pub wrap: Property<TextWrap>,
     pub overflow: Property<TextOverflow>,
     pub letter_spacing: Property<LogicalLength>,
@@ -171,6 +172,7 @@ fn font_request(self: Pin<&Self>, self_rc: &crate::items::ItemRc) -> FontRequest
             self.font_size(),
             self.letter_spacing(),
             self.font_italic(),
+            self.tabular(),
         )
     }
 }
@@ -394,6 +396,7 @@ fn font_request(self: Pin<&Self>, self_rc: &crate::items::ItemRc) -> FontRequest
             self.default_font_size(),
             Default::default(),
             Default::default(),
+            Default::default(),
         )
     }
 }
@@ -577,6 +580,7 @@ fn font_request(self: Pin<&Self>, self_rc: &crate::items::ItemRc) -> FontRequest
             self.font_size(),
             LogicalLength::default(),
             false,
+            false,
         )
     }
 }
@@ -734,6 +738,7 @@ pub struct TextInput {
     pub font_size: Property<LogicalLength>,
     pub font_weight: Property<i32>,
     pub font_italic: Property<bool>,
+    pub tabular: Property<bool>,
     pub color: Property<Brush>,
     pub selection_foreground_color: Property<Color>,
     pub selection_background_color: Property<Color>,
@@ -1299,6 +1304,7 @@ fn font_request(self: Pin<&Self>, self_rc: &crate::items::ItemRc) -> FontRequest
             self.font_size(),
             self.letter_spacing(),
             self.font_italic(),
+            self.tabular(),
         )
     }
 }
@@ -1995,6 +2001,7 @@ pub fn font_request(self: Pin<&Self>, self_rc: &ItemRc) -> FontRequest {
             self.font_size(),
             self.letter_spacing(),
             self.font_italic(),
+            self.tabular(),
         )
     }
 
diff --git a/internal/core/textlayout/sharedparley.rs b/internal/core/textlayout/sharedparley.rs
index dbe224c1b..8dc1f570c 100644
--- a/internal/core/textlayout/sharedparley.rs
+++ b/internal/core/textlayout/sharedparley.rs
@@ -231,6 +231,11 @@ fn ranged_builder<'a>(
             } else {
                 parley::style::FontStyle::Normal
             }));
+            if font_request.tabular {
+                builder.push_default(parley::StyleProperty::FontFeatures(
+                    parley::style::FontFeatures::from(r#""tnum" 1"#),
+                ));
+            }
         }
         builder.push_default(parley::StyleProperty::FontSize(self.pixel_size.get()));
         builder.push_default(parley::StyleProperty::WordBreak(match self.text_wrap {
