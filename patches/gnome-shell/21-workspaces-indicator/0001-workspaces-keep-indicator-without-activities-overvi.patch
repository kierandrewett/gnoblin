From 7f9348f707cdd150232d9bf321ec02ee8616252d Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Wed, 17 Jun 2026 15:55:00 +0100
Subject: [PATCH] workspaces: keep indicator without activities overview

Keep the GNOME workspace indicator in the panel even though the overview is
disabled. The Activities button remains a workspace indicator and scroll target,
but button/key/DND activation must not toggle the overview when the session mode
has no overview.
---
 js/ui/panel.js | 11 +++++++++--
 1 file changed, 9 insertions(+), 2 deletions(-)

diff --git a/js/ui/panel.js b/js/ui/panel.js
index 4f456e1..815b977 100644
--- a/js/ui/panel.js
+++ b/js/ui/panel.js
@@ -236,7 +236,8 @@ class ActivitiesButton extends PanelMenu.Button {
     vfunc_event(event) {
         if (event.type() === Clutter.EventType.TOUCH_END ||
             event.type() === Clutter.EventType.BUTTON_RELEASE) {
-            if (Main.overview.shouldToggleByCornerOrButton())
+            if (Main.sessionMode.hasOverview &&
+                Main.overview.shouldToggleByCornerOrButton())
                 Main.overview.toggle();
         }
 
@@ -246,7 +247,8 @@ class ActivitiesButton extends PanelMenu.Button {
     vfunc_key_release_event(event) {
         let symbol = event.get_key_symbol();
         if (symbol === Clutter.KEY_Return || symbol === Clutter.KEY_space) {
-            if (Main.overview.shouldToggleByCornerOrButton()) {
+            if (Main.sessionMode.hasOverview &&
+                Main.overview.shouldToggleByCornerOrButton()) {
                 Main.overview.toggle();
                 return Clutter.EVENT_STOP;
             }
@@ -260,6 +262,11 @@ class ActivitiesButton extends PanelMenu.Button {
         let [x, y] = global.get_pointer();
         let pickedActor = global.stage.get_actor_at_pos(Clutter.PickMode.REACTIVE, x, y);
 
+        if (!Main.sessionMode.hasOverview) {
+            this._xdndTimeOut = 0;
+            return GLib.SOURCE_REMOVE;
+        }
+
         if (pickedActor === this && Main.overview.shouldToggleByCornerOrButton())
             Main.overview.toggle();
 
-- 
