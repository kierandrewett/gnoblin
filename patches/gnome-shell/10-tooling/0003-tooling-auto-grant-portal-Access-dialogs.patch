From 85efc00f2f0c6587be3559b7120628c3c778e08a Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Tue, 16 Jun 2026 22:16:47 +0100
Subject: [PATCH] tooling: auto-grant portal Access dialogs

Auto-approve xdg-desktop-portal Access requests that would otherwise be
surfaced as an Allow/Deny modal, keeping the sender check intact so only
the legitimate portal frontend can drive the method.
---
 js/ui/accessDialog.js | 33 +++++++--------------------------
 1 file changed, 7 insertions(+), 26 deletions(-)

diff --git a/js/ui/accessDialog.js b/js/ui/accessDialog.js
index 259a7bb..3e5c203 100644
--- a/js/ui/accessDialog.js
+++ b/js/ui/accessDialog.js
@@ -146,6 +146,12 @@ export class AccessDialogDBus {
     }
 
     async AccessDialogAsync(params, invocation) {
+        // gnoblin tooling: auto-grant every access request that comes
+        // through the portal Access interface. This
+        // covers any xdg-desktop-portal Access call that's normally
+        // surfaced as a "Allow / Deny" modal in the shell. Sender check
+        // is preserved so only the legitimate portal frontend / handover
+        // bridge can drive this method.
         try {
             await this._senderChecker.checkInvocation(invocation);
         } catch (e) {
@@ -153,31 +159,6 @@ export class AccessDialogDBus {
             return;
         }
 
-        if (this._accessDialog) {
-            invocation.return_error_literal(
-                Gio.DBusError,
-                Gio.DBusError.LIMITS_EXCEEDED,
-                'Already showing a system access dialog');
-            return;
-        }
-
-        let [handle, appId, parentWindow_, title, description, body, options] = params;
-        // We probably want to use parentWindow and global.display.focus_window
-        // for this check in the future
-        if (appId && `${appId}.desktop` !== this._windowTracker.focus_app.id) {
-            invocation.return_error_literal(
-                Gio.DBusError,
-                Gio.DBusError.ACCESS_DENIED,
-                'Only the focused app is allowed to show a system access dialog');
-            return;
-        }
-
-        let dialog = new AccessDialog(
-            invocation, handle, title, description, body, options);
-        dialog.open();
-
-        dialog.connect('closed', () => (this._accessDialog = null));
-
-        this._accessDialog = dialog;
+        invocation.return_value(new GLib.Variant('(ua{sv})', [0, {}]));
     }
 }
-- 
