From 6d2f587f6dd5e80406eb49de5504404c32ea665b Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Wed, 17 Jun 2026 01:45:39 +0100
Subject: [PATCH] native-topbar: hide stock panel chrome

---
 js/ui/layout.js | 3 ++-
 js/ui/panel.js  | 3 ++-
 2 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/js/ui/layout.js b/js/ui/layout.js
index 820f49f..7dc8136 100644
--- a/js/ui/layout.js
+++ b/js/ui/layout.js
@@ -280,7 +280,8 @@ export const LayoutManager = GObject.registerClass({
             orientation: Clutter.Orientation.VERTICAL,
         });
         this.addChrome(this.panelBox, {
-            affectsStruts: true,
+            affectsInputRegion: false,
+            affectsStruts: false,
             trackFullscreen: true,
         });
         this.panelBox.connect('notify::allocation',
diff --git a/js/ui/panel.js b/js/ui/panel.js
index 46b0567..c69f77f 100644
--- a/js/ui/panel.js
+++ b/js/ui/panel.js
@@ -432,7 +432,8 @@ class Panel extends St.Widget {
     _init() {
         super._init({
             name: 'panel',
-            reactive: true,
+            opacity: 0,
+            reactive: false,
         });
 
         this.set_offscreen_redirect(Clutter.OffscreenRedirect.ALWAYS);
-- 
2.53.0

