From acb7ac4bbc4ebb40a644ba28fda805763f1944e9 Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Fri, 3 Jul 2026 01:31:45 +0100
Subject: [PATCH] gnoblin-control: register the control component in the JS
 gresource

Adds js/ui/components/gnoblinControl.js (a gnoblin overlay file) to the shell's
JS resource bundle so gnome-shell can import it as a session-mode component. The
component itself is gnoblin overlay source (src/gnome-shell-overlay/); it is
enabled purely via the gnoblin session mode's components list. This one <file>
line is the only upstream edit.
---
 js/js-resources.gresource.xml | 1 +
 1 file changed, 1 insertion(+)

diff --git a/js/js-resources.gresource.xml b/js/js-resources.gresource.xml
index e5e6167..c3806c4 100644
--- a/js/js-resources.gresource.xml
+++ b/js/js-resources.gresource.xml
@@ -134,6 +134,7 @@
     <file>ui/components.js</file>
     <file>ui/components/automountManager.js</file>
     <file>ui/components/autorunManager.js</file>
+    <file>ui/components/gnoblinControl.js</file>
     <file>ui/components/keyring.js</file>
     <file>ui/components/networkAgent.js</file>
     <file>ui/components/polkitAgent.js</file>
-- 
2.53.0

