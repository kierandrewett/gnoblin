From 24801943e604c6839d23ad374dc041658772f4c5 Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Wed, 15 Jul 2026 12:46:36 +0100
Subject: [PATCH] portal: fix Access request close handler

GJS passes asynchronous D-Bus handlers the method parameters before the invocation, so use that order when validating the caller. Return from the void Close method after closing the dialog so the caller receives a completed D-Bus reply instead of timing out.
---
 js/ui/accessDialog.js | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/js/ui/accessDialog.js b/js/ui/accessDialog.js
index 259a7bb..470f329 100644
--- a/js/ui/accessDialog.js
+++ b/js/ui/accessDialog.js
@@ -100,7 +100,7 @@ class AccessDialog extends ModalDialog.ModalDialog {
         return true;
     }
 
-    CloseAsync(invocation, _params) {
+    CloseAsync(_params, invocation) {
         if (this._invocation.get_sender() !== invocation.get_sender()) {
             invocation.return_error_literal(
                 Gio.DBusError,
@@ -110,6 +110,7 @@ class AccessDialog extends ModalDialog.ModalDialog {
         }
 
         this._sendResponse(DialogResponse.CLOSED);
+        invocation.return_value(null);
     }
 
     _sendResponse(response) {
-- 
2.53.0

