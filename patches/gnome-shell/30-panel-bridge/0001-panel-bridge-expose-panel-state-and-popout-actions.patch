From 5e9e687fbc4012ad030b673606da86b0cb155b66 Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Wed, 17 Jun 2026 01:19:10 +0100
Subject: [PATCH] panel-bridge: expose panel state and popout actions

---
 data/dbus-interfaces/org.gnome.Shell.xml | 14 +++++++++++++
 js/ui/shellDBus.js                       | 25 ++++++++++++++++++++++++
 2 files changed, 39 insertions(+)

diff --git a/data/dbus-interfaces/org.gnome.Shell.xml b/data/dbus-interfaces/org.gnome.Shell.xml
index 7d14c16..db2be59 100644
--- a/data/dbus-interfaces/org.gnome.Shell.xml
+++ b/data/dbus-interfaces/org.gnome.Shell.xml
@@ -17,6 +17,20 @@
       <arg type="s" direction="in" name="id"/>
     </method>
     <method name="ShowApplications"/>
+    <method name="OpenPanelMenu">
+      <arg type="s" direction="in" name="name"/>
+      <arg type="b" direction="out" name="success"/>
+    </method>
+    <method name="TogglePanelMenu">
+      <arg type="s" direction="in" name="name"/>
+      <arg type="b" direction="out" name="success"/>
+    </method>
+    <method name="ClosePanelMenus">
+      <arg type="b" direction="out" name="success"/>
+    </method>
+    <method name="GetPanelState">
+      <arg type="s" direction="out" name="json"/>
+    </method>
     <method name="GrabAccelerator">
       <arg type="s" direction="in" name="accelerator"/>
       <arg type="u" direction="in" name="modeFlags"/>
diff --git a/js/ui/shellDBus.js b/js/ui/shellDBus.js
index 9b2ff24..a4e3b6a 100644
--- a/js/ui/shellDBus.js
+++ b/js/ui/shellDBus.js
@@ -8,6 +8,7 @@ import * as ExtensionDownloader from './extensionDownloader.js';
 import * as ExtensionUtils from '../misc/extensionUtils.js';
 import * as Main from './main.js';
 import * as Screenshot from './screenshot.js';
+import * as TopbarBridge from './gnoblin/topbarBridge.js';
 
 import {loadInterfaceXML} from '../misc/fileUtils.js';
 import {DBusSenderChecker} from '../misc/util.js';
@@ -201,6 +202,30 @@ export class GnomeShell {
         invocation.return_value(null);
     }
 
+    OpenPanelMenuAsync([name], invocation) {
+        invocation.return_value(GLib.Variant.new('(b)', [
+            TopbarBridge.openPanelMenu(Main.panel, name),
+        ]));
+    }
+
+    TogglePanelMenuAsync([name], invocation) {
+        invocation.return_value(GLib.Variant.new('(b)', [
+            TopbarBridge.togglePanelMenu(Main.panel, name),
+        ]));
+    }
+
+    ClosePanelMenusAsync(params, invocation) {
+        invocation.return_value(GLib.Variant.new('(b)', [
+            TopbarBridge.closePanelMenus(Main.panel),
+        ]));
+    }
+
+    GetPanelStateAsync(params, invocation) {
+        invocation.return_value(GLib.Variant.new('(s)', [
+            JSON.stringify(TopbarBridge.getPanelState(Main.panel)),
+        ]));
+    }
+
     async GrabAcceleratorAsync(params, invocation) {
         try {
             await this._senderChecker.checkInvocation(invocation);
-- 
2.53.0

