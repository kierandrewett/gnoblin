From 5bf74171a3b4dff7b60a09a7389b3f7cfd89b200 Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Wed, 17 Jun 2026 15:48:00 +0100
Subject: [PATCH] screencopy: wire wlr-screencopy into the build

Register the wlr-screencopy-unstable-v1 protocol and the
meta-wayland-screencopy sources in src/meson.build, and call
meta_wayland_init_screencopy() from meta_wayland_shell_init().

The implementation, header and protocol XML are gnoblin overlay files
(src/screencopy/, copied into src/wayland/ at build time), not part of
this patch.
---
 src/meson.build                    | 6 ++++++
 src/wayland/meta-wayland-surface.c | 2 ++
 2 files changed, 8 insertions(+)

diff --git a/src/meson.build b/src/meson.build
index 508c341..7e7bd65 100644
--- a/src/meson.build
+++ b/src/meson.build
@@ -654,6 +654,10 @@ if have_wayland
     'wayland/meta-wayland-private.h',
     'wayland/meta-wayland-region.c',
     'wayland/meta-wayland-region.h',
+    # gnoblin: wlr-screencopy-unstable-v1 (sources copied from the gnoblin
+    # overlay src/screencopy/ at build time)
+    'wayland/meta-wayland-screencopy.c',
+    'wayland/meta-wayland-screencopy.h',
     'wayland/meta-wayland-seat.c',
     'wayland/meta-wayland-seat.h',
     'wayland/meta-wayland-shell-surface.c',
@@ -1190,6 +1194,8 @@ if have_wayland
     ['xdg-foreign', 'unstable', 2, ],
     ['xdg-output', 'unstable', 1, ],
     ['xdg-shell', 'stable', ],
+    # gnoblin: vendored wlr-screencopy protocol (overlay src/wayland/protocol/)
+    ['wlr-screencopy-unstable-v1', 'private', ],
     ['xdg-system-bell', 'staging', 1, ],
     ['xdg-toplevel-drag', 'staging', 1, ],
     ['xdg-toplevel-tag', 'staging', 1, ],
diff --git a/src/wayland/meta-wayland-surface.c b/src/wayland/meta-wayland-surface.c
index f01e65f..40ce0dc 100644
--- a/src/wayland/meta-wayland-surface.c
+++ b/src/wayland/meta-wayland-surface.c
@@ -43,7 +43,8 @@
 #include "wayland/meta-wayland-outputs.h"
 #include "wayland/meta-wayland-presentation-time-private.h"
 #include "wayland/meta-wayland-private.h"
 #include "wayland/meta-wayland-region.h"
+#include "wayland/meta-wayland-screencopy.h"
 #include "wayland/meta-wayland-seat.h"
 #include "wayland/meta-wayland-subsurface.h"
 #include "wayland/meta-wayland-transaction.h"
@@ -1902,3 +1903,4 @@ meta_wayland_shell_init (MetaWaylandCompositor *compositor)
   meta_wayland_init_viewporter (compositor);
   meta_wayland_init_fractional_scale (compositor);
+  meta_wayland_init_screencopy (compositor);
 }
 
 void
-- 
2.53.0
