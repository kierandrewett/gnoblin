From 43f1e227483a3d8723a0c7f3813f4c66869c64b2 Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Mon, 22 Jun 2026 13:31:00 +0100
Subject: [PATCH] tests: wait for Wayland unit client teardown

Two Wayland unit tests destroyed MetaTestClient helpers and immediately let
the next placement test run. The helper process pipes being closed does not
guarantee that Mutter has unmapped and finalized the test windows yet.

When a centered 200x200 window from an earlier test was still showing, the
invalid-geometry test could legitimately cascade by
META_WINDOW_TITLEBAR_HEIGHT and place its window at x=270 instead of the
expected centered x=220. End the explicit resize drag and wait for the test
windows to disappear before moving on.
---
 src/tests/wayland-unit-tests.c | 24 +++++++++++++++++++++++-
 1 file changed, 23 insertions(+), 1 deletion(-)

diff --git a/src/tests/wayland-unit-tests.c b/src/tests/wayland-unit-tests.c
index 9834e13..613fc61 100644
--- a/src/tests/wayland-unit-tests.c
+++ b/src/tests/wayland-unit-tests.c
@@ -25,7 +25,9 @@
 #include "backends/native/meta-backend-native.h"
 #include "backends/native/meta-kms.h"
 #include "backends/native/meta-kms-device.h"
+#include "compositor/compositor-private.h"
 #include "compositor/meta-window-actor-private.h"
+#include "compositor/meta-window-drag.h"
 #include "core/display-private.h"
 #include "core/meta-workspace-manager-private.h"
 #include "core/window-private.h"
@@ -1927,6 +1929,7 @@ toplevel_focus_changes_remembers_size (void)
 {
   GSettings *settings;
   MetaWindow *window;
+  MetaWindow *window2;
   MetaWindowWayland *wl_window;
   MtkRectangle rect;
   MetaTestClient *test_client;
@@ -1953,6 +1956,8 @@ toplevel_focus_changes_remembers_size (void)
       g_assert_no_error (error);
       g_main_context_iteration (NULL, TRUE);
     }
+  g_object_add_weak_pointer (G_OBJECT (window), (gpointer *) &window);
+
   wl_window = META_WINDOW_WAYLAND (window);
   while (meta_window_is_hidden (window))
     g_main_context_iteration (NULL, TRUE);
@@ -1985,6 +1990,12 @@ toplevel_focus_changes_remembers_size (void)
 
   while (meta_window_appears_focused (window))
     g_main_context_iteration (NULL, TRUE);
+
+  window2 = meta_test_client_find_window (test_client, "2", &error);
+  g_assert_no_error (error);
+  g_assert_nonnull (window2);
+  g_object_add_weak_pointer (G_OBJECT (window2), (gpointer *) &window2);
+
   g_assert_true (meta_window_wayland_get_pending_serial (wl_window, &serial));
   pending_configuration =
     meta_window_wayland_peek_configuration (wl_window, serial);
@@ -1998,6 +2009,9 @@ toplevel_focus_changes_remembers_size (void)
   g_assert_cmpint (rect.width, ==, 200);
   g_assert_cmpint (rect.height, ==, 200);
   meta_test_client_destroy (test_client);
+
+  while (window || window2)
+    g_main_context_iteration (NULL, TRUE);
 }
 
 static void
@@ -2010,6 +2024,7 @@ toplevel_begin_interactive_resize (void)
   ClutterInputDevice *pointer;
   ClutterSprite *pointer_sprite;
   GSettings *settings;
+  MetaWindowDrag *window_drag;
   MetaWindow *window;
   MetaWindowWayland *wl_window;
   MtkRectangle rect;
@@ -2046,6 +2061,8 @@ toplevel_begin_interactive_resize (void)
       g_assert_no_error (error);
       g_main_context_iteration (NULL, TRUE);
     }
+  g_object_add_weak_pointer (G_OBJECT (window), (gpointer *) &window);
+
   wl_window = META_WINDOW_WAYLAND (window);
   while (meta_window_is_hidden (window))
     g_main_context_iteration (NULL, TRUE);
@@ -2098,9 +2115,17 @@ toplevel_begin_interactive_resize (void)
   g_assert_cmpint (rect.width, ==, 210);
   g_assert_cmpint (rect.height, ==, 200);
 
+  window_drag =
+    meta_compositor_get_current_window_drag (window->display->compositor);
+  g_assert_nonnull (window_drag);
+  g_assert_true (meta_window_drag_get_window (window_drag) == window);
+  meta_window_drag_end (window_drag);
 
   meta_test_client_destroy (test_client);
   g_clear_object (&virtual_pointer);
+
+  while (window)
+    g_main_context_iteration (NULL, TRUE);
 }
 
 static void
-- 
2.53.0

