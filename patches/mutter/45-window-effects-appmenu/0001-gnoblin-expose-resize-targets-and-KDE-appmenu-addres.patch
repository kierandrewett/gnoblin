+static void
+meta_window_get_maximize_target_rect (MetaWindow        *window,
+                                      MetaMaximizeFlags  directions,
+                                      MtkRectangle      *target_rect)
+{
+  MtkRectangle work_area;
+
+  meta_window_get_frame_rect (window, target_rect);
+
+  if (!window->monitor)
+    {
+      *target_rect = window->unconstrained_rect;
+      return;
+    }
+
+  meta_window_get_work_area_current_monitor (window, &work_area);
+
+  if (directions & META_MAXIMIZE_HORIZONTAL)
+    {
+      target_rect->x = work_area.x;
+      target_rect->width = work_area.width;
+    }
+
+  if (directions & META_MAXIMIZE_VERTICAL)
+    {
+      target_rect->y = work_area.y;
+      target_rect->height = work_area.height;
+    }
+
+  meta_window_maybe_apply_size_hints (window, target_rect);
+}
+
+static void
+meta_window_get_tile_target_rect (MetaWindow   *window,
+                                  MetaTileMode  tile_mode,
+                                  MtkRectangle *target_rect)
+{
+  if (tile_mode == META_TILE_MAXIMIZED)
+    meta_window_get_maximize_target_rect (window, META_MAXIMIZE_BOTH, target_rect);
+  else
+    {
+      meta_window_get_tile_area (window, tile_mode, target_rect);
+      meta_window_maybe_apply_size_hints (window, target_rect);
+    }
+}
+
