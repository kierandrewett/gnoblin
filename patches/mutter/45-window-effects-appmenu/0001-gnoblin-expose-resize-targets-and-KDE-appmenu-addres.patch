@@ -6911,2 +6969,28 @@ meta_window_get_gtk_menubar_object_path (MetaWindow *window)
 
+/**
+ * meta_window_get_kde_appmenu_service_name:
+ * @window: a #MetaWindow
+ *
+ * Returns the DBus service name exported through the KDE appmenu Wayland
+ * protocol, or %NULL if the window has not advertised one.
+ */
+const char *
+meta_window_get_kde_appmenu_service_name (MetaWindow *window)
+{
+  return window->kde_appmenu_service_name;
+}
+
+/**
+ * meta_window_get_kde_appmenu_object_path:
+ * @window: a #MetaWindow
+ *
+ * Returns the DBusMenu object path exported through the KDE appmenu Wayland
+ * protocol, or %NULL if the window has not advertised one.
+ */
+const char *
+meta_window_get_kde_appmenu_object_path (MetaWindow *window)
+{
+  return window->kde_appmenu_object_path;
+}
+
 /**
@@ -7515,2 +7599,16 @@ meta_window_set_gtk_dbus_properties (MetaWindow *window,
 
+void
+meta_window_set_kde_appmenu_dbus_properties (MetaWindow *window,
+                                             const char *service_name,
+                                             const char *object_path)
+{
+  g_free (window->kde_appmenu_service_name);
+  g_free (window->kde_appmenu_object_path);
+
+  window->kde_appmenu_service_name =
+    service_name && *service_name ? g_strdup (service_name) : NULL;
+  window->kde_appmenu_object_path =
+    object_path && *object_path ? g_strdup (object_path) : NULL;
+}
+
 static gboolean
