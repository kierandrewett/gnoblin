From 234a36dc2fc5a3f8e67454df713223bed765e0e0 Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Tue, 16 Jun 2026 23:00:47 +0100
Subject: [PATCH] layer-shell: wire wlr-layer-shell into the build

Register the wlr-layer-shell-unstable-v1 protocol and the
meta-wayland-layer-shell sources in src/meson.build, and call
meta_wayland_init_layer_shell() from meta_wayland_shell_init().

The implementation, header and protocol XML are gnoblin overlay files
(src/layer-shell/, copied into src/wayland/ at build time), not part of
this patch.
---
 src/meson.build                    | 6 ++++++
 src/wayland/meta-wayland-surface.c | 2 ++
 2 files changed, 8 insertions(+)

diff --git a/src/meson.build b/src/meson.build
index 508c341..a403ef1 100644
--- a/src/meson.build
+++ b/src/meson.build
@@ -641,6 +641,10 @@ if have_wayland
     'wayland/meta-wayland-fractional-scale.h',
     'wayland/meta-wayland-gtk-shell.c',
     'wayland/meta-wayland-gtk-shell.h',
+    # gnoblin: wlr-layer-shell-unstable-v1 (sources copied from the gnoblin
+    # overlay src/layer-shell/ at build time)
+    'wayland/meta-wayland-layer-shell.c',
+    'wayland/meta-wayland-layer-shell.h',
     'wayland/meta-wayland.h',
     'wayland/meta-wayland-idle-inhibit.c',
     'wayland/meta-wayland-idle-inhibit.h',
@@ -1166,6 +1170,8 @@ if have_wayland
     ['fractional-scale', 'staging', 1, ],
     ['fifo', 'staging', 1, ],
     ['gtk-shell', 'private', ],
+    # gnoblin: vendored wlr-layer-shell protocol (overlay src/wayland/protocol/)
+    ['wlr-layer-shell-unstable-v1', 'private', ],
     ['idle-inhibit', 'unstable', 1, ],
     ['keyboard-shortcuts-inhibit', 'unstable', 1, ],
     ['linux-dmabuf', 'stable', 1, ],
diff --git a/src/wayland/meta-wayland-surface.c b/src/wayland/meta-wayland-surface.c
index f01e65f..dac1683 100644
--- a/src/wayland/meta-wayland-surface.c
+++ b/src/wayland/meta-wayland-surface.c
@@ -41,6 +41,7 @@
 #include "wayland/meta-wayland-color-representation.h"
 #include "wayland/meta-wayland-fractional-scale.h"
 #include "wayland/meta-wayland-gtk-shell.h"
+#include "wayland/meta-wayland-layer-shell.h"
 #include "wayland/meta-wayland-outputs.h"
 #include "wayland/meta-wayland-presentation-time-private.h"
 #include "wayland/meta-wayland-private.h"
@@ -1898,6 +1899,7 @@ meta_wayland_shell_init (MetaWaylandCompositor *compositor)
 {
   meta_wayland_xdg_shell_init (compositor);
   meta_wayland_init_gtk_shell (compositor);
+  meta_wayland_init_layer_shell (compositor);
   meta_wayland_init_viewporter (compositor);
   meta_wayland_init_fractional_scale (compositor);
 }
-- 
