From 6c0c3b4fd45f7e3b812a119d9195ec3f3dbd7b7a Mon Sep 17 00:00:00 2001
From: kierandrewett <kieran@drewett.dev>
Date: Sun, 21 Jun 2026 04:05:00 +0100
Subject: [PATCH] layer-shell: emit frame callbacks for layer surfaces

Layer-shell surfaces can be visible and mapped in the nested devkit while not
passing Mutter's normal Wayland "primary stage view" predicate. A layer-shell
client (e.g. a Quickshell/waybar bar) waits for wl_surface.frame callbacks to
pace animations and future redraws; when those callbacks never fire, clients
stall after the first frame and stop draining input once their renderer
attempts another blocked swap.

Keep the existing primary-view path for normal windows, but allow layer-shell
surfaces to receive frame callbacks when their actor is mapped, effectively on
the updated stage view, and not obscured on that view.

The visible devkit can also have pending layer-shell frame callbacks without a
matching stage-view update. Add a 16 ms layer-shell fallback source so those
callbacks are still delivered at a display-like cadence instead of waiting for
unrelated pointer motion.
---
 src/wayland/meta-wayland.c | 84 ++++++++++++++++++++++++++++++++++++-
 1 file changed, 82 insertions(+), 2 deletions(-)

diff --git a/src/wayland/meta-wayland.c b/src/wayland/meta-wayland.c
index f2f3775..20a8b46 100644
--- a/src/wayland/meta-wayland.c
+++ b/src/wayland/meta-wayland.c
@@ -53,6 +53,7 @@
 #include "wayland/meta-wayland-idle-inhibit.h"
 #include "wayland/meta-wayland-inhibit-shortcuts-dialog.h"
 #include "wayland/meta-wayland-inhibit-shortcuts.h"
+#include "wayland/meta-wayland-layer-shell.h"
 #include "wayland/meta-wayland-legacy-xdg-foreign.h"
 #include "wayland/meta-wayland-linux-drm-syncobj.h"
 #include "wayland/meta-wayland-outputs.h"
@@ -99,6 +100,7 @@ typedef struct _MetaWaylandCompositorPrivate
 
   MetaWaylandFilterManager *filter_manager;
   GHashTable *frame_callback_sources;
+  guint layer_shell_frame_callback_source_id;
 } MetaWaylandCompositorPrivate;
 
 G_DEFINE_TYPE_WITH_PRIVATE (MetaWaylandCompositor, meta_wayland_compositor,
@@ -126,6 +128,25 @@ typedef struct
 static void meta_wayland_compositor_update_focus (MetaWaylandCompositor *compositor,
                                                   MetaWindow            *window);
 
+static gboolean
+surface_should_emit_frame_callbacks_for_stage_view (MetaWaylandSurface *surface,
+                                                    MetaSurfaceActor   *actor,
+                                                    ClutterStageView   *stage_view)
+{
+  if (meta_surface_actor_wayland_is_view_primary (actor, stage_view))
+    return TRUE;
+
+  if (!meta_wayland_surface_is_layer_shell (surface))
+    return FALSE;
+
+  return clutter_actor_is_mapped (CLUTTER_ACTOR (actor)) &&
+         clutter_actor_is_effectively_on_stage_view (CLUTTER_ACTOR (actor),
+                                                     stage_view) &&
+         !meta_surface_actor_is_obscured_on_stage_view (actor,
+                                                        stage_view,
+                                                        NULL);
+}
+
 static gboolean
 wayland_event_source_prepare (GSource *base,
                               int     *timeout)
@@ -202,8 +223,9 @@ emit_frame_callbacks_for_stage_view (MetaWaylandCompositor *compositor,
       if (!actor)
         continue;
 
-      if (!meta_surface_actor_wayland_is_view_primary (actor,
-                                                       stage_view))
+      if (!surface_should_emit_frame_callbacks_for_stage_view (surface,
+                                                               actor,
+                                                               stage_view))
         continue;
 
       actor_surface = META_WAYLAND_ACTOR_SURFACE (surface->role);
@@ -215,6 +237,60 @@ emit_frame_callbacks_for_stage_view (MetaWaylandCompositor *compositor,
     }
 }
 
+static gboolean
+emit_layer_shell_frame_callbacks (gpointer user_data)
+{
+  MetaWaylandCompositor *compositor = user_data;
+  MetaWaylandCompositorPrivate *priv =
+    meta_wayland_compositor_get_instance_private (compositor);
+  GList *l;
+  int64_t now_us;
+
+  priv->layer_shell_frame_callback_source_id = 0;
+  now_us = g_get_monotonic_time ();
+
+  l = compositor->frame_callback_surfaces;
+  while (l)
+    {
+      GList *l_cur = l;
+      MetaWaylandSurface *surface = l->data;
+      MetaWaylandActorSurface *actor_surface;
+
+      l = l->next;
+
+      if (!meta_wayland_surface_is_layer_shell (surface))
+        continue;
+
+      actor_surface = META_WAYLAND_ACTOR_SURFACE (surface->role);
+      meta_wayland_actor_surface_emit_frame_callbacks (actor_surface,
+                                                       now_us / 1000);
+
+      compositor->frame_callback_surfaces =
+        g_list_delete_link (compositor->frame_callback_surfaces, l_cur);
+    }
+
+  return G_SOURCE_REMOVE;
+}
+
+static void
+schedule_layer_shell_frame_callbacks (MetaWaylandCompositor *compositor)
+{
+  MetaWaylandCompositorPrivate *priv =
+    meta_wayland_compositor_get_instance_private (compositor);
+
+  if (priv->layer_shell_frame_callback_source_id)
+    return;
+
+  priv->layer_shell_frame_callback_source_id =
+    g_timeout_add_full (G_PRIORITY_DEFAULT,
+                        16,
+                        emit_layer_shell_frame_callbacks,
+                        g_object_ref (compositor),
+                        g_object_unref);
+  g_source_set_name_by_id (priv->layer_shell_frame_callback_source_id,
+                           "[mutter] layer-shell frame callbacks");
+}
+
 #ifdef HAVE_NATIVE_BACKEND
 
 static gboolean
@@ -612,6 +688,9 @@ meta_wayland_compositor_add_frame_callback_surface (MetaWaylandCompositor *compo
 
   compositor->frame_callback_surfaces =
     g_list_prepend (compositor->frame_callback_surfaces, surface);
+
+  if (meta_wayland_surface_is_layer_shell (surface))
+    schedule_layer_shell_frame_callbacks (compositor);
 }
 
 void
@@ -835,6 +914,8 @@ meta_wayland_compositor_finalize (GObject *object)
   g_clear_pointer (&compositor->seat, meta_wayland_seat_free);
   meta_wayland_tablet_manager_finalize (compositor);
 
+  g_clear_handle_id (&priv->layer_shell_frame_callback_source_id,
+                     g_source_remove);
   g_clear_pointer (&priv->filter_manager, meta_wayland_filter_manager_free);
   g_clear_pointer (&priv->frame_callback_sources, g_hash_table_destroy);
 
-- 
2.53.0
